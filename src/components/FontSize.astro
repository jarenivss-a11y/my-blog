---
// FontSize - adjusts article font size for accessibility
---

<div id="font-size-controls" class="fixed right-4 top-1/2 -translate-y-1/2 z-30 hidden md:flex flex-col gap-2">
  <button
    id="font-decrease"
    class="w-10 h-10 rounded-full backdrop-blur-xl bg-white/80 dark:bg-slate-800/80 border border-white/50 dark:border-slate-700/50 shadow-lg flex items-center justify-center text-slate-600 dark:text-slate-300 hover:bg-primary hover:text-white transition-all"
    aria-label="减小字体"
    title="减小字体"
  >
    <span class="text-lg font-bold">A-</span>
  </button>
  <button
    id="font-reset"
    class="w-10 h-10 rounded-full backdrop-blur-xl bg-white/80 dark:bg-slate-800/80 border border-white/50 dark:border-slate-700/50 shadow-lg flex items-center justify-center text-slate-600 dark:text-slate-300 hover:bg-primary hover:text-white transition-all text-xs font-medium"
    aria-label="重置字体"
    title="重置字体"
  >
    A
  </button>
  <button
    id="font-increase"
    class="w-10 h-10 rounded-full backdrop-blur-xl bg-white/80 dark:bg-slate-800/80 border border-white/50 dark:border-slate-700/50 shadow-lg flex items-center justify-center text-slate-600 dark:text-slate-300 hover:bg-primary hover:text-white transition-all"
    aria-label="增大字体"
    title="增大字体"
  >
    <span class="text-lg font-bold">A+</span>
  </button>
</div>

<script is:inline>
  (function() {
    var controls = document.getElementById('font-size-controls');
    var decreaseBtn = document.getElementById('font-decrease');
    var resetBtn = document.getElementById('font-reset');
    var increaseBtn = document.getElementById('font-increase');

    if (!controls || !decreaseBtn || !resetBtn || !increaseBtn) return;

    var STORAGE_KEY = 'blog-font-size';
    var MIN_SIZE = 14;
    var MAX_SIZE = 28;
    var DEFAULT_SIZE = 18;
    var STEP = 2;

    function getSize() {
      var saved = localStorage.getItem(STORAGE_KEY);
      return saved ? parseInt(saved, 10) : DEFAULT_SIZE;
    }

    function applySize(size) {
      var article = document.querySelector('article');
      if (!article) return;
      var proseEl = article.querySelector('.prose');
      if (proseEl) {
        proseEl.style.setProperty('font-size', size + 'px', 'important');
      }
      // Also apply to all direct children of prose for better coverage
      var allElements = article.querySelectorAll('.prose p, .prose li, .prose h1, .prose h2, .prose h3, .prose h4, .prose h5, .prose h6');
      allElements.forEach(function(el) {
        if (el.tagName.match(/^H[1-6]$/)) {
          el.style.setProperty('font-size', Math.min(size + 4, size * 1.3) + 'px', 'important');
        } else {
          el.style.setProperty('font-size', size + 'px', 'important');
        }
      });
    }

    function setSize(size) {
      var clampedSize = Math.min(MAX_SIZE, Math.max(MIN_SIZE, size));
      localStorage.setItem(STORAGE_KEY, clampedSize.toString());
      applySize(clampedSize);
      updateButtons(clampedSize);
    }

    function updateButtons(currentSize) {
      decreaseBtn.classList.toggle('opacity-50', currentSize <= MIN_SIZE);
      increaseBtn.classList.toggle('opacity-50', currentSize >= MAX_SIZE);
    }

    // Initialize
    var initialSize = getSize();
    setSize(initialSize);

    // Show controls on article pages
    var article = document.querySelector('article');
    if (article) {
      controls.classList.remove('hidden');
    }

    decreaseBtn.addEventListener('click', function() {
      setSize(getSize() - STEP);
    });

    resetBtn.addEventListener('click', function() {
      setSize(DEFAULT_SIZE);
    });

    increaseBtn.addEventListener('click', function() {
      setSize(getSize() + STEP);
    });
  })();
</script>