---
// FontSize - adjusts article font size for accessibility
---

<div id="font-size-controls" class="fixed right-4 top-1/2 -translate-y-1/2 z-30 hidden md:flex flex-col gap-2">
  <button
    id="font-decrease"
    class="w-10 h-10 rounded-full backdrop-blur-xl bg-white/80 dark:bg-slate-800/80 border border-white/50 dark:border-slate-700/50 shadow-lg flex items-center justify-center text-slate-600 dark:text-slate-300 hover:bg-primary hover:text-white transition-all"
    aria-label="减小字体"
    title="减小字体"
  >
    <span class="text-lg font-bold">A-</span>
  </button>
  <button
    id="font-reset"
    class="w-10 h-10 rounded-full backdrop-blur-xl bg-white/80 dark:bg-slate-800/80 border border-white/50 dark:border-slate-700/50 shadow-lg flex items-center justify-center text-slate-600 dark:text-slate-300 hover:bg-primary hover:text-white transition-all text-xs font-medium"
    aria-label="重置字体"
    title="重置字体"
  >
    A
  </button>
  <button
    id="font-increase"
    class="w-10 h-10 rounded-full backdrop-blur-xl bg-white/80 dark:bg-slate-800/80 border border-white/50 dark:border-slate-700/50 shadow-lg flex items-center justify-center text-slate-600 dark:text-slate-300 hover:bg-primary hover:text-white transition-all"
    aria-label="增大字体"
    title="增大字体"
  >
    <span class="text-lg font-bold">A+</span>
  </button>
</div>

<style is:global>
  /* Font size classes */
  body.font-size-14 .prose, body.font-size-14 .prose p, body.font-size-14 .prose li { font-size: 14px !important; }
  body.font-size-16 .prose, body.font-size-16 .prose p, body.font-size-16 .prose li { font-size: 16px !important; }
  body.font-size-18 .prose, body.font-size-18 .prose p, body.font-size-18 .prose li { font-size: 18px !important; }
  body.font-size-20 .prose, body.font-size-20 .prose p, body.font-size-20 .prose li { font-size: 20px !important; }
  body.font-size-22 .prose, body.font-size-22 .prose p, body.font-size-22 .prose li { font-size: 22px !important; }
  body.font-size-24 .prose, body.font-size-24 .prose p, body.font-size-24 .prose li { font-size: 24px !important; }
  body.font-size-26 .prose, body.font-size-26 .prose p, body.font-size-26 .prose li { font-size: 26px !important; }
  body.font-size-28 .prose, body.font-size-28 .prose p, body.font-size-28 .prose li { font-size: 28px !important; }
</style>

<script is:inline>
  (function() {
    var controls = document.getElementById('font-size-controls');
    var decreaseBtn = document.getElementById('font-decrease');
    var resetBtn = document.getElementById('font-reset');
    var increaseBtn = document.getElementById('font-increase');

    if (!controls || !decreaseBtn || !resetBtn || !increaseBtn) return;

    var STORAGE_KEY = 'blog-font-size';
    var SIZES = [14, 16, 18, 20, 22, 24, 26, 28];
    var DEFAULT_INDEX = 2; // 18px

    function getIndex() {
      var saved = localStorage.getItem(STORAGE_KEY);
      if (saved) {
        var idx = SIZES.indexOf(parseInt(saved, 10));
        if (idx !== -1) return idx;
      }
      return DEFAULT_INDEX;
    }

    function applySize(index) {
      var size = SIZES[index];
      var body = document.body;

      // Remove all font size classes
      SIZES.forEach(function(s) {
        body.classList.remove('font-size-' + s);
      });

      // Add current font size class
      body.classList.add('font-size-' + size);

      // Save to localStorage
      localStorage.setItem(STORAGE_KEY, size.toString());

      // Update button states
      updateButtons(index);
    }

    function updateButtons(index) {
      decreaseBtn.classList.toggle('opacity-50', index <= 0);
      increaseBtn.classList.toggle('opacity-50', index >= SIZES.length - 1);
    }

    // Initialize
    var currentIndex = getIndex();
    applySize(currentIndex);

    // Show controls on article pages
    var article = document.querySelector('article');
    if (article) {
      controls.classList.remove('hidden');
    }

    decreaseBtn.addEventListener('click', function() {
      if (currentIndex > 0) {
        currentIndex--;
        applySize(currentIndex);
      }
    });

    resetBtn.addEventListener('click', function() {
      currentIndex = DEFAULT_INDEX;
      applySize(currentIndex);
    });

    increaseBtn.addEventListener('click', function() {
      if (currentIndex < SIZES.length - 1) {
        currentIndex++;
        applySize(currentIndex);
      }
    });
  })();
</script>
