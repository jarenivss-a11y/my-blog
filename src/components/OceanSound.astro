---
// Ocean Sound - Ocean waves ambient with water ripple sounds
---

<button
  id="ocean-sound-btn"
  class="fixed bottom-4 left-4 z-50 p-3 rounded-full backdrop-blur-xl bg-white/80 dark:bg-slate-800/80 border border-white/50 dark:border-slate-700/50 shadow-lg hover:shadow-xl transition-all hover:scale-105 flex items-center justify-center"
  aria-label="海浪声"
  title="海浪声 - 点击开启/关闭"
>
  <svg id="sound-icon-on" class="w-5 h-5 text-slate-600 dark:text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"/>
  </svg>
  <svg id="sound-icon-off" class="w-5 h-5 text-slate-600 dark:text-slate-300 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z"/>
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2"/>
  </svg>
</button>

<script>
  function initOceanSound() {
    const btn = document.getElementById('ocean-sound-btn');
    const iconOn = document.getElementById('sound-icon-on');
    const iconOff = document.getElementById('sound-icon-off');
    if (!btn || !iconOn || !iconOff) return;

    let audioContext = null;
    let isPlaying = false;
    let masterGain = null;

    function createOceanSound() {
      if (audioContext) return;
      audioContext = new (window.AudioContext || window.webkitAudioContext)();
      masterGain = audioContext.createGain();
      masterGain.gain.value = 0.25;
      masterGain.connect(audioContext.destination);

      // Deep ocean base - brown noise
      const deepBuffer = audioContext.createBuffer(1, 4 * audioContext.sampleRate, audioContext.sampleRate);
      const deepData = deepBuffer.getChannelData(0);
      let lastOut = 0;
      for (let i = 0; i < deepData.length; i++) {
        const white = Math.random() * 2 - 1;
        deepData[i] = (lastOut + (0.02 * white)) / 1.02;
        lastOut = deepData[i];
        deepData[i] *= 3.5;
      }
      const deepSource = audioContext.createBufferSource();
      deepSource.buffer = deepBuffer;
      deepSource.loop = true;
      const deepFilter = audioContext.createBiquadFilter();
      deepFilter.type = 'lowpass';
      deepFilter.frequency.value = 150;
      const deepGain = audioContext.createGain();
      deepGain.gain.value = 0.4;
      deepSource.connect(deepFilter);
      deepFilter.connect(deepGain);
      deepGain.connect(masterGain);
      deepSource.start();

      // Wave modulation LFO
      const waveLfo = audioContext.createOscillator();
      const waveLfoGain = audioContext.createGain();
      waveLfo.frequency.value = 0.08;
      waveLfoGain.gain.value = 0.15;
      waveLfo.connect(waveLfoGain);
      waveLfoGain.connect(deepGain.gain);
      waveLfo.start();

      // Tide - pink noise with slow modulation
      const tideBuffer = audioContext.createBuffer(1, 4 * audioContext.sampleRate, audioContext.sampleRate);
      const tideData = tideBuffer.getChannelData(0);
      let b0 = 0, b1 = 0, b2 = 0, b3 = 0, b4 = 0, b5 = 0, b6 = 0;
      for (let i = 0; i < tideData.length; i++) {
        const white = Math.random() * 2 - 1;
        b0 = 0.99886 * b0 + white * 0.0555179;
        b1 = 0.99332 * b1 + white * 0.0750759;
        b2 = 0.96900 * b2 + white * 0.1538520;
        b3 = 0.86650 * b3 + white * 0.3104856;
        b4 = 0.55000 * b4 + white * 0.5329522;
        b5 = -0.7616 * b5 - white * 0.0168980;
        tideData[i] = b0 + b1 + b2 + b3 + b4 + b5 + b6 + white * 0.5362;
        tideData[i] *= 0.11;
        b6 = white * 0.115926;
      }
      const tideSource = audioContext.createBufferSource();
      tideSource.buffer = tideBuffer;
      tideSource.loop = true;
      const tideFilter = audioContext.createBiquadFilter();
      tideFilter.type = 'lowpass';
      tideFilter.frequency.value = 400;
      const tideGain = audioContext.createGain();
      tideGain.gain.value = 0.35;
      tideSource.connect(tideFilter);
      tideFilter.connect(tideGain);
      tideGain.connect(masterGain);
      tideSource.start();

      // Tide swell LFO (slow rise and fall)
      const tideLfo = audioContext.createOscillator();
      const tideLfoGain = audioContext.createGain();
      tideLfo.frequency.value = 0.05;
      tideLfoGain.gain.value = 0.25;
      tideLfo.connect(tideLfoGain);
      tideLfoGain.connect(tideGain.gain);
      tideLfo.start();

      // High frequency ripple
      const rippleBuffer = audioContext.createBuffer(1, 2 * audioContext.sampleRate, audioContext.sampleRate);
      const rippleData = rippleBuffer.getChannelData(0);
      for (let i = 0; i < rippleData.length; i++) {
        rippleData[i] = Math.random() * 2 - 1;
      }
      const rippleSource = audioContext.createBufferSource();
      rippleSource.buffer = rippleBuffer;
      rippleSource.loop = true;
      const rippleFilter = audioContext.createBiquadFilter();
      rippleFilter.type = 'highpass';
      rippleFilter.frequency.value = 2000;
      const rippleGainNode = audioContext.createGain();
      rippleGainNode.gain.value = 0.08;
      rippleSource.connect(rippleFilter);
      rippleFilter.connect(rippleGainNode);
      rippleGainNode.connect(masterGain);
      rippleSource.start();
    }

    function playRippleSound() {
      if (!isPlaying || !audioContext || !masterGain) return;
      const osc = audioContext.createOscillator();
      const gain = audioContext.createGain();
      osc.frequency.value = 600 + Math.random() * 300;
      osc.type = 'sine';
      gain.gain.value = 0.03;
      gain.gain.exponentialRampToValueAtTime(0.001, audioContext.currentTime + 0.2);
      osc.connect(gain);
      gain.connect(masterGain);
      osc.start();
      osc.stop(audioContext.currentTime + 0.2);
    }

    function toggleSound() {
      if (!isPlaying) {
        createOceanSound();
        if (audioContext && audioContext.state === 'suspended') {
          audioContext.resume();
        }
        iconOn.classList.add('hidden');
        iconOff.classList.remove('hidden');
        isPlaying = true;
        localStorage.setItem('ocean-sound-playing', 'true');
      } else {
        if (audioContext) {
          audioContext.close();
          audioContext = null;
        }
        iconOn.classList.remove('hidden');
        iconOff.classList.add('hidden');
        isPlaying = false;
        localStorage.setItem('ocean-sound-playing', 'false');
      }
    }

    btn.addEventListener('click', toggleSound);

    let lastRipple = 0;
    document.addEventListener('mousemove', function() {
      var now = Date.now();
      if (now - lastRipple > 80) {
        playRippleSound();
        lastRipple = now;
      }
    });

    if (localStorage.getItem('ocean-sound-playing') === 'true') {
      toggleSound();
    }
  }

  initOceanSound();
  document.addEventListener('astro:after-swap', initOceanSound);
</script>
