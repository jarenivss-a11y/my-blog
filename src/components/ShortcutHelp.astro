---
// ShortcutHelp - shows keyboard shortcut help modal
---

<button
  id="shortcut-help-btn"
  class="fixed right-4 bottom-4 z-40 p-3 rounded-full backdrop-blur-xl bg-[rgba(155,180,218,0.1)] border border-[rgba(80,128,176,0.3)] shadow-lg hover:shadow-[0_8px 32px_rgba(80,128,176,0.3)] transition-all hover:scale-105 hover:bg-[rgba(80,128,176,0.3)]"
  aria-label="键盘快捷键"
  title="键盘快捷键"
>
  <svg class="w-5 h-5 text-[#72a8d8]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
  </svg>
</button>

<!-- Shortcut Help Modal -->
<div id="shortcut-modal" class="hidden fixed inset-0 z-[200] flex items-center justify-center">
  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" id="shortcut-overlay"></div>
  <div class="relative rounded-2xl shadow-2xl max-w-md w-full mx-4 overflow-hidden backdrop-blur-xl bg-[rgba(30,45,65,0.95)] border border-[rgba(80,128,176,0.3)]">
    <div class="flex items-center justify-between p-6 border-b border-[rgba(80,128,176,0.2)]">
      <h3 class="text-lg font-bold text-[#e2e9f5]">键盘快捷键</h3>
      <button id="shortcut-close" class="p-2 hover:bg-[rgba(80,128,176,0.2)] rounded-lg transition-colors">
        <svg class="w-5 h-5 text-[#8a9cc4]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <div class="p-6 space-y-4">
      <div class="space-y-3">
        <h4 class="text-sm font-medium text-[#8a9cc4] uppercase tracking-wider">导航</h4>
        <div class="space-y-2">
          <div class="flex items-center justify-between">
            <span class="text-[#b2c0d8]">首页</span>
            <kbd class="px-2 py-1 bg-[rgba(80,128,176,0.2)] rounded text-sm font-mono text-[#72a8d8]">G then H</kbd>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-[#b2c0d8]">归档</span>
            <kbd class="px-2 py-1 bg-[rgba(80,128,176,0.2)] rounded text-sm font-mono text-[#72a8d8]">G then A</kbd>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-[#b2c0d8]">搜索</span>
            <kbd class="px-2 py-1 bg-[rgba(80,128,176,0.2)] rounded text-sm font-mono text-[#72a8d8]">/</kbd>
          </div>
        </div>
      </div>
      <div class="space-y-3">
        <h4 class="text-sm font-medium text-[#8a9cc4] uppercase tracking-wider">文章</h4>
        <div class="space-y-2">
          <div class="flex items-center justify-between">
            <span class="text-[#b2c0d8]">阅读模式</span>
            <kbd class="px-2 py-1 bg-[rgba(80,128,176,0.2)] rounded text-sm font-mono text-[#72a8d8]">R</kbd>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-[#b2c0d8]">朗读文章</span>
            <kbd class="px-2 py-1 bg-[rgba(80,128,176,0.2)] rounded text-sm font-mono text-[#72a8d8]">P</kbd>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-[#b2c0d8]">返回顶部</span>
            <kbd class="px-2 py-1 bg-[rgba(80,128,176,0.2)] rounded text-sm font-mono text-[#72a8d8]">T</kbd>
          </div>
        </div>
      </div>
      <div class="space-y-3">
        <h4 class="text-sm font-medium text-[#8a9cc4] uppercase tracking-wider">其他</h4>
        <div class="space-y-2">
          <div class="flex items-center justify-between">
            <span class="text-[#b2c0d8]">切换主题</span>
            <kbd class="px-2 py-1 bg-[rgba(80,128,176,0.2)] rounded text-sm font-mono text-[#72a8d8]">D</kbd>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-[#b2c0d8]">显示帮助</span>
            <kbd class="px-2 py-1 bg-[rgba(80,128,176,0.2)] rounded text-sm font-mono text-[#72a8d8]">?</kbd>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function initShortcutHelp() {
    const btn = document.getElementById('shortcut-help-btn');
    const modal = document.getElementById('shortcut-modal');
    const closeBtn = document.getElementById('shortcut-close');
    const overlay = document.getElementById('shortcut-overlay');

    if (!btn || !modal) return;

    function openModal() {
      modal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      modal.classList.add('hidden');
      document.body.style.overflow = '';
    }

    btn.addEventListener('click', openModal);
    closeBtn?.addEventListener('click', closeModal);
    overlay?.addEventListener('click', closeModal);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
        closeModal();
      }
      if (e.key === '?' && !e.ctrlKey && !e.metaKey && !e.altKey) {
        const target = e.target as HTMLElement;
        if (target.tagName !== 'INPUT' && target.tagName !== 'TEXTAREA') {
          e.preventDefault();
          openModal();
        }
      }
    });
  }

  initShortcutHelp();
  document.addEventListener('astro:after-swap', initShortcutHelp);
</script>