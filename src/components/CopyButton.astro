<script>
  function getLanguageFromClass(className) {
    const match = className.match(/language-(\w+)/);
    return match ? match[1] : null;
  }

  function initCopyButtons() {
    document.querySelectorAll('pre').forEach((pre) => {
      if (pre.querySelector('.copy-btn')) return;

      const wrapper = document.createElement('div');
      wrapper.className = 'code-block-wrapper relative group';
      pre.parentNode?.insertBefore(wrapper, pre);
      wrapper.appendChild(pre);

      // Add language label
      const code = pre.querySelector('code');
      const langClass = Array.from(code?.classList || []).find(c => c.startsWith('language-'));
      const language = langClass ? getLanguageFromClass(langClass) : null;

      if (language) {
        const langLabel = document.createElement('span');
        langLabel.className = 'code-lang absolute top-3 left-3 px-2 py-1 rounded text-xs font-mono bg-[rgba(80,128,176,0.3)] text-[#72a8d8] uppercase';
        langLabel.textContent = language;
        wrapper.appendChild(langLabel);
      }

      const btn = document.createElement('button');
      btn.className = 'copy-btn absolute top-3 right-3 p-2 rounded-lg bg-[rgba(80,128,176,0.2)] text-[#72a8d8] opacity-0 group-hover:opacity-100 hover:bg-[rgba(80,128,176,0.3)] transition-all duration-200';
      btn.setAttribute('aria-label', '复制代码');
      btn.innerHTML = `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>`;
      wrapper.appendChild(btn);

      const codeText = code?.textContent || '';
      btn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(codeText);
          // Show checkmark on button
          const originalHTML = btn.innerHTML;
          btn.innerHTML = `<svg class="w-4 h-4 text-[#72a8d8]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>`;
          btn.classList.add('text-[#72a8d8]');
          setTimeout(() => {
            btn.innerHTML = originalHTML;
            btn.classList.remove('text-[#72a8d8]');
          }, 2000);
        } catch (err) {
          console.error('复制失败:', err);
        }
      });
    });
  }

  initCopyButtons();
  document.addEventListener('astro:after-swap', initCopyButtons);
</script>