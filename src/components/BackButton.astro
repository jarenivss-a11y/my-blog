---
// Back Button - returns to previous page
---

<button
  id="back-button"
  class="fixed left-4 bottom-24 z-50 p-3 rounded-full backdrop-blur-xl bg-[rgba(155,180,218,0.1)] border border-[rgba(80,128,176,0.3)] shadow-lg hover:shadow-[0_8px 32px_rgba(80,128,176,0.3)] transition-all hover:scale-105 opacity-0 pointer-events-none translate-x-[-20px]"
  aria-label="返回上一页"
>
  <svg class="w-5 h-5 text-[#72a8d8]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
  </svg>
</button>

<script>
  function initBackButton() {
    const btn = document.getElementById('back-button');
    if (!btn) return;

    // Check if there's a previous page in history
    const hasHistory = document.referrer && document.referrer.includes(window.location.hostname);

    if (hasHistory) {
      btn.classList.remove('opacity-0', 'pointer-events-none', 'translate-x-[-20px]');
    }

    btn.addEventListener('click', () => {
      if (window.history.length > 1) {
        window.history.back();
      } else {
        window.location.href = '/my-blog';
      }
    });
  }

  initBackButton();
  document.addEventListener('astro:after-swap', initBackButton);
</script>