---
// Theme Color Picker Component
---

<div id="theme-color-picker" class="fixed bottom-24 right-4 z-50">
  <button
    id="color-picker-toggle"
    class="p-3 rounded-full backdrop-blur-xl bg-[rgba(155,180,218,0.1)] border border-[rgba(80,128,176,0.3)] shadow-lg hover:shadow-[0_8px 32px_rgba(80,128,176,0.3)] transition-all"
    aria-label="切换主题色"
  >
    <svg class="w-5 h-5 text-[#72a8d8]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/>
    </svg>
  </button>

  <div id="color-picker-panel" class="hidden absolute bottom-14 right-0 p-4 rounded-2xl backdrop-blur-xl bg-[rgba(30,45,65,0.95)] border border-[rgba(80,128,176,0.3)] shadow-xl min-w-[200px]">
    <h4 class="text-xs font-medium text-[#8a9cc4] uppercase tracking-widest mb-3">主题色</h4>
    <div class="grid grid-cols-6 gap-2 mb-4">
      <button class="color-option w-8 h-8 rounded-full bg-[#6366f1] hover:ring-2 ring-offset-2 ring-[#6366f1] transition-all" data-color="#6366f1" data-primary="indigo"></button>
      <button class="color-option w-8 h-8 rounded-full bg-[#5080b0] hover:ring-2 ring-offset-2 ring-[#5080b0] transition-all" data-color="#5080b0" data-primary="ocean"></button>
      <button class="color-option w-8 h-8 rounded-full bg-[#72a8d8] hover:ring-2 ring-offset-2 ring-[#72a8d8] transition-all" data-color="#72a8d8" data-primary="sky"></button>
      <button class="color-option w-8 h-8 rounded-full bg-[#06b6d4] hover:ring-2 ring-offset-2 ring-[#06b6d4] transition-all" data-color="#06b6d4" data-primary="cyan"></button>
      <button class="color-option w-8 h-8 rounded-full bg-[#14b8a6] hover:ring-2 ring-offset-2 ring-[#14b8a6] transition-all" data-color="#14b8a6" data-primary="teal"></button>
      <button class="color-option w-8 h-8 rounded-full bg-[#22c55e] hover:ring-2 ring-offset-2 ring-[#22c55e] transition-all" data-color="#22c55e" data-primary="green"></button>
      <button class="color-option w-8 h-8 rounded-full bg-[#10b981] hover:ring-2 ring-offset-2 ring-[#10b981] transition-all" data-color="#10b981" data-primary="emerald"></button>
      <button class="color-option w-8 h-8 rounded-full bg-[#f59e0b] hover:ring-2 ring-offset-2 ring-[#f59e0b] transition-all" data-color="#f59e0b" data-primary="amber"></button>
      <button class="color-option w-8 h-8 rounded-full bg-[#f97316] hover:ring-2 ring-offset-2 ring-[#f97316] transition-all" data-color="#f97316" data-primary="orange"></button>
      <button class="color-option w-8 h-8 rounded-full bg-[#ef4444] hover:ring-2 ring-offset-2 ring-[#ef4444] transition-all" data-color="#ef4444" data-primary="red"></button>
      <button class="color-option w-8 h-8 rounded-full bg-[#ec4899] hover:ring-2 ring-offset-2 ring-[#ec4899] transition-all" data-color="#ec4899" data-primary="pink"></button>
      <button class="color-option w-8 h-8 rounded-full bg-[#a855f7] hover:ring-2 ring-offset-2 ring-[#a855f7] transition-all" data-color="#a855f7" data-primary="purple"></button>
    </div>
    <div class="flex items-center gap-2">
      <input type="color" id="custom-color" value="#5080b0" class="w-8 h-8 rounded cursor-pointer border-0 bg-transparent" />
      <span class="text-sm text-[#8a9cc4]">自定义颜色</span>
    </div>
  </div>
</div>

<script>
  const STORAGE_KEY = 'blog-theme-color';

  function initThemeColorPicker() {
    const toggle = document.getElementById('color-picker-toggle');
    const panel = document.getElementById('color-picker-panel');
    const colorOptions = document.querySelectorAll('.color-option');
    const customColor = document.getElementById('custom-color') as HTMLInputElement;

    if (!toggle || !panel) return;

    toggle.addEventListener('click', () => {
      panel.classList.toggle('hidden');
    });

    document.addEventListener('click', (e) => {
      if (!toggle.contains(e.target as Node) && !panel.contains(e.target as Node)) {
        panel.classList.add('hidden');
      }
    });

    const savedColor = localStorage.getItem(STORAGE_KEY);
    if (savedColor) {
      applyThemeColor(savedColor);
    }

    colorOptions.forEach(btn => {
      btn.addEventListener('click', () => {
        const color = btn.getAttribute('data-color');
        if (color) {
          applyThemeColor(color);
          localStorage.setItem(STORAGE_KEY, color);
        }
      });
    });

    if (customColor) {
      customColor.addEventListener('input', () => {
        applyThemeColor(customColor.value);
        localStorage.setItem(STORAGE_KEY, customColor.value);
      });
    }
  }

  function applyThemeColor(color: string) {
    document.documentElement.style.setProperty('--color-primary', color);

    // Calculate lighter and darker variants
    const hex = color.replace('#', '');
    const r = parseInt(hex.substring(0, 2), 16);
    const g = parseInt(hex.substring(2, 4), 16);
    const b = parseInt(hex.substring(4, 6), 16);

    document.documentElement.style.setProperty('--color-primary-light', `rgba(${r}, ${g}, ${b}, 0.12)`);
    document.documentElement.style.setProperty('--color-primary-dark', `rgba(${r}, ${g}, ${b}, 0.25)`);

    // Update all elements with inline primary colors
    document.querySelectorAll('[style*="--color-primary"]').forEach(el => {
      (el as HTMLElement).style.setProperty('--color-primary', color);
    });

    const customColor = document.getElementById('custom-color') as HTMLInputElement;
    if (customColor) {
      customColor.value = color;
    }

    document.querySelectorAll('.color-option').forEach(btn => {
      if (btn.getAttribute('data-color') === color) {
        btn.classList.add('ring-2', 'ring-offset-2');
      } else {
        btn.classList.remove('ring-2', 'ring-offset-2');
      }
    });
  }

  initThemeColorPicker();
  document.addEventListener('astro:after-swap', initThemeColorPicker);
</script>