---
interface Props {
  postId: string;
}

const { postId } = Astro.props;
---

<div class="reaction-container mt-8 p-6 rounded-2xl backdrop-blur-xl bg-white/50 dark:bg-slate-800/50 border border-white/50 dark:border-slate-700/50">
  <h3 class="text-sm font-medium text-slate-500 dark:text-slate-400 mb-4 text-center">觉得这篇文章如何？</h3>
  <div class="reaction-buttons flex justify-center gap-4">
    <button class="reaction-btn" data-reaction="like" data-post={postId}>
      <span class="reaction-icon text-2xl">👍</span>
      <span class="reaction-count text-sm text-slate-500 ml-1" id="like-count">0</span>
    </button>
    <button class="reaction-btn" data-reaction="love" data-post={postId}>
      <span class="reaction-icon text-2xl">❤️</span>
      <span class="reaction-count text-sm text-slate-500 ml-1" id="love-count">0</span>
    </button>
    <button class="reaction-btn" data-reaction="useful" data-post={postId}>
      <span class="reaction-icon text-2xl">💡</span>
      <span class="reaction-count text-sm text-slate-500 ml-1" id="useful-count">0</span>
    </button>
    <button class="reaction-btn" data-reaction="awesome" data-post={postId}>
      <span class="reaction-icon text-2xl">🚀</span>
      <span class="reaction-count text-sm text-slate-500 ml-1" id="awesome-count">0</span>
    </button>
  </div>
</div>

<style>
  .reaction-btn {
    @apply flex items-center px-4 py-2 rounded-full bg-slate-100 dark:bg-slate-700/50 hover:bg-slate-200 dark:hover:bg-slate-700 transition-all;
  }
  .reaction-btn:hover {
    transform: scale(1.1);
  }
  .reaction-btn.active {
    background-color: var(--color-primary-light);
    box-shadow: 0 0 0 2px var(--color-primary);
  }
  .reaction-icon {
    @apply transition-transform;
  }
  .reaction-btn:hover .reaction-icon {
    transform: scale(1.25);
  }
</style>

<script>
  function initReactions() {
    const buttons = document.querySelectorAll('.reaction-btn');
    const STORAGE_KEY = 'blog-reactions';

    function getReactions() {
      try {
        return JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
      } catch {
        return {};
      }
    }

    function saveReaction(postId: string, reaction: string) {
      const reactions = getReactions();
      if (!reactions[postId]) {
        reactions[postId] = {};
      }
      reactions[postId][reaction] = (reactions[postId][reaction] || 0) + 1;
      localStorage.setItem(STORAGE_KEY, JSON.stringify(reactions));
      updateDisplay();
    }

    function updateDisplay() {
      buttons.forEach(btn => {
        const postId = btn.getAttribute('data-post');
        const reaction = btn.getAttribute('data-reaction');
        const countEl = btn.querySelector('.reaction-count');
        const reactions = getReactions();

        if (postId && reaction && countEl) {
          const count = reactions[postId]?.[reaction] || 0;
          countEl.textContent = count.toString();
        }
      });
    }

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const postId = btn.getAttribute('data-post');
        const reaction = btn.getAttribute('data-reaction');
        if (postId && reaction) {
          saveReaction(postId, reaction);
          btn.classList.add('active');
          setTimeout(() => btn.classList.remove('active'), 300);
        }
      });
    });

    updateDisplay();
  }

  initReactions();
  document.addEventListener('astro:after-swap', initReactions);
</script>
