---
// OceanWebGL - Three.js WebGL realistic ocean waves
---

<div id="ocean-webgl-container" class="fixed inset-0 w-full h-full pointer-events-none z-0 overflow-hidden">
  <canvas id="ocean-webgl-canvas"></canvas>
</div>

<script>
  import * as THREE from 'three';

  function initOceanWebGL() {
    const container = document.getElementById('ocean-webgl-container');
    const canvas = document.getElementById('ocean-webgl-canvas');
    if (!container || !canvas) return;

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
    camera.position.set(0, 15, 30);
    camera.lookAt(0, 0, 0);

    const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    const geometry = new THREE.PlaneGeometry(200, 200, 256, 256);

    const vertexShader = `
      uniform float uTime;
      uniform vec2 uMouse;
      uniform float uMouseInfluence;
      uniform float uMouseSpeed;
      varying vec2 vUv;
      varying float vElevation;
      varying vec3 vNormal;
      varying vec3 vPosition;
      varying vec3 vWorldPosition;

      vec3 mod289(vec3 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
      vec2 mod289(vec2 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
      vec3 permute(vec3 x) { return mod289(((x*34.0)+1.0)*x); }

      float snoise(vec2 v) {
        const vec4 C = vec4(0.211324865405187, 0.366025403784439, -0.577350269189626, 0.024390243902439);
        vec2 i = floor(v + dot(v, C.yy));
        vec2 x0 = v - i + dot(i, C.xx);
        vec2 i1 = (x0.x > x0.y) ? vec2(1.0, 0.0) : vec2(0.0, 1.0);
        vec4 x12 = x0.xyxy + C.xxzz;
        x12.xy -= i1;
        i = mod289(i);
        vec3 p = permute(permute(i.y + vec3(0.0, i1.y, 1.0)) + i.x + vec3(0.0, i1.x, 1.0));
        vec3 m = max(0.5 - vec3(dot(x0,x0), dot(x12.xy,x12.xy), dot(x12.zw,x12.zw)), 0.0);
        m = m*m; m = m*m;
        vec3 x = 2.0 * fract(p * C.www) - 1.0;
        vec3 h = abs(x) - 0.5;
        vec3 ox = floor(x + 0.5);
        vec3 a0 = x - ox;
        m *= 1.79284291400159 - 0.85373472095314 * (a0*a0 + h*h);
        vec3 g;
        g.x = a0.x * x0.x + h.x * x0.y;
        g.yz = a0.yz * x12.xz + h.yz * x12.yw;
        return 130.0 * dot(m, g);
      }

      // FBM noise for more natural detail
      float fbm(vec2 p) {
        float f = 0.0;
        f += 0.5000 * snoise(p); p *= 2.02;
        f += 0.2500 * snoise(p); p *= 2.03;
        f += 0.1250 * snoise(p); p *= 2.01;
        f += 0.0625 * snoise(p);
        return f / 0.9375;
      }

      vec3 gerstnerWave(vec2 pos, float steepness, float wavelength, vec2 direction, float time) {
        float k = 2.0 * 3.14159 / wavelength;
        float c = sqrt(9.8 / k);
        vec2 d = normalize(direction);
        float f = k * (dot(d, pos) - c * time);
        float a = steepness / k;
        return vec3(d.x * (a * cos(f)), a * sin(f), d.y * (a * cos(f)));
      }

      void main() {
        vUv = uv;
        vec3 pos = position;

        // Multiple Gerstner waves for realistic ocean
        vec3 wave1 = gerstnerWave(pos.xz, 0.20, 80.0, vec2(1.0, 0.2), uTime * 0.6);
        vec3 wave2 = gerstnerWave(pos.xz, 0.15, 50.0, vec2(0.7, 0.5), uTime * 0.8);
        vec3 wave3 = gerstnerWave(pos.xz, 0.12, 30.0, vec2(-0.2, 0.9), uTime * 1.0);
        vec3 wave4 = gerstnerWave(pos.xz, 0.08, 18.0, vec2(0.6, -0.4), uTime * 1.3);
        vec3 wave5 = gerstnerWave(pos.xz, 0.05, 12.0, vec2(-0.5, 0.3), uTime * 1.6);
        vec3 wave6 = gerstnerWave(pos.xz, 0.03, 6.0, vec2(0.3, 0.7), uTime * 2.2);

        vec3 totalWave = wave1 + wave2 + wave3 + wave4 + wave5 + wave6;

        // FBM noise for small details
        float noise1 = fbm(vec2(pos.x * 0.08 + uTime * 0.2, pos.z * 0.08 + uTime * 0.15)) * 0.8;
        float noise2 = fbm(vec2(pos.x * 0.15 - uTime * 0.3, pos.z * 0.12 + uTime * 0.2)) * 0.4;
        float noise3 = snoise(vec2(pos.x * 0.4 + uTime * 0.8, pos.z * 0.4 - uTime * 0.6)) * 0.15;

        // Mouse interaction
        vec2 mousePos = uMouse * 60.0;
        float mouseDist = distance(pos.xz, mousePos);
        float mouseEffect = smoothstep(40.0, 0.0, mouseDist) * uMouseInfluence * 4.0;
        float mouseSpeedEffect = uMouseSpeed * smoothstep(35.0, 0.0, mouseDist) * 2.0;

        pos.x += totalWave.x;
        pos.y += totalWave.y + noise1 + noise2 + noise3;
        pos.z += totalWave.z;

        // Mouse ripples - multiple waves emanating from mouse
        float ripple1 = sin(mouseDist * 0.4 - uTime * 4.0) * mouseEffect;
        float ripple2 = sin(mouseDist * 0.25 - uTime * 3.0) * mouseEffect * 0.5;
        float ripple3 = sin(mouseDist * 0.15 - uTime * 2.0) * mouseEffect * 0.3;

        // Speed-based spray effect
        float spray = sin(mouseDist * 0.8 - uTime * 8.0) * mouseSpeedEffect;

        pos.y += ripple1 + ripple2 + ripple3 + spray;

        vElevation = pos.y;
        vPosition = pos;
        vWorldPosition = (modelMatrix * vec4(pos, 1.0)).xyz;

        // Calculate normals from wave gradients
        float eps = 0.15;
        float hL = 0.0, hR = 0.0, hD = 0.0, hU = 0.0;

        // Sample heights at nearby points for normal calculation
        vec3 pL = pos + vec3(-eps, 0.0, 0.0);
        vec3 pR = pos + vec3(eps, 0.0, 0.0);
        vec3 pD = pos + vec3(0.0, 0.0, -eps);
        vec3 pU = pos + vec3(0.0, 0.0, eps);

        // Simplified normal from wave derivatives
        float waveL = gerstnerWave(pL.xz, 0.12, 30.0, vec2(-0.2, 0.9), uTime * 1.0).y;
        float waveR = gerstnerWave(pR.xz, 0.12, 30.0, vec2(-0.2, 0.9), uTime * 1.0).y;
        float waveD = gerstnerWave(pD.xz, 0.12, 30.0, vec2(-0.2, 0.9), uTime * 1.0).y;
        float waveU = gerstnerWave(pU.xz, 0.12, 30.0, vec2(-0.2, 0.9), uTime * 1.0).y;

        hL = waveL + fbm(vec2(pL.x * 0.08 + uTime * 0.2, pL.z * 0.08 + uTime * 0.15)) * 0.8;
        hR = waveR + fbm(vec2(pR.x * 0.08 + uTime * 0.2, pR.z * 0.08 + uTime * 0.15)) * 0.8;
        hD = waveD + fbm(vec2(pD.x * 0.08 + uTime * 0.2, pD.z * 0.08 + uTime * 0.15)) * 0.8;
        hU = waveU + fbm(vec2(pU.x * 0.08 + uTime * 0.2, pU.z * 0.08 + uTime * 0.15)) * 0.8;

        vNormal = normalize(vec3(hL - hR, 2.0 * eps, hD - hU));

        gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
      }
    `;

    const fragmentShader = `
      precision highp float;
      uniform float uTime;
      uniform vec3 uDeepColor;
      uniform vec3 uMidColor;
      uniform vec3 uSurfaceColor;
      uniform vec3 uFoamColor;
      uniform vec3 uSunDirection;
      uniform vec3 uSkyColor;
      varying vec2 vUv;
      varying float vElevation;
      varying vec3 vNormal;
      varying vec3 vPosition;
      varying vec3 vWorldPosition;

      vec3 mod289(vec3 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
      vec2 mod289(vec2 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
      vec3 permute(vec3 x) { return mod289(((x*34.0)+1.0)*x); }

      float snoise(vec2 v) {
        const vec4 C = vec4(0.211324865405187, 0.366025403784439, -0.577350269189626, 0.024390243902439);
        vec2 i = floor(v + dot(v, C.yy));
        vec2 x0 = v - i + dot(i, C.xx);
        vec2 i1 = (x0.x > x0.y) ? vec2(1.0, 0.0) : vec2(0.0, 1.0);
        vec4 x12 = x0.xyxy + C.xxzz;
        x12.xy -= i1;
        i = mod289(i);
        vec3 p = permute(permute(i.y + vec3(0.0, i1.y, 1.0)) + i.x + vec3(0.0, i1.x, 1.0));
        vec3 m = max(0.5 - vec3(dot(x0,x0), dot(x12.xy,x12.xy), dot(x12.zw,x12.zw)), 0.0);
        m = m*m; m = m*m;
        vec3 x = 2.0 * fract(p * C.www) - 1.0;
        vec3 h = abs(x) - 0.5;
        vec3 ox = floor(x + 0.5);
        vec3 a0 = x - ox;
        m *= 1.79284291400159 - 0.85373472095314 * (a0*a0 + h*h);
        vec3 g;
        g.x = a0.x * x0.x + h.x * x0.y;
        g.yz = a0.yz * x12.xz + h.yz * x12.yw;
        return 130.0 * dot(m, g);
      }

      // Caustic pattern for underwater light
      float caustic(vec2 p, float time) {
        float c1 = snoise(p * 3.0 + time * 0.5);
        float c2 = snoise(p * 5.0 - time * 0.3);
        float c3 = snoise(p * 7.0 + time * 0.7);
        return (c1 + c2 + c3) / 3.0;
      }

      void main() {
        // Multi-stop color gradient for depth
        float depth = smoothstep(-5.0, 5.0, vElevation);
        vec3 color = mix(uDeepColor, uMidColor, smoothstep(0.0, 0.3, depth));
        color = mix(color, uSurfaceColor, smoothstep(0.3, 0.7, depth));

        // Fresnel effect for realistic water reflection
        vec3 viewDirection = normalize(cameraPosition - vPosition);
        float fresnel = pow(1.0 - max(dot(viewDirection, vNormal), 0.0), 4.0);
        fresnel = clamp(fresnel, 0.0, 1.0);

        // Sky reflection
        vec3 reflectDir = reflect(-viewDirection, vNormal);
        float skyReflection = smoothstep(0.0, 1.0, reflectDir.y);
        vec3 skyReflected = mix(vec3(0.4, 0.6, 0.8), uSkyColor, skyReflection);

        // Mix water color with sky reflection
        color = mix(color, skyReflected, fresnel * 0.6);

        // Foam on wave crests with more detail
        float foamNoise = snoise(vPosition.xz * 0.8 + uTime * 0.3) * 0.5 + 0.5;
        float foamNoise2 = snoise(vPosition.xz * 2.0 - uTime * 0.5) * 0.5 + 0.5;
        float foamPattern = foamNoise * foamNoise2;

        float foam = smoothstep(1.5, 2.8, vElevation);
        foam += smoothstep(2.0, 3.5, vElevation + foamPattern * 2.5);
        foam += smoothstep(2.5, 4.0, vElevation + snoise(vPosition.xz * 1.5 + uTime * 0.8) * 3.0);
        foam = clamp(foam, 0.0, 1.0);

        // Foam spray texture
        float foamSpray = snoise(vPosition.xz * 8.0 + uTime * 2.0);
        foamSpray = smoothstep(0.5, 1.0, foamSpray) * foam * 0.3;
        foam = clamp(foam + foamSpray, 0.0, 1.0);

        color = mix(color, uFoamColor, foam * 0.8);

        // Subsurface scattering approximation
        float sss = max(0.0, dot(viewDirection, -uSunDirection)) * 0.3;
        sss *= smoothstep(-2.0, 2.0, vElevation);
        color += vec3(0.1, 0.3, 0.4) * sss;

        // Sun specular reflection
        vec3 sunReflectDir = reflect(-uSunDirection, vNormal);
        float sunSpec = pow(max(dot(viewDirection, sunReflectDir), 0.0), 128.0);
        float sunSpecWide = pow(max(dot(viewDirection, sunReflectDir), 0.0), 16.0);
        color += vec3(1.0, 0.98, 0.9) * sunSpec * 1.2;
        color += vec3(1.0, 0.9, 0.7) * sunSpecWide * 0.15;

        // Shimmer/sparkle effect
        float sparkle = snoise(vPosition.xz * 15.0 + uTime * 3.0);
        sparkle = smoothstep(0.75, 1.0, sparkle);
        float sparkleMask = (1.0 - foam) * smoothstep(0.0, 1.0, vElevation);
        color += vec3(1.0, 1.0, 0.95) * sparkle * sparkleMask * 0.4;

        // Underwater caustic light patterns
        float causticLight = caustic(vPosition.xz * 0.3 + uTime * 0.2, uTime);
        causticLight = pow(abs(causticLight), 2.0) * 0.15;
        color += vec3(0.3, 0.5, 0.6) * causticLight * (1.0 - foam);

        // Atmospheric fog
        float viewDepth = length(vPosition - cameraPosition);
        float fog = smoothstep(40.0, 180.0, viewDepth);
        vec3 fogColor = mix(vec3(0.5, 0.65, 0.8), uSkyColor, 0.5);
        color = mix(color, fogColor, fog * 0.5);

        gl_FragColor = vec4(color, 0.97);
      }
    `;

    const material = new THREE.ShaderMaterial({
      vertexShader,
      fragmentShader,
      uniforms: {
        uTime: { value: 0 },
        uMouse: { value: new THREE.Vector2(0, 0) },
        uMouseInfluence: { value: 0 },
        uMouseSpeed: { value: 0 },
        uDeepColor: { value: new THREE.Color(0x041526) },
        uMidColor: { value: new THREE.Color(0x0a3a5c) },
        uSurfaceColor: { value: new THREE.Color(0x1a6a8a) },
        uFoamColor: { value: new THREE.Color(0xddeeff) },
        uSunDirection: { value: new THREE.Vector3(0.5, 0.8, 0.3).normalize() },
        uSkyColor: { value: new THREE.Color(0x87ceeb) }
      },
      transparent: true,
      side: THREE.DoubleSide
    });

    const ocean = new THREE.Mesh(geometry, material);
    ocean.rotation.x = -Math.PI / 2.2;
    ocean.position.y = -5;
    scene.add(ocean);

    scene.fog = new THREE.Fog(0x4a7a9a, 50, 200);
    scene.add(new THREE.AmbientLight(0x4a6a8a, 0.6));

    const sunLight = new THREE.DirectionalLight(0xffeedd, 0.8);
    sunLight.position.set(50, 100, 50);
    scene.add(sunLight);

    let mouseX = 0, mouseY = 0, mouseInfluence = 0, mouseSpeed = 0;
    let lastMouseX = 0, lastMouseY = 0, lastMouseTime = Date.now();

    document.addEventListener('mousemove', (e) => {
      const newMouseX = (e.clientX / window.innerWidth) * 2 - 1;
      const newMouseY = -(e.clientY / window.innerHeight) * 2 + 1;

      const now = Date.now();
      const dt = now - lastMouseTime;
      if (dt > 0) {
        const dx = newMouseX - lastMouseX;
        const dy = newMouseY - lastMouseY;
        mouseSpeed = Math.sqrt(dx * dx + dy * dy) / dt * 1000;
      }

      mouseX = newMouseX;
      mouseY = newMouseY;
      lastMouseX = mouseX;
      lastMouseY = mouseY;
      lastMouseTime = now;
      mouseInfluence = 1;
    });

    const clock = new THREE.Clock();

    function animate() {
      requestAnimationFrame(animate);
      const elapsedTime = clock.getElapsedTime();
      material.uniforms.uTime.value = elapsedTime;
      material.uniforms.uMouse.value.set(mouseX, mouseY);
      material.uniforms.uMouseInfluence.value *= 0.96;
      material.uniforms.uMouseSpeed.value = mouseSpeed * 0.5;
      mouseSpeed *= 0.9;

      // Dynamic camera movement
      camera.position.x = Math.sin(elapsedTime * 0.03) * 8;
      camera.position.z = 30 + Math.cos(elapsedTime * 0.02) * 5;
      camera.lookAt(0, 0, 0);

      renderer.render(scene, camera);
    }

    window.addEventListener('resize', () => {
      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(window.innerWidth, window.innerHeight);
    });

    animate();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initOceanWebGL);
  } else {
    initOceanWebGL();
  }

  document.addEventListener('astro:after-swap', initOceanWebGL);
</script>
