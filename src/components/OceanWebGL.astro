---
// OceanWebGL - Realistic Three.js WebGL ocean with Gerstner waves
---

<div id="ocean-container" class="fixed inset-0 w-full h-full pointer-events-none z-0 overflow-hidden">
  <canvas id="ocean-canvas"></canvas>
</div>

<script>
  function initOcean() {
    const container = document.getElementById('ocean-container');
    const canvas = document.getElementById('ocean-canvas');
    if (!container || !canvas) return;

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 2000);
    camera.position.set(0, 15, 50);
    camera.lookAt(0, 0, 0);

    const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    // Large ocean plane for realistic perspective
    const geometry = new THREE.PlaneGeometry(400, 400, 200, 200);

    const vertexShader = `
      uniform float uTime;
      uniform vec2 uMouse;
      uniform float uMouseInfluence;

      varying vec2 vUv;
      varying float vElevation;
      varying vec3 vViewPosition;

      // Gerstner wave function
      vec3 gerstnerWave(vec2 pos, float steepness, float wavelength, vec2 direction, float time, float phase) {
        float k = 2.0 * 3.14159 / wavelength;
        float c = sqrt(9.8 / k);
        vec2 d = normalize(direction);
        float f = k * (dot(d, pos) - c * time);
        float a = steepness / k;
        return vec3(
          d.x * (a * cos(f)),
          a * sin(f),
          d.y * (a * cos(f))
        );
      }

      // Noise functions for detail
      vec3 mod289(vec3 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
      vec2 mod289(vec2 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
      vec3 permute(vec3 x) { return mod289(((x*34.0)+1.0)*x); }

      float snoise(vec2 v) {
        const vec4 C = vec4(0.211324865405187, 0.366025403784439, -0.577350269189626, 0.024390243902439);
        vec2 i = floor(v + dot(v, C.yy));
        vec2 x0 = v - i + dot(i, C.xx);
        vec2 i1 = (x0.x > x0.y) ? vec2(1.0, 0.0) : vec2(0.0, 1.0);
        vec4 x12 = x0.xyxy + C.xxzz;
        x12.xy -= i1;
        i = mod289(i);
        vec3 p = permute(permute(i.y + vec3(0.0, i1.y, 1.0)) + i.x + vec3(0.0, i1.x, 1.0));
        vec3 m = max(0.5 - vec3(dot(x0,x0), dot(x12.xy,x12.xy), dot(x12.zw,x12.zw)), 0.0);
        m = m*m; m = m*m;
        vec3 x = 2.0 * fract(p * C.www) - 1.0;
        vec3 h = abs(x) - 0.5;
        vec3 ox = floor(x + 0.5);
        vec3 a0 = x - ox;
        m *= 1.79284291400159 - 0.85373472095314 * (a0*a0 + h*h);
        vec3 g;
        g.x = a0.x * x0.x + h.x * x0.y;
        g.yz = a0.yz * x12.xz + h.yz * x12.yw;
        return 130.0 * dot(m, g);
      }

      float fbm(vec2 p) {
        float f = 0.0;
        f += 0.5000 * snoise(p); p *= 2.02;
        f += 0.2500 * snoise(p); p *= 2.03;
        f += 0.1250 * snoise(p); p *= 2.01;
        f += 0.0625 * snoise(p);
        return f / 0.9375;
      }

      void main() {
        vUv = uv;
        vec3 pos = position;

        // Multiple Gerstner waves for realistic ocean
        vec3 wave1 = gerstnerWave(pos.xz, 0.35, 80.0, vec2(1.0, 0.3), uTime * 0.5, 0.0);
        vec3 wave2 = gerstnerWave(pos.xz, 0.28, 50.0, vec2(0.7, 0.6), uTime * 0.7, 1.0);
        vec3 wave3 = gerstnerWave(pos.xz, 0.22, 35.0, vec2(-0.3, 0.8), uTime * 0.9, 2.0);
        vec3 wave4 = gerstnerWave(pos.xz, 0.18, 25.0, vec2(0.5, -0.5), uTime * 1.1, 0.5);
        vec3 wave5 = gerstnerWave(pos.xz, 0.12, 18.0, vec2(-0.6, 0.4), uTime * 1.3, 1.5);
        vec3 wave6 = gerstnerWave(pos.xz, 0.08, 12.0, vec2(0.2, -0.7), uTime * 1.6, 2.5);

        vec3 totalWave = wave1 + wave2 + wave3 + wave4 + wave5 + wave6;

        // FBM noise for foam detail
        float noise1 = fbm(vec2(pos.x * 0.05 + uTime * 0.15, pos.z * 0.05 + uTime * 0.1)) * 1.2;
        float noise2 = fbm(vec2(pos.x * 0.1 - uTime * 0.2, pos.z * 0.08 + uTime * 0.15)) * 0.6;

        // Mouse interaction - create ripples
        vec2 mouseWorld = uMouse * 80.0;
        float mouseDist = distance(pos.xz, mouseWorld);
        float mouseRipple = sin(mouseDist * 0.3 - uTime * 3.0) * exp(-mouseDist * 0.03) * uMouseInfluence * 3.0;
        float mouseFoam = smoothstep(0.3, 0.8, mouseRipple) * uMouseInfluence;

        pos.x += totalWave.x;
        pos.y += totalWave.y + noise1 + noise2;
        pos.z += totalWave.z;
        pos.y += mouseRipple;

        vElevation = pos.y;

        vec4 mvPosition = modelViewMatrix * vec4(pos, 1.0);
        vViewPosition = -mvPosition.xyz;

        gl_Position = projectionMatrix * mvPosition;
      }
    `;

    const fragmentShader = `
      precision highp float;

      uniform float uTime;
      uniform vec3 uDeepColor;
      uniform vec3 uMidColor;
      uniform vec3 uSurfaceColor;
      uniform vec3 uFoamColor;
      uniform vec3 uSunColor;
      uniform vec3 uSkyColor;

      varying vec2 vUv;
      varying float vElevation;
      varying vec3 vViewPosition;

      vec3 mod289(vec3 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
      vec2 mod289(vec2 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
      vec3 permute(vec3 x) { return mod289(((x*34.0)+1.0)*x); }

      float snoise(vec2 v) {
        const vec4 C = vec4(0.211324865405187, 0.366025403784439, -0.577350269189626, 0.024390243902439);
        vec2 i = floor(v + dot(v, C.yy));
        vec2 x0 = v - i + dot(i, C.xx);
        vec2 i1 = (x0.x > x0.y) ? vec2(1.0, 0.0) : vec2(0.0, 1.0);
        vec4 x12 = x0.xyxy + C.xxzz;
        x12.xy -= i1;
        i = mod289(i);
        vec3 p = permute(permute(i.y + vec3(0.0, i1.y, 1.0)) + i.x + vec3(0.0, i1.x, 1.0));
        vec3 m = max(0.5 - vec3(dot(x0,x0), dot(x12.xy,x12.xy), dot(x12.zw,x12.zw)), 0.0);
        m = m*m; m = m*m;
        vec3 x = 2.0 * fract(p * C.www) - 1.0;
        vec3 h = abs(x) - 0.5;
        vec3 ox = floor(x + 0.5);
        vec3 a0 = x - ox;
        m *= 1.79284291400159 - 0.85373472095314 * (a0*a0 + h*h);
        vec3 g;
        g.x = a0.x * x0.x + h.x * x0.y;
        g.yz = a0.yz * x12.xz + h.yz * x12.yw;
        return 130.0 * dot(m, g);
      }

      void main() {
        // Depth-based color gradient
        float depth = smoothstep(-3.0, 4.0, vElevation);
        vec3 color = mix(uDeepColor, uMidColor, smoothstep(0.0, 0.4, depth));
        color = mix(color, uSurfaceColor, smoothstep(0.4, 0.8, depth));

        // Calculate normal from elevation (simplified)
        vec3 normal = normalize(vec3(
          sin(vElevation * 0.5 + uTime * 0.3) * 0.3,
          1.0,
          cos(vElevation * 0.5 + uTime * 0.2) * 0.3
        ));

        // View direction
        vec3 viewDir = normalize(vViewPosition);

        // Fresnel effect for realistic water reflection
        float fresnel = pow(1.0 - max(dot(viewDir, normal), 0.0), 4.0);
        fresnel = clamp(fresnel, 0.0, 1.0);

        // Sky reflection
        vec3 reflectDir = reflect(-viewDir, normal);
        float skyReflection = smoothstep(-0.2, 0.8, reflectDir.y);
        vec3 skyReflected = mix(uDeepColor, uSkyColor, skyReflection);

        // Mix water color with sky reflection
        color = mix(color, skyReflected, fresnel * 0.7);

        // Foam on wave crests
        float foamNoise = snoise(vUv * 30.0 + uTime * 0.5) * 0.5 + 0.5;
        float foamNoise2 = snoise(vUv * 60.0 - uTime * 0.3) * 0.5 + 0.5;
        float foam = smoothstep(1.5, 3.0, vElevation);
        foam += smoothstep(2.0, 3.5, vElevation + foamNoise * 2.0);
        foam += smoothstep(2.5, 4.0, vElevation + foamNoise2 * 1.5);
        foam = clamp(foam, 0.0, 1.0);

        // Foam spray texture
        float sprayNoise = snoise(vUv * 100.0 + uTime * 2.0);
        sprayNoise = smoothstep(0.3, 0.9, sprayNoise) * foam * 0.4;
        foam = clamp(foam + sprayNoise, 0.0, 1.0);

        color = mix(color, uFoamColor, foam * 0.85);

        // Sun specular reflection
        vec3 sunDir = normalize(vec3(0.5, 0.8, 0.3));
        vec3 halfDir = normalize(sunDir + viewDir);
        float sunSpec = pow(max(dot(normal, halfDir), 0.0), 256.0);
        float sunSpecWide = pow(max(dot(normal, halfDir), 0.0), 32.0);
        color += uSunColor * sunSpec * 1.5;
        color += uSunColor * sunSpecWide * 0.2;

        // Sparkle/shimmer effect
        float sparkle = snoise(vUv * 200.0 + uTime * 3.0);
        sparkle = smoothstep(0.7, 1.0, sparkle);
        float sparkleMask = (1.0 - foam) * smoothstep(-1.0, 1.5, vElevation);
        color += vec3(1.0, 1.0, 0.95) * sparkle * sparkleMask * 0.3;

        // Atmospheric fog
        float viewDepth = length(vViewPosition);
        float fog = smoothstep(50.0, 300.0, viewDepth);
        vec3 fogColor = mix(uMidColor, uSkyColor, 0.3);
        color = mix(color, fogColor, fog * 0.4);

        gl_FragColor = vec4(color, 0.95);
      }
    `;

    const material = new THREE.ShaderMaterial({
      vertexShader,
      fragmentShader,
      uniforms: {
        uTime: { value: 0 },
        uMouse: { value: new THREE.Vector2(0, 0) },
        uMouseInfluence: { value: 0 },
        uDeepColor: { value: new THREE.Color(0x021525) },
        uMidColor: { value: new THREE.Color(0x0a3a5c) },
        uSurfaceColor: { value: new THREE.Color(0x1a6a8a) },
        uFoamColor: { value: new THREE.Color(0xddeeff) },
        uSunColor: { value: new THREE.Color(0xfff5e6) },
        uSkyColor: { value: new THREE.Color(0x87ceeb) }
      },
      transparent: true,
      side: THREE.DoubleSide
    });

    const ocean = new THREE.Mesh(geometry, material);
    ocean.rotation.x = -Math.PI / 2.2;
    ocean.position.y = -8;
    scene.add(ocean);

    // Lighting
    scene.add(new THREE.AmbientLight(0x4a6a8a, 0.5));
    const sunLight = new THREE.DirectionalLight(0xffeedd, 0.7);
    sunLight.position.set(50, 80, 30);
    scene.add(sunLight);

    // Mouse tracking
    let mouseX = 0, mouseY = 0, mouseInfluence = 0;
    let lastMouseX = 0, lastMouseY = 0, lastMouseTime = Date.now();

    document.addEventListener('mousemove', (e) => {
      const newMouseX = (e.clientX / window.innerWidth) * 2 - 1;
      const newMouseY = -(e.clientY / window.innerHeight) * 2 + 1;

      const now = Date.now();
      const dx = newMouseX - lastMouseX;
      const dy = newMouseY - lastMouseY;
      const speed = Math.sqrt(dx * dx + dy * dy) / Math.max(1, now - lastMouseTime) * 1000;

      mouseX = newMouseX;
      mouseY = newMouseY;
      lastMouseX = mouseX;
      lastMouseY = mouseY;
      lastMouseTime = now;
      mouseInfluence = Math.min(1, speed * 2 + 0.3);
    });

    // Animation loop
    const clock = new THREE.Clock();

    function animate() {
      requestAnimationFrame(animate);
      const elapsedTime = clock.getElapsedTime();

      material.uniforms.uTime.value = elapsedTime;
      material.uniforms.uMouse.value.set(mouseX, mouseY);
      material.uniforms.uMouseInfluence.value = mouseInfluence;
      mouseInfluence *= 0.95;

      // Subtle camera movement for immersion
      camera.position.x = Math.sin(elapsedTime * 0.03) * 8;
      camera.position.z = 50 + Math.cos(elapsedTime * 0.02) * 5;
      camera.lookAt(0, 0, 0);

      renderer.render(scene, camera);
    }

    // Handle resize
    function handleResize() {
      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(window.innerWidth, window.innerHeight);
    }

    window.addEventListener('resize', handleResize);
    animate();
  }

  // Initialize on page load
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initOcean);
  } else {
    initOcean();
  }

  // Reinitialize after Astro page swaps
  document.addEventListener('astro:after-swap', initOcean);
</script>

<style>
  #ocean-container {
    position: fixed;
    inset: 0;
    z-index: 0;
  }

  #ocean-canvas {
    width: 100%;
    height: 100%;
  }
</style>
