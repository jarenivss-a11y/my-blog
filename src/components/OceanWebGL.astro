---
// OceanWebGL - Enhanced Three.js WebGL ocean with bloom, SSS, caustics and realistic wave interactions
---

<div id="ocean-container" class="fixed inset-0 w-full h-full pointer-events-none z-0 overflow-hidden">
  <canvas id="ocean-canvas"></canvas>
  <canvas id="bloom-canvas" class="absolute inset-0 w-full h-full pointer-events-none"></canvas>
</div>

<script>
  function initOcean() {
    const container = document.getElementById('ocean-container');
    const canvas = document.getElementById('ocean-canvas');
    const bloomCanvas = document.getElementById('bloom-canvas');
    if (!container || !canvas || !bloomCanvas) return;

    // Scene setup
    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(55, window.innerWidth / window.innerHeight, 0.1, 2000);
    camera.position.set(0, 18, 55);
    camera.lookAt(0, 0, 0);

    // Performance optimizations
    const renderer = new THREE.WebGLRenderer({ canvas, antialias: false, alpha: true, powerPreference: 'high-performance' });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.5));
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.2;

    // Bloom renderer
    const bloomCtx = bloomCanvas.getContext('2d');
    bloomCanvas.width = window.innerWidth;
    bloomCanvas.height = window.innerHeight;

    // Optimized geometry - fewer segments for better performance
    const geometry = new THREE.PlaneGeometry(500, 500, 180, 180);

    const vertexShader = `
      uniform float uTime;
      uniform vec2 uMouse;
      uniform float uMouseInfluence;
      uniform float uScrollInfluence;
      uniform float uMouseSpeed;

      varying vec2 vUv;
      varying float vElevation;
      varying vec3 vWorldPosition;
      varying vec3 vNormal;
      varying vec3 vViewPosition;

      // Gerstner wave - realistic ocean waves
      vec3 gerstnerWave(vec2 pos, float steepness, float wavelength, vec2 direction, float time, float phase) {
        float k = 2.0 * 3.14159 / wavelength;
        float c = sqrt(9.8 / k);
        vec2 d = normalize(direction);
        float f = k * (dot(d, pos) - c * time);
        float a = steepness / k;
        return vec3(
          d.x * (a * cos(f)),
          a * sin(f + phase),
          d.y * (a * cos(f))
        );
      }

      // Chop wave for smaller perturbations
      vec3 chopWave(vec2 pos, float amp, float wavelength, vec2 direction, float time) {
        float k = 2.0 * 3.14159 / wavelength;
        float c = sqrt(9.8 / k);
        vec2 d = normalize(direction);
        float f = k * (dot(d, pos) - c * time);
        return vec3(
          d.x * amp * cos(f) * 0.3,
          amp * sin(f) * 0.5,
          d.y * amp * cos(f) * 0.3
        );
      }

      // Simplex noise
      vec3 mod289(vec3 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
      vec2 mod289(vec2 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
      vec3 permute(vec3 x) { return mod289(((x*34.0)+1.0)*x); }

      float snoise(vec2 v) {
        const vec4 C = vec4(0.211324865405187, 0.366025403784439, -0.577350269189626, 0.024390243902439);
        vec2 i = floor(v + dot(v, C.yy));
        vec2 x0 = v - i + dot(i, C.xx);
        vec2 i1 = (x0.x > x0.y) ? vec2(1.0, 0.0) : vec2(0.0, 1.0);
        vec4 x12 = x0.xyxy + C.xxzz;
        x12.xy -= i1;
        i = mod289(i);
        vec3 p = permute(permute(i.y + vec3(0.0, i1.y, 1.0)) + i.x + vec3(0.0, i1.x, 1.0));
        vec3 m = max(0.5 - vec3(dot(x0,x0), dot(x12.xy,x12.xy), dot(x12.zw,x12.zw)), 0.0);
        m = m*m; m = m*m;
        vec3 x = 2.0 * fract(p * C.www) - 1.0;
        vec3 h = abs(x) - 0.5;
        vec3 ox = floor(x + 0.5);
        vec3 a0 = x - ox;
        m *= 1.79284291400159 - 0.85373472095314 * (a0*a0 + h*h);
        vec3 g;
        g.x = a0.x * x0.x + h.x * x0.y;
        g.yz = a0.yz * x12.xz + h.yz * x12.yw;
        return 130.0 * dot(m, g);
      }

      float fbm(vec2 p) {
        float f = 0.0;
        f += 0.5000 * snoise(p); p *= 2.02;
        f += 0.2500 * snoise(p); p *= 2.03;
        f += 0.1250 * snoise(p); p *= 2.01;
        f += 0.0625 * snoise(p);
        return f / 0.9375;
      }

      void main() {
        vUv = uv;
        vec3 pos = position;

        // Main ocean swells
        vec3 wave1 = gerstnerWave(pos.xz, 0.35, 120.0, vec2(1.0, 0.2), uTime * 0.35, 0.0);
        vec3 wave2 = gerstnerWave(pos.xz, 0.28, 80.0, vec2(0.7, 0.5), uTime * 0.5, 1.0);
        vec3 wave3 = gerstnerWave(pos.xz, 0.22, 50.0, vec2(-0.3, 0.7), uTime * 0.7, 2.0);
        vec3 wave4 = gerstnerWave(pos.xz, 0.18, 35.0, vec2(0.5, -0.4), uTime * 0.9, 0.5);

        // Chop waves
        vec3 chop1 = chopWave(pos.xz, 0.3, 15.0, vec2(0.6, 0.8), uTime * 2.5);
        vec3 chop2 = chopWave(pos.xz, 0.2, 10.0, vec2(-0.4, 0.6), uTime * 3.0);
        vec3 chop3 = chopWave(pos.xz, 0.15, 8.0, vec2(0.8, -0.2), uTime * 2.8);

        vec3 totalWave = wave1 + wave2 + wave3 + wave4 + chop1 + chop2 + chop3;

        // FBM detail
        float noise1 = fbm(vec2(pos.x * 0.04 + uTime * 0.08, pos.z * 0.04 + uTime * 0.06)) * 1.2;
        float noise2 = fbm(vec2(pos.x * 0.1 - uTime * 0.12, pos.z * 0.08 + uTime * 0.1)) * 0.6;
        float noise3 = snoise(vec2(pos.x * 0.4 + uTime * 0.5, pos.z * 0.4 - uTime * 0.4)) * 0.3;

        // Mouse interaction
        vec2 mouseWorld = uMouse * 120.0;
        float mouseDist = distance(pos.xz, mouseWorld);
        float mouseRipple = sin(mouseDist * 0.2 - uTime * 5.0) * exp(-mouseDist * 0.02) * uMouseInfluence * 5.0;
        float mouseRipple2 = sin(mouseDist * 0.12 - uTime * 3.5) * exp(-mouseDist * 0.015) * uMouseInfluence * 3.0;
        float mouseRipple3 = sin(mouseDist * 0.08 - uTime * 2.5) * exp(-mouseDist * 0.01) * uMouseInfluence * 2.0;

        // Speed-based spray
        float speedSpray = uMouseSpeed * 0.8;
        float speedRipple = sin(mouseDist * 0.3 - uTime * 6.0) * exp(-mouseDist * 0.03) * speedSpray * 3.0;

        // Scroll influence
        float scrollWave = sin(pos.x * 0.04 + uTime * 0.4) * uScrollInfluence * 2.5;

        // Combine
        pos.x += totalWave.x + chop1.x + chop2.x + chop3.x;
        pos.y += totalWave.y + noise1 + noise2 + noise3 + mouseRipple + mouseRipple2 + mouseRipple3 + speedRipple + scrollWave;
        pos.z += totalWave.z + chop1.z + chop2.z + chop3.z;

        vElevation = pos.y;
        vWorldPosition = (modelMatrix * vec4(pos, 1.0)).xyz;

        // Calculate normal
        float eps = 0.3;
        vec3 hL = gerstnerWave((pos.xz + vec2(-eps, 0.0)), 0.22, 50.0, vec2(-0.3, 0.7), uTime * 0.7, 2.0)
                 + chopWave((pos.xz + vec2(-eps, 0.0)), 0.2, 10.0, vec2(-0.4, 0.6), uTime * 3.0);
        vec3 hR = gerstnerWave((pos.xz + vec2(eps, 0.0)), 0.22, 50.0, vec2(-0.3, 0.7), uTime * 0.7, 2.0)
                 + chopWave((pos.xz + vec2(eps, 0.0)), 0.2, 10.0, vec2(-0.4, 0.6), uTime * 3.0);
        vec3 hD = gerstnerWave((pos.xz + vec2(0.0, -eps)), 0.22, 50.0, vec2(-0.3, 0.7), uTime * 0.7, 2.0)
                 + chopWave((pos.xz + vec2(0.0, -eps)), 0.2, 10.0, vec2(-0.4, 0.6), uTime * 3.0);
        vec3 hU = gerstnerWave((pos.xz + vec2(0.0, eps)), 0.22, 50.0, vec2(-0.3, 0.7), uTime * 0.7, 2.0)
                 + chopWave((pos.xz + vec2(0.0, eps)), 0.2, 10.0, vec2(-0.4, 0.6), uTime * 3.0);
        vNormal = normalize(vec3(hL.y - hR.y, 2.0 * eps, hD.y - hU.y));

        vec4 mvPosition = modelViewMatrix * vec4(pos, 1.0);
        vViewPosition = -mvPosition.xyz;

        gl_Position = projectionMatrix * mvPosition;
      }
    `;

    const fragmentShader = `
      precision highp float;

      uniform float uTime;
      uniform vec3 uDeepColor;
      uniform vec3 uMidColor;
      uniform vec3 uSurfaceColor;
      uniform vec3 uFoamColor;
      uniform vec3 uSunColor;
      uniform vec3 uSkyColor;
      uniform float uScrollInfluence;
      uniform float uMouseSpeed;

      varying vec2 vUv;
      varying float vElevation;
      varying vec3 vWorldPosition;
      varying vec3 vNormal;
      varying vec3 vViewPosition;

      vec3 mod289(vec3 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
      vec2 mod289(vec2 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
      vec3 permute(vec3 x) { return mod289(((x*34.0)+1.0)*x); }

      float snoise(vec2 v) {
        const vec4 C = vec4(0.211324865405187, 0.366025403784439, -0.577350269189626, 0.024390243902439);
        vec2 i = floor(v + dot(v, C.yy));
        vec2 x0 = v - i + dot(i, C.xx);
        vec2 i1 = (x0.x > x0.y) ? vec2(1.0, 0.0) : vec2(0.0, 1.0);
        vec4 x12 = x0.xyxy + C.xxzz;
        x12.xy -= i1;
        i = mod289(i);
        vec3 p = permute(permute(i.y + vec3(0.0, i1.y, 1.0)) + i.x + vec3(0.0, i1.x, 1.0));
        vec3 m = max(0.5 - vec3(dot(x0,x0), dot(x12.xy,x12.xy), dot(x12.zw,x12.zw)), 0.0);
        m = m*m; m = m*m;
        vec3 x = 2.0 * fract(p * C.www) - 1.0;
        vec3 h = abs(x) - 0.5;
        vec3 ox = floor(x + 0.5);
        vec3 a0 = x - ox;
        m *= 1.79284291400159 - 0.85373472095314 * (a0*a0 + h*h);
        vec3 g;
        g.x = a0.x * x0.x + h.x * x0.y;
        g.yz = a0.yz * x12.xz + h.yz * x12.yw;
        return 130.0 * dot(m, g);
      }

      float caustic(vec2 p, float time) {
        float c1 = snoise(p * 4.0 + time * 0.4);
        float c2 = snoise(p * 6.0 - time * 0.3);
        float c3 = snoise(p * 8.0 + time * 0.5);
        return pow(abs((c1 + c2 + c3) / 3.0), 2.0);
      }

      float waveFoam(vec2 p, float time) {
        float f1 = snoise(p * 30.0 + time * 0.5);
        float f2 = snoise(p * 50.0 - time * 0.3);
        float f3 = snoise(p * 80.0 + time * 0.7);
        return (f1 * 0.5 + f2 * 0.3 + f3 * 0.2 + 0.5);
      }

      void main() {
        // Depth gradient
        float depth = smoothstep(-5.0, 6.0, vElevation);
        vec3 color = mix(uDeepColor, uMidColor, smoothstep(0.0, 0.25, depth));
        color = mix(color, uSurfaceColor, smoothstep(0.25, 0.65, depth));

        // Subsurface scattering
        vec3 sssColor = vec3(0.15, 0.45, 0.55);
        float sss = max(0.0, dot(normalize(vViewPosition), -normalize(vec3(0.5, 0.8, 0.3))));
        sss = pow(sss, 2.5) * 0.5;
        color += sssColor * sss * (1.0 - depth * 0.6);

        // Normal and view direction
        vec3 normal = normalize(vNormal);
        vec3 viewDir = normalize(vViewPosition);

        // Fresnel
        float fresnel = pow(1.0 - max(dot(viewDir, normal), 0.0), 4.5);
        fresnel = clamp(fresnel, 0.0, 1.0);

        // Sky reflection
        vec3 reflectDir = reflect(-viewDir, normal);
        float skyReflection = smoothstep(-0.1, 0.85, reflectDir.y);
        vec3 skyReflected = mix(uDeepColor, uSkyColor, skyReflection);
        color = mix(color, skyReflected, fresnel * 0.7);

        // Caustic light
        float causticLight = caustic(vWorldPosition.xz * 0.015 + uTime * 0.08, uTime);
        causticLight *= (1.0 - smoothstep(-2.0, 1.0, vElevation)) * 0.2;
        color += vec3(0.25, 0.5, 0.6) * causticLight;

        // Foam layers
        float foamNoise1 = waveFoam(vUv * 2.0 + uTime * 0.2, uTime);
        float foamNoise2 = waveFoam(vUv * 4.0 - uTime * 0.15, uTime);
        float foamNoise3 = snoise(vUv * 160.0 + uTime * 0.5) * 0.5 + 0.5;

        float foam = smoothstep(1.0, 2.8, vElevation);
        foam += smoothstep(1.5, 3.5, vElevation + foamNoise1 * 3.0) * 0.7;
        foam += smoothstep(2.0, 4.2, vElevation + foamNoise2 * 2.5) * 0.5;
        foam += smoothstep(2.5, 4.5, vElevation + foamNoise3 * 2.0) * 0.4;
        foam = clamp(foam, 0.0, 1.0);

        // Speed spray
        float speedSpray = uMouseSpeed * 0.6;
        float sprayNoise = snoise(vUv * 250.0 + uTime * 3.0);
        sprayNoise = smoothstep(0.3, 0.85, sprayNoise) * foam * speedSpray;
        foam = clamp(foam + sprayNoise, 0.0, 1.0);

        color = mix(color, uFoamColor, foam * 0.85);

        // Sun specular
        vec3 sunDir = normalize(vec3(0.5, 0.8, 0.3));
        vec3 halfDir = normalize(sunDir + viewDir);
        float sunSpec = pow(max(dot(normal, halfDir), 0.0), 600.0);
        float sunSpecWide = pow(max(dot(normal, halfDir), 0.0), 28.0);
        color += uSunColor * sunSpec * 2.5;
        color += uSunColor * sunSpecWide * 0.35;

        // Sparkle
        float sparkle = snoise(vUv * 400.0 + uTime * 5.0);
        sparkle = smoothstep(0.8, 1.0, sparkle);
        float sparkleMask = (1.0 - foam) * smoothstep(-0.5, 1.8, vElevation);
        color += vec3(1.0, 0.98, 0.9) * sparkle * sparkleMask * 0.6;

        // Fog
        float viewDepth = length(vViewPosition);
        float fog = smoothstep(40.0, 400.0, viewDepth);
        vec3 fogColor = mix(uMidColor, uSkyColor, 0.35);
        color = mix(color, fogColor, fog * 0.55);

        // Scroll glow
        float scrollGlow = uScrollInfluence * 0.12 * smoothstep(2.0, 5.0, vElevation);
        color += vec3(0.35, 0.55, 0.75) * scrollGlow;

        gl_FragColor = vec4(color, 0.95);
      }
    `;

    const material = new THREE.ShaderMaterial({
      vertexShader,
      fragmentShader,
      uniforms: {
        uTime: { value: 0 },
        uMouse: { value: new THREE.Vector2(0, 0) },
        uMouseInfluence: { value: 0 },
        uMouseSpeed: { value: 0 },
        uScrollInfluence: { value: 0 },
        uDeepColor: { value: new THREE.Color(0x011320) },
        uMidColor: { value: new THREE.Color(0x0a3a5c) },
        uSurfaceColor: { value: new THREE.Color(0x1a7090) },
        uFoamColor: { value: new THREE.Color(0xeef5ff) },
        uSunColor: { value: new THREE.Color(0xfff8f0) },
        uSkyColor: { value: new THREE.Color(0x9ad4eb) }
      },
      transparent: true,
      side: THREE.DoubleSide
    });

    const ocean = new THREE.Mesh(geometry, material);
    ocean.rotation.x = -Math.PI / 2.15;
    ocean.position.y = -10;
    scene.add(ocean);

    // Lighting
    scene.add(new THREE.AmbientLight(0x5a7a9a, 0.4));
    const sunLight = new THREE.DirectionalLight(0xfff5e0, 0.85);
    sunLight.position.set(50, 80, 30);
    scene.add(sunLight);

    // Mouse tracking
    let mouseX = 0, mouseY = 0, mouseInfluence = 0, mouseSpeed = 0;
    let lastMouseX = 0, lastMouseY = 0, lastMouseTime = Date.now();

    document.addEventListener('mousemove', (e) => {
      const newMouseX = (e.clientX / window.innerWidth) * 2 - 1;
      const newMouseY = -(e.clientY / window.innerHeight) * 2 + 1;

      const now = Date.now();
      const dt = Math.max(1, now - lastMouseTime);
      const dx = newMouseX - lastMouseX;
      const dy = newMouseY - lastMouseY;
      const speed = Math.sqrt(dx * dx + dy * dy) / dt * 1000;

      mouseX = newMouseX;
      mouseY = newMouseY;
      lastMouseX = mouseX;
      lastMouseY = mouseY;
      lastMouseTime = now;
      mouseInfluence = Math.min(1.8, speed * 4 + 0.5);
      mouseSpeed = Math.min(1.0, speed * 2);
    });

    // Click splash
    document.addEventListener('click', (e) => {
      const clickX = (e.clientX / window.innerWidth) * 2 - 1;
      const clickY = -(e.clientY / window.innerHeight) * 2 + 1;
      material.uniforms.uMouse.value.set(clickX * 1.5, clickY * 1.5);
      mouseInfluence = 2.5;
      mouseSpeed = 1.5;
      window.dispatchEvent(new CustomEvent('ocean-splash', { detail: { x: e.clientX, y: e.clientY } }));
    });

    // Scroll tracking
    let scrollInfluence = 0;
    window.addEventListener('scroll', () => {
      scrollInfluence = Math.min(1, window.scrollY / 500);
    });

    // Animation with visibility API for performance
    const clock = new THREE.Clock();
    let isVisible = true;
    document.addEventListener('visibilitychange', () => {
      isVisible = document.visibilityState === 'visible';
    });

    function animate() {
      if (!isVisible) {
        requestAnimationFrame(animate);
        return;
      }
      requestAnimationFrame(animate);
      const elapsedTime = clock.getElapsedTime();

      material.uniforms.uTime.value = elapsedTime;
      material.uniforms.uMouse.value.set(mouseX, mouseY);
      material.uniforms.uMouseInfluence.value = mouseInfluence;
      material.uniforms.uMouseSpeed.value = mouseSpeed;
      material.uniforms.uScrollInfluence.value = scrollInfluence;
      mouseInfluence *= 0.94;
      mouseSpeed *= 0.92;
      scrollInfluence *= 0.98;

      // Camera sway
      camera.position.x = Math.sin(elapsedTime * 0.02) * 12;
      camera.position.z = 55 + Math.cos(elapsedTime * 0.015) * 8;
      camera.position.y = 18 + Math.sin(elapsedTime * 0.018) * 2.5;
      camera.lookAt(0, 0, 0);

      renderer.render(scene, camera);

      // Bloom
      bloomCtx.clearRect(0, 0, bloomCanvas.width, bloomCanvas.height);
      const time = elapsedTime * 0.4;

      const sunX = bloomCanvas.width * (0.5 + Math.sin(time * 0.25) * 0.12);
      const sunY = bloomCanvas.height * (0.3 + Math.cos(time * 0.18) * 0.08);

      const primaryGradient = bloomCtx.createRadialGradient(sunX, sunY, 0, sunX, sunY, bloomCanvas.width * 0.65);
      primaryGradient.addColorStop(0, 'rgba(180, 220, 245, 0.15)');
      primaryGradient.addColorStop(0.2, 'rgba(130, 180, 220, 0.08)');
      primaryGradient.addColorStop(0.5, 'rgba(80, 140, 190, 0.04)');
      primaryGradient.addColorStop(1, 'rgba(0, 0, 0, 0)');
      bloomCtx.fillStyle = primaryGradient;
      bloomCtx.fillRect(0, 0, bloomCanvas.width, bloomCanvas.height);

      const secondaryGradient = bloomCtx.createRadialGradient(
        bloomCanvas.width * 0.5, bloomCanvas.height * 0.65, 0,
        bloomCanvas.width * 0.5, bloomCanvas.height * 0.65, bloomCanvas.width * 0.45
      );
      secondaryGradient.addColorStop(0, 'rgba(100, 160, 200, 0.1)');
      secondaryGradient.addColorStop(0.4, 'rgba(60, 120, 170, 0.05)');
      secondaryGradient.addColorStop(1, 'rgba(0, 0, 0, 0)');
      bloomCtx.globalCompositeOperation = 'screen';
      bloomCtx.fillStyle = secondaryGradient;
      bloomCtx.fillRect(0, 0, bloomCanvas.width, bloomCanvas.height);

      const sparkleX = bloomCanvas.width * (0.35 + Math.sin(time * 1.2) * 0.2);
      const sparkleGradient = bloomCtx.createRadialGradient(
        sparkleX, bloomCanvas.height * 0.25, 0,
        sparkleX, bloomCanvas.height * 0.35, bloomCanvas.width * 0.4
      );
      sparkleGradient.addColorStop(0, 'rgba(255, 255, 255, 0.08)');
      sparkleGradient.addColorStop(0.15, 'rgba(220, 240, 255, 0.03)');
      sparkleGradient.addColorStop(1, 'rgba(0, 0, 0, 0)');
      bloomCtx.fillStyle = sparkleGradient;
      bloomCtx.fillRect(0, 0, bloomCanvas.width, bloomCanvas.height);

      bloomCtx.globalCompositeOperation = 'source-over';
    }

    function handleResize() {
      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(window.innerWidth, window.innerHeight);
      bloomCanvas.width = window.innerWidth;
      bloomCanvas.height = window.innerHeight;
    }

    window.addEventListener('resize', handleResize);
    animate();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initOcean);
  } else {
    initOcean();
  }

  document.addEventListener('astro:after-swap', initOcean);
</script>

<style>
  #ocean-container {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  #ocean-canvas {
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  #bloom-canvas {
    pointer-events: none;
    mix-blend-mode: screen;
    opacity: 0.65;
  }
</style>