---
// SEO Structured Data Component
interface Props {
  title: string;
  description?: string;
  url?: string;
  publishedTime?: Date;
  modifiedTime?: Date;
  author?: string;
  type?: 'website' | 'article';
}

const {
  title,
  description = "Personal Blog",
  url = Astro.url.pathname,
  publishedTime,
  author = "博主",
  type = "website",
} = Astro.props;

const siteUrl = "https://jarenivss-a11y.github.io/my-blog";
const fullUrl = `${siteUrl}${url}`;
---

{type === 'article' && publishedTime && (
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": title,
    "description": description,
    "url": fullUrl,
    "datePublished": publishedTime.toISOString(),
    "author": {
      "@type": "Person",
      "name": author
    },
    "publisher": {
      "@type": "Organization",
      "name": "我的博客",
      "url": siteUrl
    }
  })} />
)}

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "我的博客",
  "url": siteUrl,
  "description": description,
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": `${siteUrl}/search?q={search_term_string}`
    },
    "query-input": "required name=search_term_string"
  }
})} />