---
// Giscus Comments Component
// Comments powered by GitHub Discussions

interface Props {
  title?: string;
}

const { title = '' } = Astro.props;

const config = {
  repo: 'jarenivss-a11y/my-blog' as `${string}/${string}`,
  repoId: 'R_kgDOTDUbKQ',
  category: 'General',
  categoryId: 'DIC_kwDOTDUbKc4C_3s6',
  mapping: 'pathname' as const,
  lang: 'zh-CN',
};
---

<div id="comments" class="mt-12 p-8 rounded-2xl backdrop-blur-xl bg-[rgba(155,180,218,0.05)] border border-[rgba(165,188,230,0.12)]">
  <h3 class="text-lg font-serif font-bold text-[#e2e9f5] mb-6">评论</h3>
  <div id="giscus-comments"></div>
</div>

<script define:vars={{ config }}>
  function loadGiscus() {
    const container = document.getElementById('giscus-comments');
    if (!container) return;

    const script = document.createElement('script');
    script.src = 'https://giscus.app/client.js';
    script.setAttribute('data-repo', config.repo);
    script.setAttribute('data-repo-id', config.repoId);
    script.setAttribute('data-category', config.category);
    script.setAttribute('data-category-id', config.categoryId);
    script.setAttribute('data-mapping', config.mapping);
    script.setAttribute('data-strict', '0');
    script.setAttribute('data-reactions-enabled', '1');
    script.setAttribute('data-emit-metadata', '0');
    script.setAttribute('data-input-position', 'top');
    script.setAttribute('data-theme', document.documentElement.classList.contains('dark') ? 'dark' : 'light');
    script.setAttribute('data-lang', config.lang);
    script.setAttribute('data-loading', 'lazy');
    script.crossOrigin = 'anonymous';
    script.async = true;
    container.appendChild(script);
  }

  loadGiscus();

  // Listen for theme changes
  const observer = new MutationObserver(() => {
    const iframe = document.querySelector('giscus iframe');
    if (iframe?.contentWindow) {
      iframe.contentWindow.postMessage(
        {
          giscus: {
            setConfig: {
              theme: document.documentElement.classList.contains('dark') ? 'dark' : 'light'
            }
          }
        },
        'https://giscus.app'
      );
    }
  });
  observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
</script>