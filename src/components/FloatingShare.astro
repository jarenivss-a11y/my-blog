---
// FloatingShare - adds a floating share button for articles
---

<div id="floating-share" class="fixed left-4 bottom-24 z-40 hidden md:block">
  <button
    id="share-btn"
    class="p-3 rounded-full backdrop-blur-xl bg-white/80 dark:bg-slate-800/80 border border-white/50 dark:border-slate-700/50 shadow-lg hover:shadow-xl transition-all hover:scale-105 hover:bg-primary hover:text-white"
    aria-label="分享文章"
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/>
    </svg>
  </button>

  <!-- Share dropdown -->
  <div id="share-dropdown" class="hidden absolute bottom-full left-0 mb-2 w-48 py-2 rounded-xl backdrop-blur-xl bg-white/90 dark:bg-slate-800/90 border border-white/50 dark:border-slate-700/50 shadow-xl">
    <button class="share-option w-full px-4 py-2 text-left text-sm hover:bg-slate-100 dark:hover:bg-slate-700 flex items-center gap-2" data-platform="twitter">
      <span>X (Twitter)</span>
    </button>
    <button class="share-option w-full px-4 py-2 text-left text-sm hover:bg-slate-100 dark:hover:bg-slate-700 flex items-center gap-2" data-platform="facebook">
      <span>Facebook</span>
    </button>
    <button class="share-option w-full px-4 py-2 text-left text-sm hover:bg-slate-100 dark:hover:bg-slate-700 flex items-center gap-2" data-platform="weibo">
      <span>微博</span>
    </button>
    <button class="share-option w-full px-4 py-2 text-left text-sm hover:bg-slate-100 dark:hover:bg-slate-700 flex items-center gap-2" data-platform="copy">
      <span>复制链接</span>
    </button>
  </div>
</div>

<script>
  function initFloatingShare() {
    const container = document.getElementById('floating-share');
    const shareBtn = document.getElementById('share-btn');
    const dropdown = document.getElementById('share-dropdown');

    if (!container || !shareBtn || !dropdown) return;

    // Only show on article pages
    const article = document.querySelector('article');
    if (!article) return;
    container.classList.remove('hidden');

    let isOpen = false;

    shareBtn.addEventListener('click', () => {
      isOpen = !isOpen;
      dropdown.classList.toggle('hidden', !isOpen);
    });

    document.addEventListener('click', (e) => {
      if (!container.contains(e.target as Node)) {
        isOpen = false;
        dropdown.classList.add('hidden');
      }
    });

    // Share options
    dropdown.querySelectorAll('.share-option').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const platform = btn.getAttribute('data-platform');
        const url = encodeURIComponent(window.location.href);
        const title = encodeURIComponent(document.title);

        let shareUrl = '';
        switch (platform) {
          case 'twitter':
            shareUrl = `https://twitter.com/intent/tweet?url=${url}&text=${title}`;
            break;
          case 'facebook':
            shareUrl = `https://www.facebook.com/sharer/sharer.php?u=${url}`;
            break;
          case 'weibo':
            shareUrl = `https://service.weibo.com/share/share.php?url=${url}&title=${title}`;
            break;
          case 'copy':
            await navigator.clipboard.writeText(window.location.href);
            alert('链接已复制到剪贴板！');
            break;
        }

        if (shareUrl && platform !== 'copy') {
          window.open(shareUrl, '_blank', 'width=600,height=400');
        }

        isOpen = false;
        dropdown.classList.add('hidden');
      });
    });
  }

  initFloatingShare();
  document.addEventListener('astro:after-swap', initFloatingShare);
</script>