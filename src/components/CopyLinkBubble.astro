---
// Copy Link Bubble - appears when user selects text
---

<div id="copy-link-bubble" class="fixed z-50 hidden">
  <button
    id="copy-link-btn"
    class="px-3 py-2 rounded-lg bg-slate-800 dark:bg-slate-700 text-white text-sm shadow-lg hover:bg-slate-700 dark:hover:bg-slate-600 transition-colors flex items-center gap-2"
  >
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
    </svg>
    <span id="copy-link-text">复制链接</span>
  </button>
</div>

<script>
  function initCopyLinkBubble() {
    const bubble = document.getElementById('copy-link-bubble');
    const btn = document.getElementById('copy-link-btn');
    const textEl = document.getElementById('copy-link-text');

    if (!bubble || !btn) return;

    let hideTimeout: ReturnType<typeof setTimeout>;

    const showBubble = (x: number, y: number, text: string) => {
      clearTimeout(hideTimeout);
      bubble.style.left = `${x}px`;
      bubble.style.top = `${y}px`;
      bubble.classList.remove('hidden');
      textEl!.textContent = text.length > 20 ? text.slice(0, 20) + '...' : text;
    };

    const hideBubble = () => {
      hideTimeout = setTimeout(() => {
        bubble.classList.add('hidden');
      }, 300);
    };

    document.addEventListener('mouseup', (e) => {
      const selection = window.getSelection();
      if (!selection || selection.isCollapsed) {
        hideBubble();
        return;
      }

      const selectedText = selection.toString().trim();
      if (selectedText.length < 10) {
        hideBubble();
        return;
      }

      const range = selection.getRangeAt(0);
      const rect = range.getBoundingClientRect();

      showBubble(
        rect.left + window.scrollX + rect.width / 2 - 60,
        rect.top + window.scrollY - 50,
        selectedText
      );
    });

    document.addEventListener('mousedown', (e) => {
      if (!(e.target as HTMLElement).closest('#copy-link-bubble')) {
        hideBubble();
      }
    });

    btn.addEventListener('click', async () => {
      const selection = window.getSelection();
      const text = selection?.toString().trim() || '';
      const url = window.location.href;

      try {
        await navigator.clipboard.writeText(`${text} - ${url}`);
        if (textEl) textEl.textContent = '已复制!';
        setTimeout(() => {
          if (textEl) textEl.textContent = '复制链接';
          bubble.classList.add('hidden');
        }, 1500);
      } catch (err) {
        console.error('复制失败:', err);
      }
    });
  }

  initCopyLinkBubble();
  document.addEventListener('astro:after-swap', initCopyLinkBubble);
</script>
