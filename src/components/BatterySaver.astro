---
// BatterySaver - reduces animations to save battery
---

<script>
  function initBatterySaver() {
    const STORAGE_KEY = 'battery-saver';
    const REDUCED_MOTION_KEY = 'reduce-motion';

    // Check if user prefers reduced motion
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const savedPreference = localStorage.getItem(STORAGE_KEY);
    const savedReduceMotion = localStorage.getItem(REDUCED_MOTION_KEY);

    function enableBatterySaver() {
      document.documentElement.classList.add('battery-saver');
      localStorage.setItem(STORAGE_KEY, 'enabled');
      localStorage.setItem(REDUCED_MOTION_KEY, 'enabled');
      updateToggleButton(true);
    }

    function disableBatterySaver() {
      document.documentElement.classList.remove('battery-saver');
      localStorage.setItem(STORAGE_KEY, 'disabled');
      localStorage.setItem(REDUCED_MOTION_KEY, 'disabled');
      updateToggleButton(false);
    }

    function updateToggleButton(isEnabled) {
      const btn = document.getElementById('battery-saver-btn');
      if (btn) {
        btn.classList.toggle('bg-green-500', isEnabled);
        btn.classList.toggle('bg-slate-300', !isEnabled);
        btn.classList.toggle('dark:bg-green-500', isEnabled);
        btn.classList.toggle('dark:bg-slate-600', !isEnabled);
      }
    }

    // Auto-enable if battery is low or user prefers reduced motion
    if (prefersReducedMotion || savedPreference === 'enabled' || savedReduceMotion === 'enabled') {
      enableBatterySaver();
    }

    // Listen for battery status (if available)
    if ('getBattery' in navigator) {
      (navigator as any).getBattery().then((battery: any) => {
        if (battery.level < 0.2 && !battery.charging) {
          enableBatterySaver();
        }

        battery.addEventListener('levelchange', () => {
          if (battery.level < 0.2 && !battery.charging) {
            enableBatterySaver();
          }
        });
      });
    }

    // Create toggle button
    const btn = document.createElement('button');
    btn.id = 'battery-saver-btn';
    btn.className = 'fixed bottom-4 left-4 z-50 w-10 h-10 rounded-full flex items-center justify-center shadow-lg transition-all hover:scale-110';
    btn.title = '省电模式';
    btn.innerHTML = `
      <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
      </svg>
    `;

    const isEnabled = document.documentElement.classList.contains('battery-saver');
    btn.classList.toggle('bg-green-500', isEnabled);
    btn.classList.toggle('bg-slate-300', !isEnabled);
    btn.classList.toggle('dark:bg-green-500', isEnabled);
    btn.classList.toggle('dark:bg-slate-600', !isEnabled);

    btn.addEventListener('click', () => {
      if (document.documentElement.classList.contains('battery-saver')) {
        disableBatterySaver();
      } else {
        enableBatterySaver();
      }
    });

    document.body.appendChild(btn);
  }

  initBatterySaver();
  document.addEventListener('astro:after-swap', initBatterySaver);
</script>

<style is:global>
  .battery-saver *,
  .battery-saver *::before,
  .battery-saver *::after {
    animation-duration: 0.001ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.001ms !important;
  }

  .battery-saver .animate-pulse {
    animation: none !important;
  }

  .battery-saver .animate-bounce {
    animation: none !important;
  }

  .battery-saver .animate-spin {
    animation: none !important;
  }

  .battery-saver .animate-gradient {
    animation: none !important;
    background-size: 100% 100% !important;
  }

  .battery-saver .animate-shine {
    animation: none !important;
  }

  .battery-saver .firefly {
    display: none !important;
  }

  .battery-saver .sakura-petal {
    display: none !important;
  }
</style>