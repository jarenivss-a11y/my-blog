---
// ArticleFeedback - asks users if article was helpful
---

<div id="article-feedback" class="mt-8 p-6 rounded-2xl backdrop-blur-xl bg-[rgba(155,180,218,0.05)] border border-[rgba(165,188,230,0.12)]">
  <h3 class="text-lg font-serif font-bold text-[#e2e9f5] mb-4">这篇文章对你有帮助吗？</h3>

  <div id="feedback-buttons" class="flex flex-wrap gap-3">
    <button
      class="feedback-btn px-4 py-2 rounded-full border border-[rgba(80,128,176,0.2)] hover:border-[#72a8d8] hover:bg-[rgba(80,128,176,0.1)] transition-all flex items-center gap-2 text-[#b2c0d8]"
      data-feedback="helpful"
    >
      <span>👍</span>
      <span>有帮助</span>
    </button>
    <button
      class="feedback-btn px-4 py-2 rounded-full border border-[rgba(80,128,176,0.2)] hover:border-[#72a8d8] hover:bg-[rgba(80,128,176,0.1)] transition-all flex items-center gap-2 text-[#b2c0d8]"
      data-feedback="not-helpful"
    >
      <span>👎</span>
      <span>不太有帮助</span>
    </button>
    <button
      class="feedback-btn px-4 py-2 rounded-full border border-[rgba(80,128,176,0.2)] hover:border-[#72a8d8] hover:bg-[rgba(80,128,176,0.1)] transition-all flex items-center gap-2 text-[#b2c0d8]"
      data-feedback="suggestions"
    >
      <span>💡</span>
      <span>有改进建议</span>
    </button>
  </div>

  <div id="feedback-form" class="hidden mt-4">
    <textarea
      id="feedback-comment"
      class="w-full p-4 rounded-xl border border-[rgba(80,128,176,0.3)] bg-[rgba(80,128,176,0.1)] text-[#b2c0d8] placeholder:text-[#7a8cb4] resize-none focus:outline-none focus:ring-2 focus:ring-[#5080b0] focus:border-transparent"
      rows="3"
      placeholder="请分享你的想法..."
    ></textarea>
    <div class="flex justify-end gap-2 mt-3">
      <button id="feedback-cancel" class="px-4 py-2 text-sm text-[#8a9cc4] hover:text-[#b2c0d8] transition-colors">
        取消
      </button>
      <button id="feedback-submit" class="px-4 py-2 text-sm bg-gradient-to-r from-[#5080b0] to-[#72a8d8] text-white rounded-full hover:shadow-[0_4px 20px_rgba(80,128,176,0.4)] transition-all">
        提交反馈
      </button>
    </div>
  </div>

  <div id="feedback-thanks" class="hidden text-center py-4">
    <span class="text-2xl mb-2 block">🙏</span>
    <p class="text-[#b2c0d8]">感谢你的反馈！</p>
  </div>
</div>

<script>
  function initArticleFeedback() {
    const feedback = document.getElementById('article-feedback');
    if (!feedback) return;

    const buttons = feedback.querySelectorAll('.feedback-btn');
    const form = document.getElementById('feedback-form');
    const thanks = document.getElementById('feedback-thanks');
    const cancelBtn = document.getElementById('feedback-cancel');
    const submitBtn = document.getElementById('feedback-submit');
    const commentInput = document.getElementById('feedback-comment') as HTMLTextAreaElement;

    const postId = window.location.pathname;
    const STORAGE_KEY = `feedback-${postId}`;

    // Check if already submitted
    if (localStorage.getItem(STORAGE_KEY)) {
      buttons.forEach(btn => btn.classList.add('hidden'));
      form?.classList.add('hidden');
      thanks?.classList.remove('hidden');
    }

    let selectedFeedback = '';

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        selectedFeedback = btn.getAttribute('data-feedback') || '';

        if (selectedFeedback === 'suggestions') {
          buttons.forEach(b => b.classList.add('hidden'));
          form?.classList.remove('hidden');
        } else {
          // Save feedback
          localStorage.setItem(STORAGE_KEY, selectedFeedback);
          buttons.forEach(b => b.classList.add('hidden'));
          thanks?.classList.remove('hidden');
        }
      });
    });

    cancelBtn?.addEventListener('click', () => {
      form?.classList.add('hidden');
      buttons.forEach(b => b.classList.remove('hidden'));
      selectedFeedback = '';
    });

    submitBtn?.addEventListener('click', () => {
      const comment = commentInput?.value || '';
      // Save feedback with comment
      localStorage.setItem(STORAGE_KEY, JSON.stringify({
        type: selectedFeedback,
        comment,
        timestamp: Date.now()
      }));
      form?.classList.add('hidden');
      thanks?.classList.remove('hidden');
    });
  }

  initArticleFeedback();
  document.addEventListener('astro:after-swap', initArticleFeedback);
</script>