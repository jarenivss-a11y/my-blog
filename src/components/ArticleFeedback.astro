---
// ArticleFeedback - asks users if article was helpful
---

<div id="article-feedback" class="mt-8 p-6 rounded-2xl backdrop-blur-xl bg-white/50 dark:bg-slate-800/50 border border-white/50 dark:border-slate-700/50">
  <h3 class="text-lg font-serif font-bold text-slate-900 dark:text-white mb-4">这篇文章对你有帮助吗？</h3>

  <div id="feedback-buttons" class="flex flex-wrap gap-3">
    <button
      class="feedback-btn px-4 py-2 rounded-full border border-slate-200 dark:border-slate-600 hover:border-green-500 hover:bg-green-50 dark:hover:bg-green-900/20 transition-all flex items-center gap-2"
      data-feedback="helpful"
    >
      <span>👍</span>
      <span class="text-slate-600 dark:text-slate-300">有帮助</span>
    </button>
    <button
      class="feedback-btn px-4 py-2 rounded-full border border-slate-200 dark:border-slate-600 hover:border-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 transition-all flex items-center gap-2"
      data-feedback="not-helpful"
    >
      <span>👎</span>
      <span class="text-slate-600 dark:text-slate-300">不太有帮助</span>
    </button>
    <button
      class="feedback-btn px-4 py-2 rounded-full border border-slate-200 dark:border-slate-600 hover:border-primary hover:bg-primary/10 transition-all flex items-center gap-2"
      data-feedback="suggestions"
    >
      <span>💡</span>
      <span class="text-slate-600 dark:text-slate-300">有改进建议</span>
    </button>
  </div>

  <div id="feedback-form" class="hidden mt-4">
    <textarea
      id="feedback-comment"
      class="w-full p-4 rounded-xl border border-slate-200 dark:border-slate-600 bg-white dark:bg-slate-700 text-slate-700 dark:text-slate-200 placeholder:text-slate-400 resize-none"
      rows="3"
      placeholder="请分享你的想法..."
    ></textarea>
    <div class="flex justify-end gap-2 mt-3">
      <button id="feedback-cancel" class="px-4 py-2 text-sm text-slate-500 hover:text-slate-700 dark:hover:text-slate-300 transition-colors">
        取消
      </button>
      <button id="feedback-submit" class="px-4 py-2 text-sm bg-primary text-white rounded-full hover:bg-primary/90 transition-colors">
        提交反馈
      </button>
    </div>
  </div>

  <div id="feedback-thanks" class="hidden text-center py-4">
    <span class="text-2xl mb-2 block">🙏</span>
    <p class="text-slate-600 dark:text-slate-300">感谢你的反馈！</p>
  </div>
</div>

<script>
  function initArticleFeedback() {
    const feedback = document.getElementById('article-feedback');
    if (!feedback) return;

    const buttons = feedback.querySelectorAll('.feedback-btn');
    const form = document.getElementById('feedback-form');
    const thanks = document.getElementById('feedback-thanks');
    const cancelBtn = document.getElementById('feedback-cancel');
    const submitBtn = document.getElementById('feedback-submit');
    const commentInput = document.getElementById('feedback-comment') as HTMLTextAreaElement;

    const postId = window.location.pathname;
    const STORAGE_KEY = `feedback-${postId}`;

    // Check if already submitted
    if (localStorage.getItem(STORAGE_KEY)) {
      buttons.forEach(btn => btn.classList.add('hidden'));
      form?.classList.add('hidden');
      thanks?.classList.remove('hidden');
    }

    let selectedFeedback = '';

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        selectedFeedback = btn.getAttribute('data-feedback') || '';

        if (selectedFeedback === 'suggestions') {
          buttons.forEach(b => b.classList.add('hidden'));
          form?.classList.remove('hidden');
        } else {
          // Save feedback
          localStorage.setItem(STORAGE_KEY, selectedFeedback);
          buttons.forEach(b => b.classList.add('hidden'));
          thanks?.classList.remove('hidden');
        }
      });
    });

    cancelBtn?.addEventListener('click', () => {
      form?.classList.add('hidden');
      buttons.forEach(b => b.classList.remove('hidden'));
      selectedFeedback = '';
    });

    submitBtn?.addEventListener('click', () => {
      const comment = commentInput?.value || '';
      // Save feedback with comment
      localStorage.setItem(STORAGE_KEY, JSON.stringify({
        type: selectedFeedback,
        comment,
        timestamp: Date.now()
      }));
      form?.classList.add('hidden');
      thanks?.classList.remove('hidden');
    });
  }

  initArticleFeedback();
  document.addEventListener('astro:after-swap', initArticleFeedback);
</script>