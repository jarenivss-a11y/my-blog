---
// Sakura animation - colorful sakura petals (always visible)
---

<div id="sakura-container" class="fixed inset-0 w-full h-full pointer-events-none z-10 overflow-hidden">
  <style>
    @keyframes sakuraFall {
      0% { transform: translate(0, -10vh) rotate(0deg) scale(1); opacity: 0; }
      5% { opacity: 1; }
      25% { transform: translate(10vw, 25vh) rotate(90deg) scale(1.1); }
      50% { transform: translate(-8vw, 50vh) rotate(180deg) scale(1); }
      75% { transform: translate(15vw, 75vh) rotate(270deg) scale(0.9); }
      90% { opacity: 1; }
      100% { transform: translate(5vw, 110vh) rotate(360deg) scale(0.8); opacity: 0; }
    }
    .sakura-petal { position: absolute; top: 0; border-radius: 100% 0 100% 0; }
  </style>
</div>

<script>
  const colorPalettes = [
    'linear-gradient(135deg, rgba(255, 182, 193, 0.9), rgba(255, 192, 203, 0.7))',
    'linear-gradient(135deg, rgba(255, 192, 203, 0.9), rgba(255, 218, 233, 0.7))',
    'linear-gradient(135deg, rgba(255, 160, 180, 0.9), rgba(255, 182, 193, 0.6))',
    'linear-gradient(135deg, rgba(253, 200, 208, 0.9), rgba(255, 182, 193, 0.8))',
    'linear-gradient(135deg, rgba(255, 105, 180, 0.6), rgba(255, 182, 193, 0.8))',
    'linear-gradient(135deg, rgba(255, 255, 240, 0.8), rgba(255, 250, 245, 0.6))',
  ];

  function createSakura() {
    const container = document.getElementById('sakura-container');
    if (!container) return;

    Array.from({ length: 30 }).forEach((_, i) => {
      const petal = document.createElement('div');
      petal.className = 'sakura-petal';
      const size = 8 + Math.random() * 14;
      const color = colorPalettes[Math.floor(Math.random() * colorPalettes.length)];
      petal.style.cssText = 'left:' + (Math.random() * 110) + '%;width:' + size + 'px;height:' + (size * 1.2) + 'px;background:' + color + ';filter:blur(' + (Math.random() * 2) + 'px);box-shadow:0 0 ' + (size/2) + 'px rgba(255,182,193,0.5);animation:sakuraFall ' + (8 + Math.random() * 10) + 's ease-in-out infinite;animation-delay:' + (Math.random() * -20) + 's;';
      container.appendChild(petal);
    });
  }

  createSakura();
</script>
