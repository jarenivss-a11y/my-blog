---
// Keyboard Shortcuts Component
---

<div id="keyboard-hint" class="fixed bottom-8 left-4 z-40 p-3 rounded-lg backdrop-blur-xl bg-[rgba(30,45,65,0.95)] border border-[rgba(80,128,176,0.3)] shadow-lg text-xs text-[#8a9cc4] opacity-0 transition-opacity duration-300 pointer-events-none">
  <div class="space-y-1">
    <div><kbd class="px-1.5 py-0.5 rounded bg-[rgba(80,128,176,0.2)] font-mono text-[#72a8d8]">j</kbd> / <kbd class="px-1.5 py-0.5 rounded bg-[rgba(80,128,176,0.2)] font-mono text-[#72a8d8]">k</kbd> 上/下导航</div>
    <div><kbd class="px-1.5 py-0.5 rounded bg-[rgba(80,128,176,0.2)] font-mono text-[#72a8d8]">g</kbd> 回到顶部</div>
    <div><kbd class="px-1.5 py-0.5 rounded bg-[rgba(80,128,176,0.2)] font-mono text-[#72a8d8]">s</kbd> 搜索</div>
    <div><kbd class="px-1.5 py-0.5 rounded bg-[rgba(80,128,176,0.2)] font-mono text-[#72a8d8]">?</kbd> 关闭帮助</div>
  </div>
</div>

<script>
  function initKeyboardShortcuts() {
    const hint = document.getElementById('keyboard-hint');
    let hintVisible = false;

    const showHint = () => {
      if (hint) {
        hint.classList.remove('opacity-0', 'pointer-events-none');
        hintVisible = true;
        setTimeout(() => {
          hint.classList.add('opacity-0', 'pointer-events-none');
          hintVisible = false;
        }, 3000);
      }
    };

    // Show hint on first press of ?
    document.addEventListener('keydown', (e) => {
      // Ignore if user is typing in an input
      if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) {
        return;
      }

      switch (e.key.toLowerCase()) {
        case '?':
          if (hint) {
            hint.classList.toggle('opacity-0', hintVisible);
            hint.classList.toggle('pointer-events-none', hintVisible);
            hintVisible = !hintVisible;
          }
          break;
        case 'j':
        case 'arrowdown':
          window.scrollBy({ top: 100, behavior: 'smooth' });
          break;
        case 'k':
        case 'arrowup':
          window.scrollBy({ top: -100, behavior: 'smooth' });
          break;
        case 'g':
          if (e.shiftKey) {
            // G = bottom
            window.scrollTo({ top: document.body.scrollHeight, behavior: 'smooth' });
          } else {
            // g = top
            window.scrollTo({ top: 0, behavior: 'smooth' });
          }
          break;
        case 's':
          const searchInput = document.getElementById('search-input');
          if (searchInput) {
            searchInput.focus();
          }
          break;
      }
    });

    // Show hint on first visit (once per session)
    if (!sessionStorage.getItem('keyboard-hint-shown')) {
      setTimeout(showHint, 1000);
      sessionStorage.setItem('keyboard-hint-shown', 'true');
    }
  }

  initKeyboardShortcuts();
  document.addEventListener('astro:after-swap', initKeyboardShortcuts);
</script>