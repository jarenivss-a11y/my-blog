---
// Article-specific SEO for blog posts
interface Props {
  title: string;
  description?: string;
  url: string;
  publishedTime: Date;
  author?: string;
  image?: string;
}

const {
  title,
  description = "",
  url,
  publishedTime,
  author = "博主",
  image,
} = Astro.props;

const siteUrl = "https://jarenivss-a11y.github.io/my-blog";
const fullUrl = `${siteUrl}${url}`;
const twitterImage = image || `${siteUrl}/og-default.png`;
---

<!-- Twitter Card Meta Tags -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={twitterImage} />
<meta name="twitter:image:alt" content={title} />

<!-- Article JSON-LD Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "url": fullUrl,
  "datePublished": publishedTime.toISOString(),
  "author": {
    "@type": "Person",
    "name": author
  },
  "publisher": {
    "@type": "Organization",
    "name": "我的博客",
    "url": siteUrl
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": fullUrl
  },
  ...(image && { "image": image })
})} />