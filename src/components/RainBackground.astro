---
// RainBackground - Dynamic CSS/Canvas rain effect with ocean blue aesthetic
---

<div id="rain-container" class="fixed inset-0 w-full h-full pointer-events-none z-0 overflow-hidden">
  <canvas id="rain-canvas"></canvas>
</div>

<script>
  function initRain() {
    const container = document.getElementById('rain-container');
    const canvas = document.getElementById('rain-canvas');
    if (!container || !canvas) return;

    const ctx = canvas.getContext('2d');
    let width = window.innerWidth;
    let height = window.innerHeight;
    canvas.width = width;
    canvas.height = height;

    // Rain configuration - ocean blue colors
    const raindrops: { x: number; y: number; length: number; speed: number; opacity: number; color: string }[] = [];
    const maxDrops = 150;

    // Ocean blue color palette
    const colors = [
      'rgba(6, 182, 212, 0.3)',  // cyan-500
      'rgba(34, 211, 238, 0.25)', // cyan-400
      'rgba(103, 232, 249, 0.2)', // cyan-300
      'rgba(8, 145, 178, 0.35)', // cyan-600
    ];

    // Initialize raindrops
    for (let i = 0; i < maxDrops; i++) {
      raindrops.push({
        x: Math.random() * width,
        y: Math.random() * height,
        length: Math.random() * 20 + 10,
        speed: Math.random() * 8 + 6,
        opacity: Math.random() * 0.3 + 0.1,
        color: colors[Math.floor(Math.random() * colors.length)]
      });
    }

    // Mouse interaction - creates ripples
    let ripples: { x: number; y: number; radius: number; opacity: number }[] = [];

    canvas.addEventListener('mousemove', (e) => {
      if (Math.random() > 0.85) {
        ripples.push({
          x: e.clientX,
          y: e.clientY,
          radius: 0,
          opacity: 0.4
        });
      }
    });

    canvas.addEventListener('click', (e) => {
      for (let i = 0; i < 3; i++) {
        ripples.push({
          x: e.clientX + (Math.random() - 0.5) * 30,
          y: e.clientY + (Math.random() - 0.5) * 30,
          radius: 0,
          opacity: 0.5
        });
      }
    });

    function drawRain() {
      ctx.clearRect(0, 0, width, height);

      // Draw raindrops
      raindrops.forEach(drop => {
        ctx.beginPath();
        ctx.moveTo(drop.x, drop.y);
        ctx.lineTo(drop.x + 1.5, drop.y + drop.length);
        ctx.strokeStyle = drop.color;
        ctx.lineWidth = 1.5;
        ctx.lineCap = 'round';
        ctx.stroke();

        // Update position
        drop.y += drop.speed;
        if (drop.y > height) {
          drop.y = -drop.length;
          drop.x = Math.random() * width;
        }
      });

      // Draw and update ripples
      ripples = ripples.filter(ripple => {
        ctx.beginPath();
        ctx.arc(ripple.x, ripple.y, ripple.radius, 0, Math.PI * 2);
        ctx.strokeStyle = `rgba(6, 182, 212, ${ripple.opacity})`;
        ctx.lineWidth = 1.5;
        ctx.stroke();

        ripple.radius += 2;
        ripple.opacity *= 0.96;

        return ripple.opacity > 0.01;
      });

      requestAnimationFrame(drawRain);
    }

    // Visibility API for performance
    let isVisible = true;
    document.addEventListener('visibilitychange', () => {
      isVisible = document.visibilityState === 'visible';
    });

    function animate() {
      if (isVisible) {
        requestAnimationFrame(drawRain);
      } else {
        requestAnimationFrame(animate);
      }
    }

    animate();

    // Handle resize
    window.addEventListener('resize', () => {
      width = window.innerWidth;
      height = window.innerHeight;
      canvas.width = width;
      canvas.height = height;
    });

    // Dispatch rain event for audio
    canvas.addEventListener('mousemove', () => {
      window.dispatchEvent(new CustomEvent('rain-drop', { detail: { x: Math.random() * width } }));
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initRain);
  } else {
    initRain();
  }

  document.addEventListener('astro:after-swap', initRain);
</script>

<style>
  #rain-container {
    position: fixed;
    inset: 0;
    z-index: 0;
  }
  #rain-canvas {
    width: 100%;
    height: 100%;
  }
</style>