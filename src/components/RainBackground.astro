---
// RainBackground - Professional rain effect with realistic ripples and mouse interaction
---

<div id="rain-container" class="fixed inset-0 w-full h-full z-0 overflow-hidden">
  <canvas id="rain-canvas"></canvas>
</div>

<script>
  class RainDrop {
    x: number;
    y: number;
    length: number;
    speed: number;
    opacity: number;
    width: number;

    constructor(width: number, height: number) {
      this.x = Math.random() * width;
      this.y = Math.random() * height;
      this.length = Math.random() * 20 + 15;
      this.speed = Math.random() * 10 + 12;
      this.opacity = Math.random() * 0.4 + 0.2;
      this.width = Math.random() * 1.5 + 0.5;
    }

    update(height: number, wind: number) {
      this.y += this.speed;
      this.x += wind;
      if (this.y > height) {
        this.y = -this.length;
        this.x = Math.random() * window.innerWidth;
      }
    }
  }

  class Ripple {
    x: number;
    y: number;
    radius: number;
    maxRadius: number;
    opacity: number;
    speed: number;
    rings: number[];

    constructor(x: number, y: number) {
      this.x = x;
      this.y = y;
      this.radius = 0;
      this.maxRadius = Math.random() * 60 + 40;
      this.opacity = 0.6;
      this.speed = Math.random() * 1.5 + 1;
      this.rings = [0, 0.3, 0.6];
    }

    update() {
      this.radius += this.speed;
      this.opacity *= 0.97;
      return this.opacity > 0.01 && this.radius < this.maxRadius;
    }
  }

  class Splash {
    x: number;
    y: number;
    particles: { x: number; y: number; vx: number; vy: number; life: number; size: number }[];
    opacity: number;

    constructor(x: number, y: number) {
      this.x = x;
      this.y = y;
      this.opacity = 1;
      this.particles = [];
      for (let i = 0; i < 8; i++) {
        const angle = (Math.PI * 2 * i) / 8 + Math.random() * 0.3;
        const speed = Math.random() * 3 + 2;
        this.particles.push({
          x: x,
          y: y,
          vx: Math.cos(angle) * speed,
          vy: -Math.random() * 4 - 2,
          life: 1,
          size: Math.random() * 2 + 1
        });
      }
    }

    update() {
      this.particles.forEach(p => {
        p.x += p.vx;
        p.y += p.vy;
        p.vy += 0.2;
        p.life -= 0.03;
      });
      this.particles = this.particles.filter(p => p.life > 0);
      return this.particles.length > 0;
    }
  }

  class RainSystem {
    private canvas: HTMLCanvasElement;
    private ctx: CanvasRenderingContext2D;
    private width: number = 0;
    private height: number = 0;
    private raindrops: RainDrop[] = [];
    private ripples: Ripple[] = [];
    private splashes: Splash[] = [];
    private maxDrops: number = 200;
    private wind: number = 0;
    private windTarget: number = 0;
    private mouseX: number = 0;
    private mouseY: number = 0;
    private isVisible: boolean = true;
    private lastTime: number = 0;

    constructor(canvas: HTMLCanvasElement) {
      this.canvas = canvas;
      const ctx = canvas.getContext('2d');
      if (!ctx) throw new Error('Could not get 2d context');
      this.ctx = ctx;
      this.resize();
      this.initRain();
      this.setupEvents();
    }

    private resize() {
      this.width = window.innerWidth;
      this.height = window.innerHeight;
      this.canvas.width = this.width;
      this.canvas.height = this.height;
    }

    private initRain() {
      this.raindrops = [];
      for (let i = 0; i < this.maxDrops; i++) {
        this.raindrops.push(new RainDrop(this.width, this.height));
      }
    }

    private setupEvents() {
      window.addEventListener('resize', () => this.resize());

      document.addEventListener('visibilitychange', () => {
        this.isVisible = document.visibilityState === 'visible';
      });

      this.canvas.addEventListener('mousemove', (e) => {
        this.mouseX = e.clientX;
        this.mouseY = e.clientY;

        if (Math.random() > 0.7) {
          this.ripples.push(new Ripple(this.mouseX, this.mouseY));
        }
      });

      this.canvas.addEventListener('click', (e) => {
        const x = e.clientX;
        const y = e.clientY;

        for (let i = 0; i < 3; i++) {
          const offsetX = (Math.random() - 0.5) * 40;
          const offsetY = (Math.random() - 0.5) * 40;
          this.ripples.push(new Ripple(x + offsetX, y + offsetY));
        }

        this.splashes.push(new Splash(x, y));

        window.dispatchEvent(new CustomEvent('rain-splash', {
          detail: { x, y }
        }));
      });

      this.canvas.addEventListener('touchmove', (e) => {
        if (e.touches.length > 0) {
          const touch = e.touches[0];
          this.mouseX = touch.clientX;
          this.mouseY = touch.clientY;
          if (Math.random() > 0.6) {
            this.ripples.push(new Ripple(this.mouseX, this.mouseY));
          }
        }
      });

      this.canvas.addEventListener('touchstart', (e) => {
        if (e.touches.length > 0) {
          const touch = e.touches[0];
          for (let i = 0; i < 2; i++) {
            this.ripples.push(new Ripple(
              touch.clientX + (Math.random() - 0.5) * 30,
              touch.clientY + (Math.random() - 0.5) * 30
            ));
          }
          this.splashes.push(new Splash(touch.clientX, touch.clientY));
        }
      });
    }

    private drawRain() {
      const ctx = this.ctx;

      this.raindrops.forEach(drop => {
        const gradient = ctx.createLinearGradient(
          drop.x, drop.y,
          drop.x, drop.y + drop.length
        );
        gradient.addColorStop(0, `rgba(6, 182, 212, 0)`);
        gradient.addColorStop(0.3, `rgba(6, 182, 212, ${drop.opacity * 0.5})`);
        gradient.addColorStop(1, `rgba(6, 182, 212, ${drop.opacity})`);

        ctx.beginPath();
        ctx.moveTo(drop.x, drop.y);
        ctx.lineTo(drop.x + drop.width + this.wind * 2, drop.y + drop.length);
        ctx.strokeStyle = gradient;
        ctx.lineWidth = drop.width;
        ctx.lineCap = 'round';
        ctx.stroke();

        drop.update(this.height, this.wind);
      });
    }

    private drawRipples() {
      const ctx = this.ctx;

      this.ripples = this.ripples.filter(ripple => {
        const isAlive = ripple.update();

        ripple.rings.forEach((ringOffset, i) => {
          const r = ripple.radius + ringOffset * 20;
          if (r > 0 && r < ripple.maxRadius) {
            const ringOpacity = ripple.opacity * (1 - r / ripple.maxRadius) * 0.5;
            ctx.beginPath();
            ctx.arc(ripple.x, ripple.y, r, 0, Math.PI * 2);
            ctx.strokeStyle = `rgba(6, 182, 212, ${ringOpacity})`;
            ctx.lineWidth = 1.5 - (r / ripple.maxRadius);
            ctx.stroke();
          }
        });

        if (ripple.radius < 10) {
          ctx.beginPath();
          ctx.arc(ripple.x, ripple.y, 3, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(6, 182, 212, ${ripple.opacity * 0.5})`;
          ctx.fill();
        }

        return isAlive;
      });
    }

    private drawSplashes() {
      const ctx = this.ctx;

      this.splashes = this.splashes.filter(splash => {
        const isAlive = splash.update();

        splash.particles.forEach(p => {
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.size * p.life, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(6, 182, 212, ${p.life * 0.6})`;
          ctx.fill();
        });

        return isAlive;
      });
    }

    private updateWind() {
      this.windTarget = Math.sin(Date.now() * 0.0003) * 0.5;
      this.wind += (this.windTarget - this.wind) * 0.02;
    }

    animate(currentTime: number) {
      if (!this.isVisible) {
        requestAnimationFrame((t) => this.animate(t));
        return;
      }

      const deltaTime = currentTime - this.lastTime;
      this.lastTime = currentTime;

      this.ctx.clearRect(0, 0, this.width, this.height);

      this.updateWind();
      this.drawRain();
      this.drawRipples();
      this.drawSplashes();

      requestAnimationFrame((t) => this.animate(t));
    }

    resize() {
      this.width = window.innerWidth;
      this.height = window.innerHeight;
      this.canvas.width = this.width;
      this.canvas.height = this.height;
    }
  }

  function initRain() {
    const container = document.getElementById('rain-container');
    const canvas = document.getElementById('rain-canvas') as HTMLCanvasElement;
    if (!container || !canvas) return;

    const rainSystem = new RainSystem(canvas);
    rainSystem.animate(0);

    (window as any).rainSystem = rainSystem;
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initRain);
  } else {
    initRain();
  }

  document.addEventListener('astro:after-swap', initRain);
</script>

<style>
  #rain-container {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  #rain-canvas {
    width: 100%;
    height: 100%;
    cursor: crosshair;
    pointer-events: auto;
  }
</style>