---
// RainBackground - Rain effect with mouse sparkle trails
---

<div id="rain-container" class="fixed inset-0 w-full h-full z-0 overflow-hidden">
  <canvas id="rain-canvas"></canvas>
</div>

<script>
  class RainDrop {
    x: number;
    y: number;
    length: number;
    speed: number;
    opacity: number;
    width: number;

    constructor(width: number, height: number) {
      this.x = Math.random() * width;
      this.y = Math.random() * height;
      this.length = Math.random() * 20 + 15;
      this.speed = Math.random() * 10 + 12;
      this.opacity = Math.random() * 0.4 + 0.2;
      this.width = Math.random() * 1.5 + 0.5;
    }

    update(height: number, wind: number) {
      this.y += this.speed;
      this.x += wind;
      if (this.y > height) {
        this.y = -this.length;
        this.x = Math.random() * window.innerWidth;
      }
    }
  }

  class Sparkle {
    x: number;
    y: number;
    vx: number;
    vy: number;
    life: number;
    maxLife: number;
    size: number;
    hue: number;

    constructor(x: number, y: number, mouseVx: number, mouseVy: number) {
      this.x = x;
      this.y = y;
      const speed = Math.sqrt(mouseVx * mouseVx + mouseVy * mouseVy);
      const angle = Math.atan2(mouseVy, mouseVx) + (Math.random() - 0.5) * Math.PI * 0.5;
      const sparkSpeed = Math.min(speed * 0.3 + Math.random() * 2, 8);
      this.vx = Math.cos(angle) * sparkSpeed;
      this.vy = Math.sin(angle) * sparkSpeed;
      this.maxLife = Math.random() * 30 + 20;
      this.life = this.maxLife;
      this.size = Math.random() * 3 + 2;
      this.hue = Math.random() * 30 + 175; // cyan range 175-205
    }

    update() {
      this.x += this.vx;
      this.y += this.vy;
      this.vx *= 0.96;
      this.vy *= 0.96;
      this.vy += 0.05; // slight gravity
      this.life--;
      return this.life > 0;
    }

    draw(ctx: CanvasRenderingContext2D) {
      const alpha = this.life / this.maxLife;
      const glow = Math.sin(alpha * Math.PI) * 0.8;

      ctx.save();
      ctx.beginPath();
      ctx.arc(this.x, this.y, this.size * alpha, 0, Math.PI * 2);
      ctx.fillStyle = `hsla(${this.hue}, 90%, 65%, ${alpha * 0.8})`;
      ctx.fill();

      // Glow effect
      ctx.beginPath();
      ctx.arc(this.x, this.y, this.size * 2 * alpha, 0, Math.PI * 2);
      ctx.fillStyle = `hsla(${this.hue}, 100%, 80%, ${glow * 0.3})`;
      ctx.fill();
      ctx.restore();
    }
  }

  class Star {
    x: number;
    y: number;
    size: number;
    twinkle: number;
    twinkleSpeed: number;

    constructor(width: number, height: number) {
      this.x = Math.random() * width;
      this.y = Math.random() * height;
      this.size = Math.random() * 1.5 + 0.5;
      this.twinkle = Math.random() * Math.PI * 2;
      this.twinkleSpeed = Math.random() * 0.05 + 0.02;
    }

    update() {
      this.twinkle += this.twinkleSpeed;
    }

    draw(ctx: CanvasRenderingContext2D) {
      const alpha = (Math.sin(this.twinkle) * 0.3 + 0.7) * 0.4;
      ctx.beginPath();
      ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(200, 230, 255, ${alpha})`;
      ctx.fill();
    }
  }

  class RainSystem {
    private canvas: HTMLCanvasElement;
    private ctx: CanvasRenderingContext2D;
    private width: number = 0;
    private height: number = 0;
    private raindrops: RainDrop[] = [];
    private sparkles: Sparkle[] = [];
    private stars: Star[] = [];
    private maxDrops: number = 150;
    private maxSparkles: number = 100;
    private wind: number = 0;
    private windTarget: number = 0;
    private lastMouseX: number = 0;
    private lastMouseY: number = 0;
    private lastMouseTime: number = 0;
    private isVisible: boolean = true;

    constructor(canvas: HTMLCanvasElement) {
      this.canvas = canvas;
      const ctx = canvas.getContext('2d');
      if (!ctx) throw new Error('Could not get 2d context');
      this.ctx = ctx;
      this.resize();
      this.initRain();
      this.initStars();
      this.setupEvents();
    }

    private resize() {
      this.width = window.innerWidth;
      this.height = window.innerHeight;
      this.canvas.width = this.width;
      this.canvas.height = this.height;
    }

    private initRain() {
      this.raindrops = [];
      for (let i = 0; i < this.maxDrops; i++) {
        this.raindrops.push(new RainDrop(this.width, this.height));
      }
    }

    private initStars() {
      this.stars = [];
      const starCount = Math.floor((this.width * this.height) / 15000);
      for (let i = 0; i < Math.min(starCount, 100); i++) {
        this.stars.push(new Star(this.width, this.height));
      }
    }

    private setupEvents() {
      window.addEventListener('resize', () => {
        this.resize();
        this.initStars();
      });

      document.addEventListener('visibilitychange', () => {
        this.isVisible = document.visibilityState === 'visible';
      });

      // Use document-level mouse events for full screen interaction
      document.addEventListener('mousemove', (e) => {
        const now = Date.now();
        const dx = e.clientX - this.lastMouseX;
        const dy = e.clientY - this.lastMouseY;
        const dt = Math.max(1, now - this.lastMouseTime);
        const speed = Math.sqrt(dx * dx + dy * dy) / dt * 16;

        if (speed > 0.5 && Math.random() > 0.3) {
          const count = Math.min(Math.floor(speed * 0.5) + 1, 5);
          for (let i = 0; i < count; i++) {
            if (this.sparkles.length < this.maxSparkles) {
              this.sparkles.push(new Sparkle(e.clientX, e.clientY, dx / dt * 16, dy / dt * 16));
            }
          }

          // Dispatch event for sound
          window.dispatchEvent(new CustomEvent('rain-sparkle', {
            detail: { x: e.clientX, y: e.clientY, speed }
          }));
        }

        this.lastMouseX = e.clientX;
        this.lastMouseY = e.clientY;
        this.lastMouseTime = now;
      });

      document.addEventListener('click', (e) => {
        const x = e.clientX;
        const y = e.clientY;

        // Create burst of sparkles
        for (let i = 0; i < 15; i++) {
          const angle = (Math.PI * 2 * i) / 15;
          const speed = Math.random() * 4 + 2;
          const sparkle = new Sparkle(x, y, Math.cos(angle) * speed, Math.sin(angle) * speed);
          sparkle.life = sparkle.maxLife;
          this.sparkles.push(sparkle);
        }

        window.dispatchEvent(new CustomEvent('rain-burst', {
          detail: { x, y }
        }));
      });
    }

    private drawRain() {
      const ctx = this.ctx;

      this.raindrops.forEach(drop => {
        const gradient = ctx.createLinearGradient(
          drop.x, drop.y,
          drop.x, drop.y + drop.length
        );
        gradient.addColorStop(0, `rgba(6, 182, 212, 0)`);
        gradient.addColorStop(0.3, `rgba(6, 182, 212, ${drop.opacity * 0.5})`);
        gradient.addColorStop(1, `rgba(6, 182, 212, ${drop.opacity})`);

        ctx.beginPath();
        ctx.moveTo(drop.x, drop.y);
        ctx.lineTo(drop.x + drop.width + this.wind * 2, drop.y + drop.length);
        ctx.strokeStyle = gradient;
        ctx.lineWidth = drop.width;
        ctx.lineCap = 'round';
        ctx.stroke();

        drop.update(this.height, this.wind);
      });
    }

    private drawStars() {
      this.stars.forEach(star => {
        star.update();
        star.draw(this.ctx);
      });
    }

    private drawSparkles() {
      this.sparkles = this.sparkles.filter(sparkle => {
        const alive = sparkle.update();
        if (alive) {
          sparkle.draw(this.ctx);
        }
        return alive;
      });
    }

    private updateWind() {
      this.windTarget = Math.sin(Date.now() * 0.0003) * 0.5;
      this.wind += (this.windTarget - this.wind) * 0.02;
    }

    animate() {
      if (!this.isVisible) {
        requestAnimationFrame(() => this.animate());
        return;
      }

      this.ctx.clearRect(0, 0, this.width, this.height);

      this.updateWind();
      this.drawStars();
      this.drawRain();
      this.drawSparkles();

      requestAnimationFrame(() => this.animate());
    }
  }

  function initRain() {
    const container = document.getElementById('rain-container');
    const canvas = document.getElementById('rain-canvas') as HTMLCanvasElement;
    if (!container || !canvas) return;

    const rainSystem = new RainSystem(canvas);
    rainSystem.animate();

    (window as any).rainSystem = rainSystem;
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initRain);
  } else {
    initRain();
  }

  document.addEventListener('astro:after-swap', initRain);
</script>

<style>
  #rain-container {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  #rain-canvas {
    width: 100%;
    height: 100%;
    cursor: pointer;
    pointer-events: auto;
  }
</style>