---
// FontSizeToggle - Switch between small/medium/large font sizes for article content
---

<button
  id="font-size-toggle"
  class="p-2 rounded-lg hover:bg-[rgba(80,128,176,0.1)] transition-colors"
  aria-label="切换字体大小"
  title="字体大小"
>
  <svg class="w-5 h-5 text-[#72a8d8]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h8m-8 6h16"/>
  </svg>
</button>

<div id="font-size-menu" class="hidden absolute right-0 top-full mt-2 p-2 rounded-xl backdrop-blur-xl bg-[rgba(30,45,65,0.98)] border border-[rgba(80,128,176,0.3)] shadow-xl z-50 min-w-[120px]">
  <div class="text-xs text-[#8a9cc4] px-2 py-1 mb-1">字体大小</div>
  <button data-size="small" class="font-size-btn w-full text-left px-3 py-2 rounded-lg text-sm text-[#b2c0d8] hover:bg-[rgba(80,128,176,0.1)] transition-colors">
    小
  </button>
  <button data-size="medium" class="font-size-btn w-full text-left px-3 py-2 rounded-lg text-sm text-[#b2c0d8] hover:bg-[rgba(80,128,176,0.1)] transition-colors">
    中
  </button>
  <button data-size="large" class="font-size-btn w-full text-left px-3 py-2 rounded-lg text-sm text-[#b2c0d8] hover:bg-[rgba(80,128,176,0.1)] transition-colors">
    大
  </button>
</div>

<script>
  function initFontSizeToggle() {
    const toggleBtn = document.getElementById('font-size-toggle');
    const menu = document.getElementById('font-size-menu');
    if (!toggleBtn || !menu) return;

    const fontSizes = {
      small: '16px',
      medium: '18px',
      large: '20px'
    };

    // Get saved preference or default to medium
    const saved = localStorage.getItem('article-font-size') || 'medium';
    applyFontSize(saved);

    // Toggle menu
    toggleBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      menu.classList.toggle('hidden');
    });

    // Close menu on outside click
    document.addEventListener('click', () => {
      menu.classList.add('hidden');
    });

    // Handle size selection
    menu.querySelectorAll('.font-size-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const size = (btn as HTMLElement).dataset.size as keyof typeof fontSizes;
        applyFontSize(size);
        menu.classList.add('hidden');
      });
    });

    function applyFontSize(size: keyof typeof fontSizes) {
      document.documentElement.style.setProperty('--article-font-size', fontSizes[size]);
      localStorage.setItem('article-font-size', size);

      // Update active state
      menu.querySelectorAll('.font-size-btn').forEach(btn => {
        const btnSize = (btn as HTMLElement).dataset.size;
        if (btnSize === size) {
          btn.classList.add('bg-[rgba(80,128,176,0.2)]', 'text-[#72a8d8]');
        } else {
          btn.classList.remove('bg-[rgba(80,128,176,0.2)]', 'text-[#72a8d8]');
        }
      });
    }
  }

  initFontSizeToggle();
  document.addEventListener('astro:after-swap', initFontSizeToggle);
</script>