---
// OceanWaves - Animated ocean wave background effect
---

<div id="ocean-waves" class="fixed inset-0 w-full h-full pointer-events-none z-[1] overflow-hidden">
  <svg class="absolute bottom-0 w-full" viewBox="0 0 1440 320" preserveAspectRatio="none">
    <defs>
      <linearGradient id="wave-gradient-1" x1="0%" y1="0%" x2="0%" y2="100%">
        <stop offset="0%" style="stop-color:rgba(30, 60, 114, 0.3)"/>
        <stop offset="100%" style="stop-color:rgba(30, 60, 114, 0.6)"/>
      </linearGradient>
      <linearGradient id="wave-gradient-2" x1="0%" y1="0%" x2="0%" y2="100%">
        <stop offset="0%" style="stop-color:rgba(50, 100, 150, 0.25)"/>
        <stop offset="100%" style="stop-color:rgba(50, 100, 150, 0.5)"/>
      </linearGradient>
      <linearGradient id="wave-gradient-3" x1="0%" y1="0%" x2="0%" y2="100%">
        <stop offset="0%" style="stop-color:rgba(20, 40, 80, 0.35)"/>
        <stop offset="100%" style="stop-color:rgba(20, 40, 80, 0.65)"/>
      </linearGradient>
    </defs>
    <path id="wave1" fill="url(#wave-gradient-1)" d="M0,192L48,197.3C96,203,192,213,288,229.3C384,245,480,267,576,250.7C672,235,768,181,864,181.3C960,181,1056,235,1152,234.7C1248,235,1344,181,1392,154.7L1440,128L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path>
    <path id="wave2" fill="url(#wave-gradient-2)" d="M0,256L48,261.3C96,267,192,277,288,266.7C384,256,480,224,576,218.7C672,213,768,235,864,261.3C960,288,1056,320,1152,304C1248,288,1344,224,1392,192L1440,160L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path>
    <path id="wave3" fill="url(#wave-gradient-3)" d="M0,96L48,101.3C96,107,192,117,288,144C384,171,480,213,576,218.7C672,224,768,192,864,181.3C960,171,1056,181,1152,197.3C1248,213,1344,235,1392,245.3L1440,256L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"></path>
  </svg>
</div>

<style>
  @keyframes wave {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  #wave1 {
    animation: wave 25s linear infinite;
  }
  #wave2 {
    animation: wave 20s linear infinite reverse;
  }
  #wave3 {
    animation: wave 15s linear infinite;
  }
</style>
