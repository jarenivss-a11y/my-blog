---
// Read Aloud - Text to Speech component using Web Speech API
---

<button
  id="read-aloud-btn"
  class="fixed bottom-24 right-4 z-50 p-3 rounded-full backdrop-blur-xl bg-white/80 dark:bg-slate-800/80 border border-white/50 dark:border-slate-700/50 shadow-lg hover:shadow-xl transition-all hover:scale-105"
  aria-label="朗读文章"
  title="朗读文章"
>
  <svg class="w-5 h-5 text-slate-600 dark:text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z"/>
  </svg>
</button>

<!-- Control Panel -->
<div id="read-aloud-panel" class="hidden fixed bottom-36 right-4 z-50 p-4 rounded-2xl backdrop-blur-xl bg-white/90 dark:bg-slate-800/90 border border-white/50 dark:border-slate-700/50 shadow-xl w-72">
  <div class="flex items-center justify-between mb-3">
    <span class="text-sm font-medium text-slate-700 dark:text-slate-200">朗读中</span>
    <button id="close-aloud-panel" class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-300">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <!-- Progress -->
  <div class="mb-3">
    <div class="h-1.5 bg-slate-200 dark:bg-slate-700 rounded-full overflow-hidden">
      <div id="aloud-progress" class="h-full bg-primary transition-all duration-300" style="width: 0%"></div>
    </div>
    <div class="flex justify-between text-xs text-slate-400 mt-1">
      <span id="aloud-current-time">0:00</span>
      <span id="aloud-total-time">0:00</span>
    </div>
  </div>

  <!-- Controls -->
  <div class="flex items-center justify-center gap-3">
    <button id="aloud-rewind" class="p-2 rounded-full hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors">
      <svg class="w-5 h-5 text-slate-600 dark:text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12.066 11.2a1 1 0 000 1.6l5.334 4A1 1 0 0019 16V8a1 1 0 00-1.6-.8l-5.333 4zM4.066 11.2a1 1 0 000 1.6l5.334 4A1 1 0 0011 16V8a1 1 0 00-1.6-.8l-5.334 4z"/>
      </svg>
    </button>
    <button id="aloud-play" class="p-3 rounded-full bg-primary text-white hover:bg-primary/90 transition-colors">
      <svg id="play-icon" class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
        <path d="M8 5v14l11-7z"/>
      </svg>
      <svg id="pause-icon" class="w-6 h-6 hidden" fill="currentColor" viewBox="0 0 24 24">
        <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
      </svg>
    </button>
    <button id="aloud-forward" class="p-2 rounded-full hover:bg-slate-100 dark:hover:bg-slate-700 transition-colors">
      <svg class="w-5 h-5 text-slate-600 dark:text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.933 12.8a1 1 0 000-1.6L6.6 7.2A1 1 0 005 8v8a1 1 0 001.6.8l5.333-4zM19.933 12.8a1 1 0 000-1.6l-5.333-4A1 1 0 0013 8v8a1 1 0 001.6.8l5.333-4z"/>
      </svg>
    </button>
  </div>

  <!-- Speed control -->
  <div class="mt-3 flex items-center justify-between">
    <span class="text-xs text-slate-400">速度</span>
    <div class="flex gap-1">
      <button class="speed-btn px-2 py-1 text-xs rounded bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 hover:bg-primary hover:text-white transition-colors" data-speed="0.5">0.5x</button>
      <button class="speed-btn px-2 py-1 text-xs rounded bg-primary text-white" data-speed="1">1x</button>
      <button class="speed-btn px-2 py-1 text-xs rounded bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 hover:bg-primary hover:text-white transition-colors" data-speed="1.5">1.5x</button>
      <button class="speed-btn px-2 py-1 text-xs rounded bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 hover:bg-primary hover:text-white transition-colors" data-speed="2">2x</button>
    </div>
  </div>
</div>

<script>
  function initReadAloud() {
    const btn = document.getElementById('read-aloud-btn');
    const panel = document.getElementById('read-aloud-panel');
    const closeBtn = document.getElementById('close-aloud-panel');
    const playBtn = document.getElementById('aloud-play');
    const rewindBtn = document.getElementById('aloud-rewind');
    const forwardBtn = document.getElementById('aloud-forward');
    const progressBar = document.getElementById('aloud-progress');
    const currentTimeEl = document.getElementById('aloud-current-time');
    const totalTimeEl = document.getElementById('aloud-total-time');
    const playIcon = document.getElementById('play-icon');
    const pauseIcon = document.getElementById('pause-icon');
    const speedBtns = document.querySelectorAll('.speed-btn');

    if (!btn || !panel) return;

    let utterance: SpeechSynthesisUtterance | null = null;
    let isPlaying = false;
    let currentSpeed = 1;
    let spokenChars = 0;
    let totalChars = 0;

    const article = document.querySelector('article');
    const text = article?.textContent || '';

    // Calculate estimated time (average 150 words per minute, ~900 characters)
    const words = text.split(/\s+/).length;
    const minutes = words / 150;
    totalTimeEl!.textContent = `${Math.floor(minutes)}:${String(Math.round((minutes % 1) * 60)).padStart(2, '0')}`;
    totalChars = text.length;

    const togglePanel = () => {
      panel.classList.toggle('hidden');
    };

    btn.addEventListener('click', () => {
      if (panel.classList.contains('hidden')) {
        togglePanel();
        startSpeaking();
      }
    });

    closeBtn?.addEventListener('click', () => {
      togglePanel();
      stopSpeaking();
    });

    playBtn?.addEventListener('click', () => {
      if (isPlaying) {
        pauseSpeaking();
      } else {
        startSpeaking();
      }
    });

    rewindBtn?.addEventListener('click', () => {
      // Skip back ~10 seconds worth of text
      spokenChars = Math.max(0, spokenChars - 1500);
      restartSpeaking();
    });

    forwardBtn?.addEventListener('click', () => {
      // Skip forward ~10 seconds worth of text
      spokenChars = Math.min(totalChars, spokenChars + 1500);
      restartSpeaking();
    });

    speedBtns.forEach(speedBtn => {
      speedBtn.addEventListener('click', () => {
        currentSpeed = parseFloat(speedBtn.getAttribute('data-speed') || '1');
        speedBtns.forEach(b => {
          b.classList.remove('bg-primary', 'text-white');
          b.classList.add('bg-slate-100', 'dark:bg-slate-700', 'text-slate-600', 'dark:text-slate-300');
        });
        speedBtn.classList.remove('bg-slate-100', 'dark:bg-slate-700', 'text-slate-600', 'dark:text-slate-300');
        speedBtn.classList.add('bg-primary', 'text-white');
        if (utterance) {
          utterance.rate = currentSpeed;
        }
      });
    });

    function startSpeaking() {
      if (!('speechSynthesis' in window)) {
        alert('您的浏览器不支持语音合成');
        return;
      }

      const textToSpeak = text.slice(spokenChars);

      utterance = new SpeechSynthesisUtterance(textToSpeak);
      utterance.rate = currentSpeed;
      utterance.lang = 'zh-CN';
      utterance.pitch = 1;

      utterance.onboundary = (event) => {
        if (event.name === 'word' || event.charIndex !== undefined) {
          spokenChars += event.charIndex || 0;
          const progress = (spokenChars / totalChars) * 100;
          progressBar!.style.width = `${Math.min(100, progress)}%`;

          // Update time
          const spokenWords = spokenChars / 5;
          const currentMinutes = spokenWords / 150;
          currentTimeEl!.textContent = `${Math.floor(currentMinutes)}:${String(Math.round((currentMinutes % 1) * 60)).padStart(2, '0')}`;
        }
      };

      utterance.onend = () => {
        isPlaying = false;
        playIcon?.classList.remove('hidden');
        pauseIcon?.classList.add('hidden');
        progressBar!.style.width = '100%';
      };

      utterance.onerror = () => {
        isPlaying = false;
        playIcon?.classList.remove('hidden');
        pauseIcon?.classList.add('hidden');
      };

      speechSynthesis.speak(utterance);
      isPlaying = true;
      playIcon?.classList.add('hidden');
      pauseIcon?.classList.remove('hidden');
    }

    function pauseSpeaking() {
      speechSynthesis.pause();
      isPlaying = false;
      playIcon?.classList.remove('hidden');
      pauseIcon?.classList.add('hidden');
    }

    function stopSpeaking() {
      speechSynthesis.cancel();
      isPlaying = false;
      playIcon?.classList.remove('hidden');
      pauseIcon?.classList.add('hidden');
    }

    function restartSpeaking() {
      stopSpeaking();
      setTimeout(startSpeaking, 100);
    }
  }

  initReadAloud();
  document.addEventListener('astro:after-swap', initReadAloud);
</script>
