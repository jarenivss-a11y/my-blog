---
// Browse History Component - tracks recently viewed posts
interface Props {
  maxItems?: number;
}

const { maxItems = 5 } = Astro.props;
---

<div id="browse-history" class="p-5 rounded-2xl backdrop-blur-xl bg-[rgba(155,180,218,0.05)] border border-[rgba(165,188,230,0.12)] shadow-[0_8px_32px_rgba(0,0,0,0.1)]">
  <h4 class="text-xs font-medium text-[#8a9cc4] uppercase tracking-widest mb-4 flex items-center gap-2">
    <span class="w-8 h-px bg-gradient-to-r from-transparent to-[rgba(80,128,176,0.4)]"></span>
    最近浏览
  </h4>
  <div id="history-list" class="space-y-2">
    <p class="text-sm text-[#7a8cb4] italic">暂无浏览记录</p>
  </div>
</div>

<script define:vars={{ maxItems }}>
  const STORAGE_KEY = 'browse-history';

  function getHistory() {
    try {
      return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
    } catch {
      return [];
    }
  }

  function addToHistory(postId, title, url) {
    const history = getHistory().filter(item => item.id !== postId);
    history.unshift({ id: postId, title, url, time: Date.now() });
    const trimmed = history.slice(0, maxItems);
    localStorage.setItem(STORAGE_KEY, JSON.stringify(trimmed));
    renderHistory();
  }

  function renderHistory() {
    const list = document.getElementById('history-list');
    if (!list) return;

    const history = getHistory();
    if (history.length === 0) {
      list.innerHTML = '<p class="text-sm text-[#7a8cb4] italic">暂无浏览记录</p>';
      return;
    }

    list.innerHTML = history.map(item => `
      <a href="${item.url}" class="group block text-sm text-[#b2c0d8] hover:text-[#8ac4e8] transition-all duration-300 line-clamp-2 py-2 px-3 rounded-lg hover:bg-[rgba(80,128,176,0.1)] -mx-3">
        <span class="text-[#5080b0] mr-2 opacity-60 group-hover:opacity-100 transition-opacity">·</span>${item.title}
      </a>
    `).join('');
  }

  // Track current page
  const titleEl = document.querySelector('h1');
  if (titleEl && window.location.pathname.includes('/post/')) {
    const title = titleEl.textContent?.trim() || '';
    const path = window.location.pathname;
    addToHistory(path, title, path);
  }

  renderHistory();
</script>
