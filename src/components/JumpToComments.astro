---
// Jump to Comments Button - appears after scrolling past 50% of article
---

<div id="jump-to-comments" class="fixed right-4 z-40 opacity-0 pointer-events-none transition-all duration-300 translate-y-4">
  <button
    id="jump-btn"
    class="p-3 rounded-full backdrop-blur-xl bg-[rgba(155,180,218,0.1)] border border-[rgba(80,128,176,0.3)] shadow-lg hover:shadow-[0_8px 32px_rgba(80,128,176,0.3)] transition-all hover:scale-105 flex items-center gap-2"
    aria-label="跳转至评论"
  >
    <svg class="w-5 h-5 text-[#72a8d8]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
    </svg>
    <span class="text-sm text-[#72a8d8] hidden sm:inline">评论</span>
  </button>
</div>

<script>
  function initJumpToComments() {
    const container = document.getElementById('jump-to-comments');
    const btn = document.getElementById('jump-btn');
    const commentsSection = document.getElementById('comments');

    if (!container || !btn) return;

    const toggleVisibility = () => {
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;

      // Show button after scrolling past 50%
      if (progress > 50) {
        container.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-4');
        container.classList.add('opacity-100', 'translate-y-0');
      } else {
        container.classList.add('opacity-0', 'pointer-events-none', 'translate-y-4');
        container.classList.remove('opacity-100', 'translate-y-0');
      }
    };

    btn.addEventListener('click', () => {
      commentsSection?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });

    window.addEventListener('scroll', toggleVisibility, { passive: true });
    toggleVisibility();
  }

  initJumpToComments();
  document.addEventListener('astro:after-swap', initJumpToComments);
</script>