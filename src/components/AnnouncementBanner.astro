---
// Announcement Banner Component
// Set announcement text and visibility in the script below

interface Props {
  message?: string;
  link?: { text: string; href: string };
}

const {
  message = "🎉 博客新版上线！新增主题颜色切换和键盘快捷键功能",
  link = { text: "了解更多", href: "/my-blog/about" }
} = Astro.props;

const isVisible = true; // Set to false to hide the banner
---

{isVisible && (
  <div id="announcement-banner" class="fixed top-0 left-0 right-0 z-[60] transform transition-transform duration-300">
    <div class="bg-gradient-to-r from-primary via-purple-500 to-pink-500 text-white py-2 px-4">
      <div class="max-w-6xl mx-auto flex items-center justify-center gap-4 text-sm">
        <span class="text-center">{message}</span>
        <a
          href={link.href}
          class="px-3 py-1 rounded-full bg-white/20 hover:bg-white/30 transition-colors font-medium text-xs"
        >
          {link.text} →
        </a>
        <button
          id="close-announcement"
          class="absolute right-4 top-1/2 -translate-y-1/2 p-1 hover:bg-white/20 rounded transition-colors"
          aria-label="关闭公告"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
)}

<script>
  function initAnnouncement() {
    const banner = document.getElementById('announcement-banner');
    const closeBtn = document.getElementById('close-announcement');
    const STORAGE_KEY = 'announcement-closed';

    // Check if previously closed
    if (localStorage.getItem(STORAGE_KEY)) {
      banner?.classList.add('hidden');
      // Adjust navbar if banner is hidden
      document.body.classList.add('banner-closed');
    }

    closeBtn?.addEventListener('click', () => {
      banner?.classList.add('-translate-y-full');
      setTimeout(() => banner?.classList.add('hidden'), 300);
      localStorage.setItem(STORAGE_KEY, 'true');
      document.body.classList.add('banner-closed');
    });
  }

  initAnnouncement();
  document.addEventListener('astro:after-swap', initAnnouncement);
</script>

<style>
  .banner-closed #navbar {
    @apply top-0;
  }
  .banner-closed #main-content {
    @apply pt-16;
  }
</style>
