---
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const publishedPosts = allPosts.filter(p => !p.data.draft);

const postDates = publishedPosts.map(p => p.data.published.toISOString().split('T')[0]);

const now = new Date();
const year = now.getFullYear();
const month = now.getMonth();

const firstDay = new Date(year, month, 1).getDay();
const daysInMonth = new Date(year, month + 1, 0).getDate();

const calendarDays: (number | null)[] = [];
for (let i = 0; i < firstDay; i++) {
  calendarDays.push(null);
}
for (let i = 1; i <= daysInMonth; i++) {
  calendarDays.push(i);
}

const monthNames = ['一月', '二月', '三月', '四月', '五月', '六月', '七月', '八月', '九月', '十月', '十一月', '十二月'];
---

<div class="p-5 rounded-2xl backdrop-blur-xl bg-[rgba(155,180,218,0.05)] border border-[rgba(165,188,230,0.12)] shadow-[0_8px_32px_rgba(0,0,0,0.1)]">
  <div class="flex items-center justify-between mb-4">
    <h4 class="text-xs font-medium text-[#8a9cc4] uppercase tracking-widest">{year}年 {monthNames[month]}</h4>
    <span class="text-xs text-[#8a9cc4]">{publishedPosts.length} 篇文章</span>
  </div>

  <div class="grid grid-cols-7 gap-1 text-center mb-2">
    <span class="text-xs text-[#7a8cb4]">日</span>
    <span class="text-xs text-[#7a8cb4]">一</span>
    <span class="text-xs text-[#7a8cb4]">二</span>
    <span class="text-xs text-[#7a8cb4]">三</span>
    <span class="text-xs text-[#7a8cb4]">四</span>
    <span class="text-xs text-[#7a8cb4]">五</span>
    <span class="text-xs text-[#7a8cb4]">六</span>
  </div>

  <div class="grid grid-cols-7 gap-1">
    {calendarDays.map(day => {
      if (day === null) {
        return <div></div>;
      }
      const dateStr = `${year}-${String(month + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
      const hasPost = postDates.includes(dateStr);
      const isToday = dateStr === now.toISOString().split('T')[0];
      return (
        <div class={`group aspect-square flex items-center justify-center rounded-full text-xs transition-all duration-300 ${
          hasPost
            ? 'bg-[rgba(80,128,176,0.25)] text-[#72a8d8] font-medium hover:bg-[rgba(80,128,176,0.4)]'
            : isToday
              ? 'ring-1 ring-[rgba(80,128,176,0.5)] text-[#72a8d8] hover:ring-2 hover:ring-[rgba(80,128,176,0.7)]'
              : 'text-[#7a8cb4] hover:text-[#8a9cc4]'
        }`}>
          {day}
        </div>
      );
    })}
  </div>
</div>