---
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const publishedPosts = allPosts.filter(p => !p.data.draft);

const postDates = publishedPosts.map(p => p.data.published.toISOString().split('T')[0]);

const now = new Date();
const year = now.getFullYear();
const month = now.getMonth();

const firstDay = new Date(year, month, 1).getDay();
const daysInMonth = new Date(year, month + 1, 0).getDate();

const calendarDays: (number | null)[] = [];
for (let i = 0; i < firstDay; i++) {
  calendarDays.push(null);
}
for (let i = 1; i <= daysInMonth; i++) {
  calendarDays.push(i);
}

const monthNames = ['一月', '二月', '三月', '四月', '五月', '六月', '七月', '八月', '九月', '十月', '十一月', '十二月'];
---

<div class="p-4 rounded-2xl backdrop-blur-xl bg-white/70 dark:bg-slate-800/50 border border-white/50 dark:border-slate-700/50">
  <div class="flex items-center justify-between mb-4">
    <h4 class="text-xs font-medium text-slate-400 uppercase tracking-widest">{year}年 {monthNames[month]}</h4>
    <span class="text-xs text-slate-400">{publishedPosts.length} 篇文章</span>
  </div>

  <div class="grid grid-cols-7 gap-1 text-center mb-2">
    <span class="text-xs text-slate-400">日</span>
    <span class="text-xs text-slate-400">一</span>
    <span class="text-xs text-slate-400">二</span>
    <span class="text-xs text-slate-400">三</span>
    <span class="text-xs text-slate-400">四</span>
    <span class="text-xs text-slate-400">五</span>
    <span class="text-xs text-slate-400">六</span>
  </div>

  <div class="grid grid-cols-7 gap-1">
    {calendarDays.map(day => {
      if (day === null) {
        return <div></div>;
      }
      const dateStr = `${year}-${String(month + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
      const hasPost = postDates.includes(dateStr);
      const isToday = dateStr === now.toISOString().split('T')[0];
      return (
        <div class={`aspect-square flex items-center justify-center rounded-full text-xs ${
          hasPost
            ? 'bg-primary text-primary font-medium'
            : isToday
              ? 'ring-1 ring-primary text-primary'
              : 'text-slate-400 dark:text-slate-500'
        }`}>
          {day}
        </div>
      );
    })}
  </div>
</div>