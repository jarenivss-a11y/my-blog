---
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const publishedPosts = allPosts.filter(p => !p.data.draft);

const postDates = publishedPosts.map(p => p.data.published.toISOString().split('T')[0]);

const now = new Date();
const year = now.getFullYear();
const month = now.getMonth();

const firstDay = new Date(year, month, 1).getDay();
const daysInMonth = new Date(year, month + 1, 0).getDate();

const calendarDays: (number | null)[] = [];
for (let i = 0; i < firstDay; i++) {
  calendarDays.push(null);
}
for (let i = 1; i <= daysInMonth; i++) {
  calendarDays.push(i);
}

const monthNames = ['一月', '二月', '三月', '四月', '五月', '六月', '七月', '八月', '九月', '十月', '十一月', '十二月'];
---

<div class="p-5 rounded-2xl border border-gray-100 bg-white shadow-sm">
  <div class="flex items-center justify-between mb-4">
    <h4 class="text-xs font-medium text-gray-500 uppercase tracking-widest">{year}年 {monthNames[month]}</h4>
    <span class="text-xs text-gray-400">{publishedPosts.length} 篇文章</span>
  </div>

  <div class="grid grid-cols-7 gap-1 text-center mb-2">
    <span class="text-xs text-gray-400">日</span>
    <span class="text-xs text-gray-400">一</span>
    <span class="text-xs text-gray-400">二</span>
    <span class="text-xs text-gray-400">三</span>
    <span class="text-xs text-gray-400">四</span>
    <span class="text-xs text-gray-400">五</span>
    <span class="text-xs text-gray-400">六</span>
  </div>

  <div class="grid grid-cols-7 gap-1">
    {calendarDays.map(day => {
      if (day === null) {
        return <div></div>;
      }
      const dateStr = `${year}-${String(month + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
      const hasPost = postDates.includes(dateStr);
      const isToday = dateStr === now.toISOString().split('T')[0];
      return (
        <div class={`group aspect-square flex items-center justify-center rounded-full text-xs transition-all duration-200 ${
          hasPost
            ? 'bg-cyan-100 text-cyan-600 font-medium hover:bg-cyan-200'
            : isToday
              ? 'ring-1 ring-cyan-300 text-cyan-600 hover:ring-2 hover:ring-cyan-400'
              : 'text-gray-400 hover:text-gray-600'
        }`}>
          {day}
        </div>
      );
    })}
  </div>
</div>