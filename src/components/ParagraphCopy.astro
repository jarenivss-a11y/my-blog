---
// Paragraph Copy - adds copy button to paragraphs
---

<script>
  function initParagraphCopy() {
    const article = document.querySelector('article');
    if (!article) return;

    const copyBtnHTML = `
      <button class="para-copy-btn absolute -right-10 top-0 p-1.5 rounded opacity-0 group-hover:opacity-100 bg-[rgba(80,128,176,0.15)] hover:bg-[rgba(80,128,176,0.3)] hover:text-white text-[#72a8d8] transition-all" title="复制段落">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
        </svg>
      </button>
    `;

    article.querySelectorAll('p, li, blockquote').forEach((el) => {
      if (el.querySelector('.para-copy-btn')) return;

      el.classList.add('relative', 'group');
      const wrapper = document.createElement('div');
      wrapper.className = 'para-copy-wrapper absolute -right-10 top-0';
      wrapper.innerHTML = copyBtnHTML;
      el.appendChild(wrapper);

      const btn = el.querySelector('.para-copy-btn');
      btn?.addEventListener('click', async (e) => {
        e.stopPropagation();
        const text = el.textContent?.trim() || '';
        try {
          await navigator.clipboard.writeText(text);
          const btnEl = e.target as HTMLElement;
          const originalHTML = btnEl.innerHTML;
          btnEl.innerHTML = `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>`;
          btnEl.classList.add('text-[#72a8d8]');
          setTimeout(() => {
            btnEl.innerHTML = originalHTML;
            btnEl.classList.remove('text-[#72a8d8]');
          }, 1500);
        } catch (err) {
          console.error('复制失败:', err);
        }
      });
    });
  }

  initParagraphCopy();
  document.addEventListener('astro:after-swap', initParagraphCopy);
</script>

<style>
  .para-copy-wrapper {
    min-width: 24px;
  }
</style>
