---
interface Props {
  items: Array<{ name: string; href?: string }>;
}

const { items } = Astro.props;

const siteUrl = "https://jarenivss-a11y.github.io/my-blog";

// Build breadcrumb items for JSON-LD
const breadcrumbItems = [
  { "@type": "ListItem", "position": 1, "name": "首页", "item": siteUrl },
  ...items.map((item, index) => ({
    "@type": "ListItem",
    "position": index + 2,
    "name": item.name,
    "item": item.href ? `${siteUrl}${item.href}` : undefined
  }))
].filter(item => item["@type"]);
---

<nav aria-label="面包屑导航" class="mb-6">
  <ol class="flex items-center gap-2 text-sm text-[#8a9cc4]" itemscope itemtype="https://schema.org/BreadcrumbList">
    <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
      <a href="/my-blog/" class="hover:text-[#72a8d8] transition-colors" itemprop="item">
        <span itemprop="name">首页</span>
      </a>
      <meta itemprop="position" content="1" />
    </li>
    {items.map((item, index) => (
      <li class="text-[rgba(80,128,176,0.4)]">/</li>
    ))}
    {items.map((item, index) => (
      <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        {item.href ? (
          <a href={item.href} class="hover:text-[#72a8d8] transition-colors" itemprop="item">
            <span itemprop="name">{item.name}</span>
          </a>
        ) : (
          <span class="text-[#e2e9f5]" itemprop="item">
            <span itemprop="name">{item.name}</span>
          </span>
        )}
        <meta itemprop="position" content={String(index + 2)} />
      </li>
    ))}
  </ol>
</nav>

<!-- BreadcrumbList JSON-LD -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbItems
})} />