---
// InternalBeyond Background Integration
// Embeds InternalBeyond as background with blog content overlaid
---

<div id="ib-background-wrapper" class="fixed inset-0 z-0 overflow-hidden">
  <!-- InternalBeyond iframe as background -->
  <iframe
    id="ib-frame"
    src="/ib/InternalBeyond.html"
    class="w-full h-full border-0"
    allow="autoplay"
    sandbox="allow-scripts allow-same-origin allow-forms"
  ></iframe>

  <!-- Overlay to ensure blog content is readable -->
  <div id="ib-content-overlay" class="absolute inset-0 bg-[rgba(24,30,50,0.82)]"></div>
</div>

<style>
  #ib-background-wrapper {
    position: fixed;
    inset: 0;
    z-index: 0;
  }

  #ib-frame {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  #ib-content-overlay {
    pointer-events: none;
    backdrop-filter: blur(2px);
  }
</style>
