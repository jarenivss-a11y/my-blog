---
// Table of Contents - extracts headings from content
interface Props {
  headings: { depth: number; slug: string; text: string }[];
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);
---

{filteredHeadings.length > 2 && (
  <>
    <!-- Mobile Toggle Button -->
    <button
      id="toc-toggle"
      class="lg:hidden fixed right-4 bottom-24 z-40 p-3 rounded-full backdrop-blur-xl bg-[rgba(155,180,218,0.1)] border border-[rgba(80,128,176,0.3)] shadow-lg hover:shadow-[0_8px 32px_rgba(80,128,176,0.3)] transition-all"
      aria-label="切换目录"
    >
      <svg class="w-5 h-5 text-[#72a8d8]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7"/>
      </svg>
    </button>

    <!-- TOC Panel -->
    <nav id="toc" class="hidden lg:block fixed right-8 top-32 w-64 z-30">
      <div class="p-4 rounded-2xl backdrop-blur-xl bg-[rgba(155,180,218,0.05)] border border-[rgba(165,188,230,0.12)]">
        <div class="flex items-center justify-between mb-4">
          <h4 class="text-xs font-medium text-[#8a9cc4] uppercase tracking-widest">目录</h4>
          <button id="toc-close" class="lg:hidden text-[#8a9cc4] hover:text-[#72a8d8]">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
        <ul class="space-y-2">
          {filteredHeadings.map((heading) => (
            <li class={heading.depth === 3 ? 'pl-3' : ''}>
              <a
                href={`#${heading.slug}`}
                class="group flex items-center gap-2 text-sm text-[#8a9cc4] hover:text-[#72a8d8] transition-colors line-clamp-2 toc-link"
                data-slug={heading.slug}
              >
                <span class="flex-1">{heading.text}</span>
                <svg class="w-4 h-4 opacity-0 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
                </svg>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </nav>

    <!-- Mobile Overlay -->
    <div id="toc-overlay" class="hidden fixed inset-0 bg-black/30 z-20 lg:hidden"></div>
  </>
)}

<script>
  function initTOC() {
    const toc = document.getElementById('toc');
    const toggle = document.getElementById('toc-toggle');
    const close = document.getElementById('toc-close');
    const overlay = document.getElementById('toc-overlay');

    if (toggle && toc) {
      toggle.addEventListener('click', () => {
        toc.classList.remove('hidden');
        overlay?.classList.remove('hidden');
      });
    }

    if (close && toc) {
      close.addEventListener('click', () => {
        toc.classList.add('hidden');
        overlay?.classList.add('hidden');
      });
    }

    if (overlay) {
      overlay.addEventListener('click', () => {
        toc?.classList.add('hidden');
        overlay.classList.add('hidden');
      });
    }

    const tocLinks = document.querySelectorAll('.toc-link');
    if (!tocLinks.length) return;

    const headingElements = Array.from(tocLinks).map(link => {
      const slug = link.getAttribute('data-slug');
      return slug ? document.getElementById(slug) : null;
    }).filter(Boolean) as HTMLElement[];

    const updateActiveLink = () => {
      const scrollY = window.scrollY + 100;

      let currentId = '';
      let maxProgress = 0;
      headingElements.forEach(heading => {
        const progress = Math.min(100, ((scrollY - heading.offsetTop + 100) / heading.offsetTop) * 100);
        if (heading.offsetTop <= scrollY && progress > maxProgress) {
          currentId = heading.id;
          maxProgress = progress;
        }
      });

      tocLinks.forEach(link => {
        const slug = link.getAttribute('data-slug');
        if (slug === currentId) {
          link.classList.add('text-[#72a8d8]', 'font-medium');
          link.classList.remove('text-[#8a9cc4]');
        } else {
          link.classList.remove('text-[#72a8d8]', 'font-medium');
          link.classList.add('text-[#8a9cc4]');
        }
      });
    };

    window.addEventListener('scroll', updateActiveLink, { passive: true });
    updateActiveLink();
  }

  initTOC();
  document.addEventListener('astro:after-swap', initTOC);
</script>