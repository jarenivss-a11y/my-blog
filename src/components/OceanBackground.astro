---
// OceanBackground - Realistic interactive ocean wave background
---

<div id="ocean-container" class="fixed inset-0 w-full h-full pointer-events-none z-0 overflow-hidden">
  <canvas id="ocean-canvas"></canvas>
</div>

<style>
  #ocean-container {
    background: linear-gradient(180deg, #1a3a5c 0%, #2d5a7b 30%, #4a8db7 60%, #6bb3d9 100%);
  }
</style>

<script>
  function initOceanBackground() {
    const canvas = document.getElementById('ocean-canvas') as HTMLCanvasElement;
    if (!canvas) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let width = window.innerWidth;
    let height = window.innerHeight;
    canvas.width = width;
    canvas.height = height;

    let mouseX = width / 2;
    let mouseY = height / 2;
    let mouseInfluence = 0;

    document.addEventListener('mousemove', (e) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
      mouseInfluence = 1;
    });

    const waves: any[] = [];
    const WAVE_COUNT = 8;

    for (let i = 0; i < WAVE_COUNT; i++) {
      waves.push({
        y: height * (0.5 + i * 0.06),
        amplitude: 15 + Math.random() * 25,
        frequency: 0.01 + i * 0.002,
        speed: 0.02 + i * 0.005,
        phase: Math.random() * Math.PI * 2,
        thickness: 2 + Math.random() * 3
      });
    }

    const particles: any[] = [];
    const PARTICLE_COUNT = 60;

    for (let i = 0; i < PARTICLE_COUNT; i++) {
      particles.push({
        x: Math.random() * width,
        y: height * 0.4 + Math.random() * height * 0.5,
        size: 1 + Math.random() * 3,
        speedX: 0.2 + Math.random() * 0.5,
        opacity: 0.2 + Math.random() * 0.4
      });
    }

    let time = 0;

    function drawOcean() {
      const skyGradient = ctx.createLinearGradient(0, 0, 0, height);
      skyGradient.addColorStop(0, '#1a3a5c');
      skyGradient.addColorStop(0.3, '#2d5a7b');
      skyGradient.addColorStop(0.6, '#4a8db7');
      skyGradient.addColorStop(1, '#1a5276');
      ctx.fillStyle = skyGradient;
      ctx.fillRect(0, 0, width, height);

      if (mouseInfluence > 0) {
        mouseInfluence *= 0.98;
      }

      waves.forEach((wave, index) => {
        ctx.beginPath();
        ctx.moveTo(0, height);

        for (let x = 0; x <= width; x += 5) {
          let y = wave.y;
          y += Math.sin(x * wave.frequency + time * wave.speed + wave.phase) * wave.amplitude;
          y += Math.sin(x * wave.frequency * 0.5 + time * wave.speed * 1.5) * wave.amplitude * 0.5;

          const dx = x - mouseX;
          const dy = y - mouseY;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < 200 && mouseInfluence > 0.01) {
            const influence = (1 - dist / 200) * mouseInfluence * 30;
            y += Math.sin(dist * 0.05 - time * 0.1) * influence;
          }

          ctx.lineTo(x, y);
        }

        ctx.lineTo(width, height);
        ctx.closePath();

        const alpha = 0.15 + index * 0.05;
        const waveGrad = ctx.createLinearGradient(0, wave.y - wave.amplitude, 0, height);
        waveGrad.addColorStop(0, `rgba(100, 180, 220, ${alpha * 0.5})`);
        waveGrad.addColorStop(0.3, `rgba(60, 140, 190, ${alpha})`);
        waveGrad.addColorStop(1, `rgba(20, 60, 100, ${alpha + 0.1})`);

        ctx.fillStyle = waveGrad;
        ctx.fill();

        ctx.beginPath();
        for (let x = 0; x <= width; x += 5) {
          let y = wave.y;
          y += Math.sin(x * wave.frequency + time * wave.speed + wave.phase) * wave.amplitude;
          y += Math.sin(x * wave.frequency * 0.5 + time * wave.speed * 1.5) * wave.amplitude * 0.5;

          const dx = x - mouseX;
          const dy = y - mouseY;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < 200 && mouseInfluence > 0.01) {
            const influence = (1 - dist / 200) * mouseInfluence * 30;
            y += Math.sin(dist * 0.05 - time * 0.1) * influence;
          }

          if (x === 0) ctx.moveTo(x, y);
          else ctx.lineTo(x, y);
        }
        ctx.strokeStyle = `rgba(150, 210, 240, ${0.2 + index * 0.03})`;
        ctx.lineWidth = wave.thickness;
        ctx.stroke();
      });

      particles.forEach(p => {
        p.x += p.speedX;
        p.y += Math.sin(time * 0.02 + p.x * 0.01) * 0.3;

        if (p.x > width + 10) {
          p.x = -10;
          p.y = height * 0.4 + Math.random() * height * 0.5;
        }

        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(255, 255, 255, ${p.opacity * (0.5 + Math.sin(time * 0.05 + p.x * 0.1) * 0.3)})`;
        ctx.fill();
      });

      const horizonGrad = ctx.createRadialGradient(width / 2, height * 0.7, 0, width / 2, height * 0.7, width * 0.6);
      horizonGrad.addColorStop(0, 'rgba(255, 200, 150, 0.1)');
      horizonGrad.addColorStop(0.5, 'rgba(100, 180, 220, 0.05)');
      horizonGrad.addColorStop(1, 'transparent');
      ctx.fillStyle = horizonGrad;
      ctx.fillRect(0, 0, width, height);

      time += 1;
      requestAnimationFrame(drawOcean);
    }

    function handleResize() {
      width = window.innerWidth;
      height = window.innerHeight;
      canvas.width = width;
      canvas.height = height;
    }

    window.addEventListener('resize', handleResize);
    drawOcean();
  }

  initOceanBackground();
  document.addEventListener('astro:after-swap', initOceanBackground);
</script>
