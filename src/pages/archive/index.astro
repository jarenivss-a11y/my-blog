---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const BASE = '/my-blog';

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.published.getTime() - a.data.published.getTime());

// Group posts by year and month
const archive: Record<string, Record<string, typeof posts>> = {};
posts.forEach(post => {
  const year = post.data.published.getFullYear().toString();
  const month = (post.data.published.getMonth() + 1).toString().padStart(2, '0');
  if (!archive[year]) archive[year] = {};
  if (!archive[year][month]) archive[year][month] = [];
  archive[year][month].push(post);
});

const categoryInfo: Record<string, { name: string }> = {
  daily: { name: '日常生活' },
  music: { name: '音乐分析' },
  books: { name: '读书鉴赏' },
  ecommerce: { name: '电商运营' },
  pokemon: { name: '宝可梦' },
};

const monthNames = ['一月', '二月', '三月', '四月', '五月', '六月', '七月', '八月', '九月', '十月', '十一月', '十二月'];
---

<Layout title="归档 | 我的博客">
  <!-- Header -->
  <header class="mb-12 p-8 rounded-3xl backdrop-blur-xl bg-gradient-to-br from-white/80 to-slate-100/80 dark:from-slate-800/80 dark:to-slate-900/80 border border-white/50 dark:border-slate-700/50">
    <h1 class="text-3xl font-serif font-black text-slate-900 dark:text-white mb-2">文章归档</h1>
    <p class="text-slate-500 dark:text-slate-400">共 {posts.length} 篇文章</p>
  </header>

  <!-- Archive List -->
  <div class="space-y-12">
    {Object.entries(archive)
      .sort(([a], [b]) => Number(b) - Number(a))
      .map(([year, months]) => (
        <section>
          <h2 class="text-2xl font-serif font-bold text-slate-900 dark:text-white mb-6 flex items-center gap-4">
            <span>{year}</span>
            <span class="text-sm font-normal text-slate-400">{Object.values(months).flat().length} 篇</span>
          </h2>
          <div class="space-y-8 pl-4 border-l-2 border-primary">
            {Object.entries(months)
              .sort(([a], [b]) => Number(b) - Number(a))
              .map(([month, monthPosts]) => (
                <div>
                  <h3 class="text-lg font-medium text-slate-700 dark:text-slate-200 mb-4">
                    {monthNames[parseInt(month) - 1]}
                  </h3>
                  <div class="space-y-3">
                    {monthPosts.map((post) => (
                      <a
                        href={`${BASE}/post/${post.id}`}
                        class="group flex items-center gap-4 p-4 rounded-xl backdrop-blur-xl bg-white/50 dark:bg-slate-800/50 border border-white/50 dark:border-slate-700/50 hover:bg-white/70 dark:hover:bg-slate-800/70 hover:border-primary transition-all"
                      >
                        <span class="text-sm text-slate-400 w-16 flex-shrink-0">
                          {post.data.published.toLocaleDateString('zh-CN', { month: '2-digit', day: '2-digit' })}
                        </span>
                        <span class="flex-1 text-slate-800 dark:text-slate-100 group-hover:text-primary transition-colors line-clamp-1">
                          {post.data.title}
                        </span>
                        <span class="text-xs px-2 py-0.5 rounded-full bg-primary text-primary flex-shrink-0">
                          {categoryInfo[post.data.category]?.name || '未知'}
                        </span>
                      </a>
                    ))}
                  </div>
                </div>
              ))}
          </div>
        </section>
      ))}
  </div>
</Layout>