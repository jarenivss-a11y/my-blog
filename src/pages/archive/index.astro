---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const BASE = '/my-blog';

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.published.getTime() - a.data.published.getTime());

// Group posts by year and month
const archive: Record<string, Record<string, typeof posts>> = {};
posts.forEach(post => {
  const year = post.data.published.getFullYear().toString();
  const month = (post.data.published.getMonth() + 1).toString().padStart(2, '0');
  if (!archive[year]) archive[year] = {};
  if (!archive[year][month]) archive[year][month] = [];
  archive[year][month].push(post);
});

const categoryInfo: Record<string, { name: string }> = {
  daily: { name: '日常生活' },
  music: { name: '音乐分析' },
  books: { name: '读书鉴赏' },
  ecommerce: { name: '电商运营' },
  pokemon: { name: '宝可梦' },
};

const monthNames = ['一月', '二月', '三月', '四月', '五月', '六月', '七月', '八月', '九月', '十月', '十一月', '十二月'];
---

<Layout title="归档 | 我的博客">
  <!-- Header -->
  <header class="mb-12 p-10 rounded-3xl backdrop-blur-xl bg-[rgba(155,180,218,0.06)] border border-[rgba(165,188,230,0.15)] shadow-[0_8px_32px_rgba(0,0,0,0.15)] relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[rgba(80,128,176,0.08)] via-transparent to-[rgba(114,168,216,0.05)] pointer-events-none"></div>
    <div class="absolute -top-10 -right-10 w-32 h-32 rounded-full bg-[rgba(80,128,176,0.1)] blur-2xl"></div>
    <h1 class="text-3xl font-serif font-black text-[#e2e9f5] mb-2 relative z-10">文章归档</h1>
    <p class="text-[#8a9cc4] relative z-10">共 {posts.length} 篇文章</p>
  </header>

  <!-- Archive List -->
  <div class="space-y-12">
    {Object.entries(archive)
      .sort(([a], [b]) => Number(b) - Number(a))
      .map(([year, months]) => (
        <section>
          <h2 class="text-2xl font-serif font-bold text-[#e2e9f5] mb-6 flex items-center gap-4">
            <span>{year}</span>
            <span class="text-sm font-normal text-[#8a9cc4]">{Object.values(months).flat().length} 篇</span>
          </h2>
          <div class="space-y-8 pl-4 border-l-2 border-[rgba(80,128,176,0.4)]">
            {Object.entries(months)
              .sort(([a], [b]) => Number(b) - Number(a))
              .map(([month, monthPosts]) => (
                <div>
                  <h3 class="text-lg font-medium text-[#b2c0d8] mb-4">
                    {monthNames[parseInt(month) - 1]}
                  </h3>
                  <div class="space-y-3">
                    {monthPosts.map((post) => (
                      <a
                        href={`${BASE}/post/${post.id}`}
                        class="group flex items-center gap-4 p-4 rounded-xl backdrop-blur-xl bg-[rgba(155,180,218,0.04)] border border-[rgba(165,188,230,0.12)] hover:bg-[rgba(155,180,218,0.08)] hover:border-[rgba(80,128,176,0.3)] hover:shadow-[0_4px_20px_rgba(80,128,176,0.15)] transition-all duration-300"
                      >
                        <span class="text-sm text-[#7a8cb4] w-16 flex-shrink-0">
                          {post.data.published.toLocaleDateString('zh-CN', { month: '2-digit', day: '2-digit' })}
                        </span>
                        <span class="flex-1 text-[#b2c0d8] group-hover:text-[#8ac4e8] transition-colors line-clamp-1">
                          {post.data.title}
                        </span>
                        <span class="text-xs px-2 py-0.5 rounded-full bg-[rgba(80,128,176,0.15)] border border-[rgba(80,128,176,0.2)] text-[#72a8d8] flex-shrink-0">
                          {categoryInfo[post.data.category]?.name || '未知'}
                        </span>
                      </a>
                    ))}
                  </div>
                </div>
              ))}
          </div>
        </section>
      ))}
  </div>
</Layout>