---
import Layout from '../layouts/Layout.astro';

const BASE = '/my-blog';

// 友链数据 - 可以后续扩展
const friends = [
  {
    name: 'XHBlogs',
    description: '一个高颜值的毛玻璃风格个人博客系统',
    url: 'https://github.com/heiehiehi/XinghuisamaBlogs',
    avatar: 'X',
  },
];
---

<Layout title="友链 | 我的博客">
  <!-- Header -->
  <header class="mb-12 p-10 rounded-3xl backdrop-blur-xl bg-[rgba(155,180,218,0.06)] border border-[rgba(165,188,230,0.15)] shadow-[0_8px_32px_rgba(0,0,0,0.15)] relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[rgba(80,128,176,0.08)] via-transparent to-[rgba(114,168,216,0.05)] pointer-events-none"></div>
    <div class="absolute -top-10 -right-10 w-32 h-32 rounded-full bg-[rgba(80,128,176,0.1)] blur-2xl"></div>
    <h1 class="text-3xl font-serif font-black text-[#e2e9f5] mb-2 relative z-10">友链</h1>
    <p class="text-[#8a9cc4] relative z-10">交换链接，携手前行</p>
  </header>

  <!-- Friends Grid -->
  <section class="mb-12">
    <h2 class="text-xs font-medium text-[#8a9cc4] uppercase tracking-widest mb-6">我的朋友们</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {friends.map((friend) => (
        <a
          href={friend.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group p-6 rounded-2xl backdrop-blur-xl bg-[rgba(155,180,218,0.05)] border border-[rgba(165,188,230,0.12)] hover:bg-[rgba(155,180,218,0.1)] hover:border-[rgba(80,128,176,0.3)] hover:shadow-[0_8px_32px_rgba(80,128,176,0.2)] transition-all duration-300"
        >
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-full bg-gradient-to-br from-[#5080b0] to-[#72a8d8] flex items-center justify-center text-xl font-serif text-white flex-shrink-0 shadow-[0_4px_12px_rgba(80,128,176,0.3)]">
              {friend.avatar}
            </div>
            <div>
              <h3 class="font-medium text-[#e2e9f5] group-hover:text-[#72a8d8] transition-colors mb-1">
                {friend.name}
              </h3>
              <p class="text-sm text-[#8a9cc4] line-clamp-2">
                {friend.description}
              </p>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Apply Section -->
  <section class="p-8 rounded-3xl backdrop-blur-xl bg-[rgba(155,180,218,0.05)] border border-[rgba(165,188,230,0.12)]">
    <h2 class="text-lg font-serif font-bold text-[#e2e9f5] mb-4">申请友链</h2>
    <p class="text-[#8a9cc4] mb-6">
      如果你想和我交换友链，欢迎通过以下方式联系我：
    </p>
    <div class="space-y-3 text-sm">
      <div class="flex items-center gap-3">
        <span class="text-[#7a8cb4]">博客名称：</span>
        <span class="text-[#b2c0d8]">我的博客</span>
      </div>
      <div class="flex items-center gap-3">
        <span class="text-[#7a8cb4]">博客地址：</span>
        <span class="text-[#72a8d8]">https://jarenivss-a11y.github.io/my-blog/</span>
      </div>
    </div>
    <p class="text-xs text-[#7a8cb4] mt-6">
      * 请确保你的博客内容健康、至少有一篇原创文章，且网站可以正常访问
    </p>
  </section>
</Layout>