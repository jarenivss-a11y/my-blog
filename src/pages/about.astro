---
import Layout from '../layouts/Layout.astro';

const BASE = '/my-blog';

const categories = [
  { name: '日常生活', slug: 'daily', icon: '🏠' },
  { name: '音乐分析', slug: 'music', icon: '🎵' },
  { name: '读书鉴赏', slug: 'books', icon: '📚' },
  { name: '电商运营', slug: 'ecommerce', icon: '🛒' },
  { name: '宝可梦', slug: 'pokemon', icon: '⚡' },
];
---

<Layout title="关于我 | 我的博客">
  <div class="max-w-3xl mx-auto">
    <!-- Avatar Card -->
    <div class="mb-12 p-8 rounded-3xl backdrop-blur-xl bg-gradient-to-br from-white/80 to-slate-100/80 dark:from-slate-800/80 dark:to-slate-900/80 border border-white/50 dark:border-slate-700/50 text-center">
      <div class="w-24 h-24 mx-auto mb-6 rounded-full bg-gradient-to-br from-primary/20 to-primary/40 flex items-center justify-center text-4xl font-serif text-primary backdrop-blur-xl">
        M
      </div>
      <h1 class="text-3xl font-serif font-black text-slate-900 dark:text-white mb-2">关于我</h1>
      <p class="text-slate-500 dark:text-slate-400">一个对生活充满好奇的人</p>
    </div>

    <!-- Introduction -->
    <section class="mb-12 p-8 rounded-3xl backdrop-blur-xl bg-white/70 dark:bg-slate-800/50 border border-white/50 dark:border-slate-700/50">
      <h2 class="text-lg font-serif font-bold text-slate-900 dark:text-white mb-4">介绍</h2>
      <p class="text-slate-600 dark:text-slate-300 leading-relaxed mb-4">
        你好！我是一个对生活充满好奇的人，喜欢探索各种有趣的事物。这个博客用于记录我的思考和分享我的兴趣爱好。
      </p>
      <p class="text-slate-600 dark:text-slate-300 leading-relaxed">
        我对电商运营充满热情，同时也热爱音乐、阅读和宝可梦。希望能在这里与你分享我的见解和心得。
      </p>
    </section>

    <!-- Categories -->
    <section class="p-8 rounded-3xl backdrop-blur-xl bg-white/70 dark:bg-slate-800/50 border border-white/50 dark:border-slate-700/50">
      <h2 class="text-lg font-serif font-bold text-slate-900 dark:text-white mb-6">兴趣分类</h2>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
        {categories.map((cat) => (
          <a
            href={`${BASE}/category/${cat.slug}`}
            class="group flex flex-col items-center gap-2 p-4 rounded-2xl backdrop-blur-xl bg-white/50 dark:bg-slate-700/50 border border-white/50 dark:border-slate-600/50 hover:bg-primary/10 hover:border-primary/30 dark:hover:border-primary/50 transition-all duration-300 text-center"
          >
            <span class="text-2xl">{cat.icon}</span>
            <span class="text-sm font-medium text-slate-700 dark:text-slate-200 group-hover:text-primary transition-colors">{cat.name}</span>
          </a>
        ))}
      </div>
    </section>
  </div>
</Layout>