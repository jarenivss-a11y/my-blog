---
import Layout from '../layouts/Layout.astro';
---

<Layout title="关于我 | 我的博客">
  <div class="p-8 max-w-2xl">
    <h1 class="text-3xl font-bold text-gray-900 mb-6">关于我</h1>

    <div class="bg-white rounded-xl border border-gray-200 p-8">
      <p class="text-gray-700 mb-4">
        你好！我是一个对生活充满好奇的人，喜欢探索各种有趣的事物。
      </p>
      <p class="text-gray-700 mb-4">
        这个博客用于记录我的思考和分享我的兴趣爱好。
      </p>

      <h2 class="text-xl font-bold text-gray-900 mt-8 mb-4">我的兴趣</h2>
      <ul class="space-y-2">
        <li class="flex items-center gap-2">
          <span>🏠</span>
          <a href="/category/daily" class="text-indigo-600 hover:underline">日常生活</a>
        </li>
        <li class="flex items-center gap-2">
          <span>🎵</span>
          <a href="/category/music" class="text-indigo-600 hover:underline">音乐分析</a>
        </li>
        <li class="flex items-center gap-2">
          <span>📚</span>
          <a href="/category/books" class="text-indigo-600 hover:underline">读书鉴赏</a>
        </li>
        <li class="flex items-center gap-2">
          <span>🛒</span>
          <a href="/category/ecommerce" class="text-indigo-600 hover:underline">电商运营</a>
        </li>
        <li class="flex items-center gap-2">
          <span>⚡</span>
          <a href="/category/pokemon" class="text-indigo-600 hover:underline">宝可梦</a>
        </li>
      </ul>
    </div>
  </div>
</Layout>