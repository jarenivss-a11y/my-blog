---
import Layout from '../layouts/Layout.astro';

const BASE = '/my-blog';

const categories = [
  { name: '日常生活', slug: 'daily', icon: '🏠' },
  { name: '音乐分析', slug: 'music', icon: '🎵' },
  { name: '读书鉴赏', slug: 'books', icon: '📚' },
  { name: '电商运营', slug: 'ecommerce', icon: '🛒' },
  { name: '宝可梦', slug: 'pokemon', icon: '⚡' },
];
---

<Layout title="关于我 | 我的博客">
  <div class="mb-12">
    <!-- Avatar -->
    <div class="w-20 h-20 mb-6 rounded-full bg-gray-100 flex items-center justify-center text-3xl font-serif text-gray-400">
      M
    </div>

    <h1 class="text-3xl font-serif font-semibold text-gray-900 mb-2">关于我</h1>
    <p class="text-gray-500">一个对生活充满好奇的人</p>
  </div>

  <div class="space-y-12">
    <section>
      <h2 class="text-lg font-medium text-gray-900 mb-4">介绍</h2>
      <p class="text-gray-600 leading-relaxed mb-4">
        你好！我是一个对生活充满好奇的人，喜欢探索各种有趣的事物。这个博客用于记录我的思考和分享我的兴趣爱好。
      </p>
      <p class="text-gray-600 leading-relaxed">
        我对电商运营充满热情，同时也热爱音乐、阅读和宝可梦。希望能在这里与你分享我的见解和心得。
      </p>
    </section>

    <section>
      <h2 class="text-lg font-medium text-gray-900 mb-6">兴趣分类</h2>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-3">
        {categories.map((cat) => (
          <a
            href={`${BASE}/category/${cat.slug}`}
            class="flex flex-col items-center gap-2 p-4 rounded-xl border border-gray-200 hover:border-gray-400 hover:bg-gray-50 transition-all duration-200 text-center"
          >
            <span class="text-2xl">{cat.icon}</span>
            <span class="text-sm font-medium text-gray-700">{cat.name}</span>
          </a>
        ))}
      </div>
    </section>
  </div>
</Layout>