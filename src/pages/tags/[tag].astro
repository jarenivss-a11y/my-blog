---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const BASE = '/my-blog';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');

  // Collect all unique tags
  const allTags = [...new Set(allPosts.flatMap(post => post.data.tags || []))];

  return allTags.map(tag => ({
    params: { tag },
    props: { tag }
  }));
}

const { tag } = Astro.props;

// Get all posts
const allPosts = await getCollection('blog');

// Filter posts by tag
const taggedPosts = allPosts
  .filter(post => post.data.tags && post.data.tags.includes(tag as string))
  .sort((a, b) => b.data.published.getTime() - a.data.published.getTime());

const categoryInfo: Record<string, { name: string }> = {
  daily: { name: '日常生活' },
  music: { name: '音乐分析' },
  books: { name: '读书鉴赏' },
  ecommerce: { name: '电商运营' },
  pokemon: { name: '宝可梦' },
};
---

<Layout title={`#${tag} | 我的博客`}>
  <!-- Header -->
  <header class="mb-12 p-8 rounded-3xl backdrop-blur-xl bg-[rgba(155,180,218,0.1)] border border-[rgba(80,128,176,0.3)]">
    <a href={`${BASE}/tags`} class="text-sm text-[#8ac4e8] hover:text-[#72a8d8] transition-colors mb-2 inline-block">← 返回标签</a>
    <h1 class="text-3xl font-serif font-black text-[#5080b0] mb-2">#{tag}</h1>
    <p class="text-[#8ac4e8]">共 {taggedPosts.length} 篇文章</p>
  </header>

  <!-- Posts -->
  <div class="space-y-4">
    {taggedPosts.length > 0 ? (
      taggedPosts.map((post) => (
        <article class="group">
          <a
            href={`${BASE}/post/${post.id}`}
            class="block p-6 rounded-2xl backdrop-blur-xl bg-[rgba(155,180,218,0.08)] border border-[rgba(80,128,176,0.2)] hover:bg-[rgba(80,128,176,0.15)] hover:border-[#72a8d8] hover:shadow-lg transition-all duration-300"
          >
            <div class="flex items-center gap-3 mb-3">
              <span class="text-xs text-[#8ac4e8]">{post.data.published.toLocaleDateString('zh-CN')}</span>
              <span class="px-2 py-0.5 text-xs bg-[rgba(80,128,176,0.2)] text-[#72a8d8] rounded-full">
                {categoryInfo[post.data.category]?.name || '未知'}
              </span>
            </div>
            <h3 class="text-lg font-serif font-semibold text-[#5080b0] group-hover:text-[#72a8d8] transition-colors mb-2">
              {post.data.title}
            </h3>
            <p class="text-sm text-[#8ac4e8] line-clamp-2">{post.body.slice(0, 150)}...</p>
          </a>
        </article>
      ))
    ) : (
      <div class="text-center py-16">
        <p class="text-[#8ac4e8]">暂无文章</p>
      </div>
    )}
  </div>
</Layout>