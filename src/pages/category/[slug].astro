---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const BASE = '/my-blog';

export function getStaticPaths() {
  return [
    { params: { slug: 'daily' } },
    { params: { slug: 'music' } },
    { params: { slug: 'books' } },
    { params: { slug: 'ecommerce' } },
    { params: { slug: 'pokemon' } },
  ];
}

const { slug } = Astro.params;

const categoryInfo: Record<string, { name: string; icon: string; description: string; color: string }> = {
  daily: { name: '日常生活', icon: '🏠', description: '记录生活的点滴', color: 'from-rose-500 to-pink-500' },
  music: { name: '音乐分析', icon: '🎵', description: '分享音乐心得', color: 'from-violet-500 to-purple-500' },
  books: { name: '读书鉴赏', icon: '📚', description: '读书笔记与感悟', color: 'from-amber-500 to-orange-500' },
  ecommerce: { name: '电商运营', icon: '🛒', description: '电商运营知识与实践', color: 'from-emerald-500 to-teal-500' },
  pokemon: { name: '宝可梦', icon: '⚡', description: '宝可梦相关内容', color: 'from-blue-500 to-cyan-500' },
};

const info = categoryInfo[slug as string] || { name: '未知', icon: '📁', description: '', color: 'from-slate-500 to-gray-500' };
const allPosts = await getCollection('blog');
const posts = allPosts.filter(post => post.data.category === slug).sort((a, b) => b.data.published.getTime() - a.data.published.getTime());
---

<Layout title={`${info.name} | 我的博客`}>
  <!-- Header -->
  <div class="mb-12 text-center py-8">
    <div class={`inline-flex items-center justify-center w-20 h-20 rounded-2xl bg-gradient-to-br ${info.color} text-white text-4xl mb-6 shadow-lg`}>
      {info.icon}
    </div>
    <h1 class="text-4xl font-bold text-slate-800 mb-3">{info.name}</h1>
    <p class="text-lg text-slate-500">{info.description}</p>
    <div class="mt-4 text-sm text-slate-400">{posts.length} 篇文章</div>
  </div>

  <!-- Posts -->
  <div class="grid gap-6">
    {posts.length > 0 ? (
      posts.map((post) => (
        <article class="group bg-white rounded-2xl border border-slate-200/50 p-8 hover:border-indigo-200 hover:shadow-xl hover:shadow-indigo-500/10 transition-all duration-300">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <div class="text-sm text-slate-400 mb-3">{post.data.published.toLocaleDateString('zh-CN')}</div>
              <h2 class="text-2xl font-bold text-slate-800 mb-3 group-hover:text-indigo-600 transition-colors">
                <a href={`${BASE}/post/${post.id}`}>{post.data.title}</a>
              </h2>
              <p class="text-slate-600 line-clamp-3 mb-4">{post.body.slice(0, 200)}...</p>
              {post.data.tags && (
                <div class="flex gap-2">
                  {post.data.tags.map((tag) => (
                    <span class="px-3 py-1 rounded-full text-xs bg-indigo-50 text-indigo-600">
                      {tag}
                    </span>
                  ))}
                </div>
              )}
            </div>
            <a href={`${BASE}/post/${post.id}`} class="flex-shrink-0 flex items-center justify-center w-12 h-12 rounded-xl bg-slate-100 text-slate-600 group-hover:bg-indigo-500 group-hover:text-white transition-all duration-300">
              →
            </a>
          </div>
        </article>
      ))
    ) : (
      <div class="bg-white rounded-2xl border border-slate-200/50 p-12 text-center">
        <div class="text-4xl mb-4">{info.icon}</div>
        <p class="text-slate-500 mb-2">暂无文章</p>
        <p class="text-sm text-slate-400">敬请期待...</p>
      </div>
    )}
  </div>
</Layout>