---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const BASE = '/my-blog';

export function getStaticPaths() {
  return [
    { params: { slug: 'daily' } },
    { params: { slug: 'music' } },
    { params: { slug: 'books' } },
    { params: { slug: 'ecommerce' } },
    { params: { slug: 'pokemon' } },
  ];
}

const { slug } = Astro.params;

const categoryInfo: Record<string, { name: string; icon: string; description: string }> = {
  daily: { name: '日常生活', icon: '🏠', description: '记录生活的点滴' },
  music: { name: '音乐分析', icon: '🎵', description: '分享音乐心得' },
  books: { name: '读书鉴赏', icon: '📚', description: '读书笔记与感悟' },
  ecommerce: { name: '电商运营', icon: '🛒', description: '电商运营知识与实践' },
  pokemon: { name: '宝可梦', icon: '⚡', description: '宝可梦相关内容' },
};

const info = categoryInfo[slug as string] || { name: '未知', icon: '📁', description: '' };
const allPosts = await getCollection('blog');
const posts = allPosts.filter(post => post.data.category === slug).sort((a, b) => b.data.published.getTime() - a.data.published.getTime());
---

<Layout title={`${info.name} | 我的博客`}>
  <!-- Header -->
  <header class="mb-12">
    <div class="flex items-center gap-4 mb-4">
      <span class="text-4xl">{info.icon}</span>
      <h1 class="text-3xl font-serif font-semibold text-gray-900">{info.name}</h1>
    </div>
    <p class="text-gray-500">{info.description}</p>
    <p class="text-sm text-gray-400 mt-2">{posts.length} 篇文章</p>
  </header>

  <!-- Posts -->
  <div class="space-y-1">
    {posts.length > 0 ? (
      posts.map((post) => (
        <article class="group">
          <a href={`${BASE}/post/${post.id}`} class="block py-5 border-b border-gray-100 hover:border-gray-300 transition-all duration-200">
            <div class="flex items-baseline justify-between gap-4 mb-2">
              <h2 class="text-lg font-medium text-gray-900 group-hover:text-gray-600 transition-colors">
                {post.data.title}
              </h2>
              <span class="text-sm text-gray-400 flex-shrink-0">
                {post.data.published.toLocaleDateString('zh-CN')}
              </span>
            </div>
            <p class="text-sm text-gray-500 line-clamp-2">{post.body.slice(0, 150)}...</p>
            {post.data.tags && (
              <div class="flex gap-2 mt-3">
                {post.data.tags.map((tag) => (
                  <span class="px-2 py-0.5 text-xs bg-gray-100 text-gray-500 rounded">
                    {tag}
                  </span>
                ))}
              </div>
            )}
          </a>
        </article>
      ))
    ) : (
      <div class="py-16 text-center">
        <p class="text-gray-400">{info.icon} 暂无文章</p>
      </div>
    )}
  </div>
</Layout>