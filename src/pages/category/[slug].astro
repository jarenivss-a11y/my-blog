---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const BASE = '/my-blog';

export function getStaticPaths() {
  return [
    { params: { slug: 'daily' } },
    { params: { slug: 'music' } },
    { params: { slug: 'books' } },
    { params: { slug: 'ecommerce' } },
    { params: { slug: 'pokemon' } },
  ];
}

const { slug } = Astro.params;

const categoryInfo: Record<string, { name: string; icon: string; description: string }> = {
  daily: { name: '日常生活', icon: '🏠', description: '记录生活的点滴' },
  music: { name: '音乐分析', icon: '🎵', description: '分享音乐心得' },
  books: { name: '读书鉴赏', icon: '📚', description: '读书笔记与感悟' },
  ecommerce: { name: '电商运营', icon: '🛒', description: '电商运营知识与实践' },
  pokemon: { name: '宝可梦', icon: '⚡', description: '宝可梦相关内容' },
};

const info = categoryInfo[slug as string] || { name: '未知', icon: '📁', description: '' };
const allPosts = await getCollection('blog');
const posts = allPosts.filter(post => post.data.category === slug).sort((a, b) => b.data.published.getTime() - a.data.published.getTime());
---

< Layout title={`${info.name} | 我的博客`}>
  <div class="p-8">
    <div class="mb-8">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-4xl">{info.icon}</span>
        <h1 class="text-3xl font-bold text-gray-900">{info.name}</h1>
      </div>
      <p class="text-gray-600">{info.description}</p>
    </div>

    <div class="space-y-4">
      {posts.length > 0 ? (
        posts.map((post) => (
          <article class="bg-white rounded-xl border border-gray-200 p-6 hover:shadow-md transition-shadow">
            <div class="text-sm text-gray-500 mb-2">
              {post.data.published.toLocaleDateString('zh-CN')}
            </div>
            <h2 class="text-xl font-bold text-gray-900 mb-2">
              <a href={`${BASE}/post/${post.id}`} class="hover:text-indigo-600 transition-colors">
                {post.data.title}
              </a>
            </h2>
            <p class="text-gray-600 line-clamp-3">{post.body.slice(0, 150)}...</p>
            {post.data.tags && (
              <div class="flex gap-2 mt-4">
                {post.data.tags.map((tag) => (
                  <span class="bg-gray-100 text-gray-600 px-2 py-1 rounded text-sm">
                    {tag}
                  </span>
                ))}
              </div>
            )}
          </article>
        ))
      ) : (
        <div class="bg-white rounded-xl border border-gray-200 p-12 text-center">
          <p class="text-gray-500">暂无文章</p>
          <p class="text-gray-400 text-sm mt-2">敬请期待...</p>
        </div>
      )}
    </div>
  </div>
</Layout>