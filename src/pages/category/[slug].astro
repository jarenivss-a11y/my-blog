---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const BASE = '/my-blog';

export function getStaticPaths() {
  return [
    { params: { slug: 'daily' } },
    { params: { slug: 'music' } },
    { params: { slug: 'books' } },
    { params: { slug: 'ecommerce' } },
    { params: { slug: 'pokemon' } },
  ];
}

const { slug } = Astro.params;

const categoryInfo: Record<string, { name: string; icon: string; description: string }> = {
  daily: { name: '日常生活', icon: '🏠', description: '记录生活的点滴' },
  music: { name: '音乐分析', icon: '🎵', description: '分享音乐心得' },
  books: { name: '读书鉴赏', icon: '📚', description: '读书笔记与感悟' },
  ecommerce: { name: '电商运营', icon: '🛒', description: '电商运营知识与实践' },
  pokemon: { name: '宝可梦', icon: '⚡', description: '宝可梦相关内容' },
};

const info = categoryInfo[slug as string] || { name: '未知', icon: '📁', description: '' };
const allPosts = await getCollection('blog');
const posts = allPosts.filter(post => post.data.category === slug).sort((a, b) => b.data.published.getTime() - a.data.published.getTime());
---

<Layout title={`${info.name} | 我的博客`}>
  <!-- Header -->
  <header class="mb-12 p-8 rounded-3xl backdrop-blur-xl bg-[rgba(155,180,218,0.1)] border border-[rgba(80,128,176,0.3)]">
    <div class="flex items-center gap-4 mb-4">
      <span class="text-5xl">{info.icon}</span>
      <div>
        <h1 class="text-3xl font-serif font-black text-[#5080b0]">{info.name}</h1>
        <p class="text-[#8ac4e8] mt-1">{info.description}</p>
      </div>
    </div>
    <p class="text-sm text-[#8ac4e8]">{posts.length} 篇文章</p>
  </header>

  <!-- Posts -->
  <div class="space-y-4">
    {posts.length > 0 ? (
      posts.map((post) => (
        <article class="group">
          <a
            href={`${BASE}/post/${post.id}`}
            class="block p-6 rounded-2xl backdrop-blur-xl bg-[rgba(155,180,218,0.08)] border border-[rgba(80,128,176,0.2)] hover:bg-[rgba(80,128,176,0.15)] hover:border-[#72a8d8] hover:shadow-lg transition-all duration-300"
          >
            <div class="flex items-baseline justify-between gap-4 mb-3">
              <h2 class="text-lg font-serif font-semibold text-[#5080b0] group-hover:text-[#72a8d8] transition-colors">
                {post.data.title}
              </h2>
              <span class="text-sm text-[#8ac4e8] flex-shrink-0">
                {post.data.published.toLocaleDateString('zh-CN')}
              </span>
            </div>
            <p class="text-sm text-[#8ac4e8] line-clamp-2">{post.body.slice(0, 150)}...</p>
            {post.data.tags && (
              <div class="flex gap-2 mt-4">
                {post.data.tags.map((tag) => (
                  <span class="px-2 py-0.5 text-xs bg-[rgba(80,128,176,0.2)] text-[#72a8d8] rounded-full">
                    {tag}
                  </span>
                ))}
              </div>
            )}
          </a>
        </article>
      ))
    ) : (
      <div class="py-20 text-center rounded-3xl backdrop-blur-xl bg-[rgba(155,180,218,0.08)] border border-[rgba(80,128,176,0.2)]">
        <p class="text-4xl mb-4">{info.icon}</p>
        <p class="text-[#8ac4e8]">暂无文章</p>
      </div>
    )}
  </div>
</Layout>