---
import Layout from '../../layouts/Layout.astro';
import { skills, totalSkills } from '../../data/skills';

const BASE = '/my-blog';

const categories = Object.entries(skills).map(([name, data]) => ({
  name,
  icon: data.icon,
  count: data.items.length
}));
---

<Layout title="技能库 | 我的博客" description="Claude Code Skills 技能库">
  <div class="max-w-6xl mx-auto px-4 md:px-6 py-12">
    <!-- Header -->
    <header class="text-center mb-12">
      <h1 class="text-4xl font-serif font-black text-[#5080b0] mb-4 tracking-tight">
        Claude Code <span class="text-[#72a8d8]">Skills</span>
      </h1>
      <p class="text-lg text-[#8ac4e8] mb-8">
        实用的技能库，让 AI 助手更强大
      </p>

      <!-- Stats -->
      <div class="flex justify-center gap-6 flex-wrap">
        <div class="px-6 py-4 rounded-2xl bg-[rgba(155,180,218,0.1)] border border-[rgba(80,128,176,0.3)] shadow-sm backdrop-blur-xl">
          <div class="text-3xl font-serif font-bold text-[#72a8d8]">{totalSkills}</div>
          <div class="text-sm text-[#8ac4e8]">技能总数</div>
        </div>
        <div class="px-6 py-4 rounded-2xl bg-[rgba(155,180,218,0.1)] border border-[rgba(80,128,176,0.3)] shadow-sm backdrop-blur-xl">
          <div class="text-3xl font-serif font-bold text-[#72a8d8]">{categories.length}</div>
          <div class="text-sm text-[#8ac4e8]">分类数量</div>
        </div>
      </div>
    </header>

    <!-- Search -->
    <div class="max-w-md mx-auto mb-10">
      <div class="relative">
        <input
          type="text"
          id="search-input"
          placeholder="搜索技能..."
          class="w-full h-12 pl-12 pr-4 rounded-full border border-[rgba(80,128,176,0.3)] bg-[rgba(155,180,218,0.1)] text-[#e2e9f5] placeholder:text-[#8ac4e8] focus:outline-none focus:ring-2 focus:ring-[#72a8d8] focus:border-[#72a8d8] transition-all"
        />
        <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-[#8ac4e8]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
      </div>
    </div>

    <!-- Filter Buttons -->
    <div class="flex flex-wrap justify-center gap-3 mb-12">
      <button
        class="filter-btn active px-5 py-2 rounded-full border-2 border-primary bg-primary text-white font-medium text-sm transition-all hover:shadow-lg hover:shadow-primary"
        data-filter="all"
      >
        📋 全部
      </button>
      {categories.map(cat => (
        <button
          class="filter-btn px-5 py-2 rounded-full border-2 border-[rgba(80,128,176,0.3)] bg-[rgba(155,180,218,0.1)] text-[#5080b0] font-medium text-sm transition-all hover:border-[#72a8d8] hover:text-[#72a8d8]"
          data-filter={cat.name}
        >
          {cat.icon} {cat.name}
        </button>
      ))}
    </div>

    <!-- Skills Grid -->
    <div id="skills-container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {categories.map(cat => (
        <div class="skill-category" data-category={cat.name}>
          <div class="bg-[rgba(155,180,218,0.08)] rounded-2xl border border-[rgba(80,128,176,0.2)] p-6 backdrop-blur-xl">
            <div class="flex items-center gap-3 mb-4">
              <span class="text-2xl">{cat.icon}</span>
              <div>
                <h2 class="text-lg font-bold text-[#5080b0]">{cat.name}</h2>
                <span class="text-xs text-[#8ac4e8]">{cat.count} 个技能</span>
              </div>
            </div>
            <div class="space-y-3">
              {skills[cat.name].items.map(skill => (
                <div
                  class="skill-card p-4 rounded-xl bg-[rgba(155,180,218,0.05)] hover:bg-[rgba(80,128,176,0.15)] border border-transparent hover:border-[#72a8d8] transition-all cursor-pointer group"
                  data-name={skill.name.toLowerCase()}
                  data-desc={skill.desc.toLowerCase()}
                >
                  <div class="flex items-start justify-between gap-2 mb-1">
                    <code class="text-sm font-mono text-[#72a8d8] font-medium group-hover:underline">{skill.name}</code>
                    {skill.version && skill.version !== "-" && (
                      <span class="text-xs px-2 py-0.5 rounded-full bg-[rgba(80,128,176,0.2)] text-[#72a8d8]">{skill.version}</span>
                    )}
                  </div>
                  <p class="text-sm text-[#8ac4e8] line-clamp-2">{skill.desc}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- No Results -->
    <div id="no-results" class="hidden text-center py-16">
      <p class="text-[#8ac4e8] text-lg">没有找到匹配的技能</p>
    </div>
  </div>

  <!-- Modal -->
  <div id="skill-modal" class="hidden fixed inset-0 z-[100] flex items-center justify-center p-4">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" id="modal-overlay"></div>
    <div class="relative bg-[rgba(30,45,65,0.98)] rounded-3xl p-8 max-w-lg w-full shadow-2xl max-h-[80vh] overflow-y-auto border border-[rgba(80,128,176,0.3)]">
      <button id="modal-close" class="absolute top-4 right-4 p-2 hover:bg-[rgba(80,128,176,0.2)] rounded-lg transition-colors">
        <svg class="w-5 h-5 text-[#8ac4e8]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
      <div id="modal-content"></div>
    </div>
  </div>
</Layout>

<style>
  .skill-category.hidden {
    display: none;
  }
  .skill-card.hidden {
    display: none;
  }
</style>

<script>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const categories = document.querySelectorAll('.skill-category');
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const noResults = document.getElementById('no-results');
  const modal = document.getElementById('skill-modal');
  const modalOverlay = document.getElementById('modal-overlay');
  const modalClose = document.getElementById('modal-close');
  const modalContent = document.getElementById('modal-content');

  let currentFilter = 'all';

  function filterSkills() {
    const searchTerm = searchInput?.value.toLowerCase() || '';
    let visibleCount = 0;

    categories.forEach(cat => {
      const categoryName = cat.getAttribute('data-category');
      const cards = cat.querySelectorAll('.skill-card');
      let categoryVisible = currentFilter === 'all' || categoryName === currentFilter;
      let categoryHasVisibleCards = false;

      cards.forEach(card => {
        const name = card.getAttribute('data-name') || '';
        const desc = card.getAttribute('data-desc') || '';
        const matchesSearch = name.includes(searchTerm) || desc.includes(searchTerm);
        const shouldShow = categoryVisible && matchesSearch;

        if (shouldShow) {
          (card as HTMLElement).style.display = '';
          categoryHasVisibleCards = true;
          visibleCount++;
        } else {
          (card as HTMLElement).style.display = 'none';
        }
      });

      (cat as HTMLElement).style.display = categoryHasVisibleCards ? '' : 'none';
    });

    if (noResults) {
      noResults.classList.toggle('hidden', visibleCount > 0);
    }
  }

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => {
        b.classList.remove('active', 'bg-[#72a8d8]', 'text-white', 'border-[#72a8d8]');
        b.classList.add('border-[rgba(80,128,176,0.3)]', 'bg-[rgba(155,180,218,0.1)]', 'text-[#5080b0]');
      });
      btn.classList.add('active', 'bg-[#72a8d8]', 'text-white', 'border-[#72a8d8]');
      btn.classList.remove('border-[rgba(80,128,176,0.3)]', 'bg-[rgba(155,180,218,0.1)]', 'text-[#5080b0]');
      currentFilter = btn.getAttribute('data-filter') || 'all';
      filterSkills();
    });
  });

  searchInput?.addEventListener('input', filterSkills);

  // Skill card click to show modal
  document.querySelectorAll('.skill-card').forEach(card => {
    card.addEventListener('click', () => {
      const name = card.getAttribute('data-name') || '';
      const desc = card.querySelector('p')?.textContent || '';

      if (modalContent) {
        modalContent.innerHTML = `
          <h3 class="text-xl font-bold text-[#72a8d8] mb-2 font-serif">${name}</h3>
          <p class="text-[#8ac4e8] mb-4">${desc}</p>
          <div class="text-sm text-[#8ac4e8]">
            <p>在 Claude Code 中使用：<code class="px-2 py-1 rounded bg-[rgba(80,128,176,0.2)] text-[#72a8d8]">/ ${name}</code></p>
          </div>
        `;
      }

      modal?.classList.remove('hidden');
    });
  });

  function closeModal() {
    modal?.classList.add('hidden');
  }

  modalOverlay?.addEventListener('click', closeModal);
  modalClose?.addEventListener('click', closeModal);
</script>
