---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

const BASE = '/my-blog';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const categoryInfo: Record<string, { name: string; icon: string }> = {
  daily: { name: '日常生活', icon: '🏠' },
  music: { name: '音乐分析', icon: '🎵' },
  books: { name: '读书鉴赏', icon: '📚' },
  ecommerce: { name: '电商运营', icon: '🛒' },
  pokemon: { name: '宝可梦', icon: '⚡' },
};

const category = categoryInfo[post.data.category] || { name: '未知', icon: '📁' };
---

<Layout title={`${post.data.title} | 我的博客`}>
  <article>
    <!-- Header -->
    <header class="mb-12 pb-8 border-b border-gray-200">
      <a
        href={`${BASE}/category/${post.data.category}`}
        class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-gray-900 transition-colors mb-6"
      >
        <span>{category.icon}</span>
        <span>{category.name}</span>
      </a>
      <h1 class="text-3xl font-serif font-semibold text-gray-900 mb-4 leading-tight">
        {post.data.title}
      </h1>
      <div class="flex items-center gap-4 text-sm text-gray-400">
        <span>{post.data.published.toLocaleDateString('zh-CN')}</span>
        {post.data.tags && (
          <div class="flex gap-2">
            {post.data.tags.map((tag) => (
              <span class="px-2 py-0.5 text-xs bg-gray-100 text-gray-500 rounded">
                {tag}
              </span>
            ))}
          </div>
        )}
      </div>
    </header>

    <!-- Content -->
    <div class="prose prose-lg max-w-none prose-gray prose-headings:font-serif prose-headings:text-gray-900 prose-p:text-gray-600 prose-li:text-gray-600 prose-a:text-gray-900 prose-strong:text-gray-900">
      <Content />
    </div>

    <!-- Footer -->
    <footer class="mt-16 pt-8 border-t border-gray-200">
      <a
        href={`${BASE}/category/${post.data.category}`}
        class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-gray-900 transition-colors"
      >
        ← 返回{category.name}
      </a>
    </footer>
  </article>
</Layout>

<style>
  .prose h2 {
    @apply text-xl font-semibold text-gray-900 mt-12 mb-4;
  }
  .prose h3 {
    @apply text-lg font-semibold text-gray-900 mt-8 mb-3;
  }
  .prose p {
    @apply text-gray-600 leading-relaxed mb-6;
  }
  .prose ul, .prose ol {
    @apply text-gray-600 mb-6 pl-6;
  }
  .prose li {
    @apply mb-2;
  }
  .prose strong {
    @apply font-semibold text-gray-900;
  }
  .prose a {
    @apply text-gray-900 underline decoration-gray-300 hover:decoration-gray-900 transition-colors;
  }
  .prose blockquote {
    @apply border-l-4 border-gray-300 pl-4 italic text-gray-500 my-8;
  }
  .prose code {
    @apply bg-gray-100 px-1.5 py-0.5 rounded text-sm text-gray-800;
  }
  .prose pre {
    @apply bg-gray-900 text-gray-100 p-4 rounded-xl overflow-x-auto my-8;
  }
  .prose pre code {
    @apply bg-transparent p-0 text-gray-100;
  }
</style>