---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import TableOfContents from '../../components/TableOfContents.astro';
import SocialShare from '../../components/SocialShare.astro';
import Comments from '../../components/Comments.astro';
import ArticleSEO from '../../components/ArticleSEO.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Reaction from '../../components/Reaction.astro';
import JumpToComments from '../../components/JumpToComments.astro';
import ReadingMode from '../../components/ReadingMode.astro';
import ReadAloud from '../../components/ReadAloud.astro';
import ParagraphCopy from '../../components/ParagraphCopy.astro';
import ReadingPosition from '../../components/ReadingPosition.astro';
import CopyAllCode from '../../components/CopyAllCode.astro';
import ReadingCompletion from '../../components/ReadingCompletion.astro';
import CollapsibleSections from '../../components/CollapsibleSections.astro';
import ReadingModeToggle from '../../components/ReadingModeToggle.astro';
import HeadingLinks from '../../components/HeadingLinks.astro';
import ArticleFeedback from '../../components/ArticleFeedback.astro';

const BASE = '/my-blog';
const SITE_URL = 'https://jarenivss-a11y.github.io/my-blog';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

// Get all posts for prev/next navigation
const allPosts = await getCollection('blog');
const categoryPosts = allPosts
  .filter(p => p.data.category === post.data.category && !p.data.draft)
  .sort((a, b) => b.data.published.getTime() - a.data.published.getTime());

const currentIndex = categoryPosts.findIndex(p => p.id === post.id);
const prevPost = currentIndex < categoryPosts.length - 1 ? categoryPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? categoryPosts[currentIndex - 1] : null;

// Calculate reading time (assuming 400 words per minute)
const wordCount = post.body.split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 400));

const categoryInfo: Record<string, { name: string; icon: string }> = {
  daily: { name: '日常生活', icon: '🏠' },
  music: { name: '音乐分析', icon: '🎵' },
  books: { name: '读书鉴赏', icon: '📚' },
  ecommerce: { name: '电商运营', icon: '🛒' },
  pokemon: { name: '宝可梦', icon: '⚡' },
};

const category = categoryInfo[post.data.category] || { name: '未知', icon: '📁' };
---

<Layout title={`${post.data.title} | 我的博客`}>
  <article class="relative">
    <!-- Table of Contents (fixed right) -->
    <TableOfContents headings={headings} />

    <div class="max-w-3xl mx-auto">
      <!-- Breadcrumb -->
      <Breadcrumb items={[
        { name: category.name, href: `${BASE}/category/${post.data.category}` },
        { name: post.data.title }
      ]} />

      <!-- Header -->
      <header class="mb-12 p-8 rounded-3xl backdrop-blur-xl bg-white/70 dark:bg-slate-800/50 border border-white/50 dark:border-slate-700/50">
        <a
          href={`${BASE}/category/${post.data.category}`}
          class="inline-flex items-center gap-2 text-sm text-primary hover:text-primary transition-colors mb-6"
        >
          <span>{category.icon}</span>
          <span>{category.name}</span>
        </a>
        <h1 class="text-3xl font-serif font-black text-slate-900 dark:text-white mb-6 leading-tight">
          {post.data.title}
        </h1>
        <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-slate-400 dark:text-slate-500">
          <span class="flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            {post.data.published.toLocaleDateString('zh-CN')}
          </span>
          <span class="flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            {readingTime} 分钟阅读
          </span>
          <span class="flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
            {wordCount.toLocaleString()} 字
          </span>
          {post.data.tags && post.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-2 ml-auto">
              {post.data.tags.map((tag) => (
                <a href={`${BASE}/tags/${encodeURIComponent(tag)}`} class="px-2 py-0.5 rounded-full bg-primary/10 text-primary text-xs hover:bg-primary hover:text-white transition-colors">
                  #{tag}
                </a>
              ))}
            </div>
          )}
        </div>
      </header>

      {/* Cover Image */}
      {post.data.cover && (
        <div class="mb-8 rounded-3xl overflow-hidden">
          <img
            src={post.data.cover}
            alt={post.data.title}
            class="w-full h-64 md:h-80 object-cover"
            loading="lazy"
          />
        </div>
      )}

      <!-- Content -->
      <div class="p-8 rounded-3xl backdrop-blur-xl bg-white/70 dark:bg-slate-800/50 border border-white/50 dark:border-slate-700/50 prose prose-lg max-w-none prose-slate dark:prose-invert prose-headings:font-serif prose-headings:text-slate-900 dark:prose-headings:text-white prose-p:text-slate-600 dark:prose-p:text-slate-300 prose-li:text-slate-600 dark:prose-li:text-slate-300 prose-a:text-primary prose-strong:text-slate-900 dark:prose-strong:text-white">
        <Content />
      </div>

      <!-- Prev/Next Navigation -->
      {(prevPost || nextPost) && (
        <nav class="mt-8 grid grid-cols-2 gap-4">
          {prevPost ? (
            <a
              href={`${BASE}/post/${prevPost.id}`}
              class="group p-6 rounded-2xl backdrop-blur-xl bg-white/50 dark:bg-slate-800/50 border border-white/50 dark:border-slate-700/50 hover:bg-white/70 dark:hover:bg-slate-800/70 hover:border-primary transition-all"
            >
              <span class="text-xs text-slate-400 mb-1 block">← 上一篇</span>
              <span class="text-sm font-medium text-slate-700 dark:text-slate-200 group-hover:text-primary transition-colors line-clamp-2">
                {prevPost.data.title}
              </span>
            </a>
          ) : (
            <div></div>
          )}
          {nextPost ? (
            <a
              href={`${BASE}/post/${nextPost.id}`}
              class="group p-6 rounded-2xl backdrop-blur-xl bg-white/50 dark:bg-slate-800/50 border border-white/50 dark:border-slate-700/50 hover:bg-white/70 dark:hover:bg-slate-800/70 hover:border-primary transition-all text-right"
            >
              <span class="text-xs text-slate-400 mb-1 block">下一篇 →</span>
              <span class="text-sm font-medium text-slate-700 dark:text-slate-200 group-hover:text-primary transition-colors line-clamp-2">
                {nextPost.data.title}
              </span>
            </a>
          ) : (
            <div></div>
          )}
        </nav>
      )}

      <!-- Footer -->
      <footer class="mt-8 p-6 rounded-2xl backdrop-blur-xl bg-white/50 dark:bg-slate-800/50 border border-white/50 dark:border-slate-700/50">
        <div class="flex items-center justify-between flex-wrap gap-4">
          <a
            href={`${BASE}/category/${post.data.category}`}
            class="inline-flex items-center gap-2 text-sm text-slate-500 hover:text-primary transition-colors"
          >
            ← 返回{category.name}
          </a>
          <SocialShare title={post.data.title} url={`${SITE_URL}/post/${post.id}`} category={category.name} />
          <div class="flex items-center gap-3">
            <a
              href="#"
              class="edit-on-github hidden text-sm text-slate-400 hover:text-primary transition-colors"
              data-post-id={`${post.id}.md`}
              title="在 GitHub 上编辑"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
              </svg>
              编辑
            </a>
            <button
              id="add-to-reading-list"
              class="flex items-center gap-2 px-4 py-2 rounded-full bg-slate-100 dark:bg-slate-700 hover:bg-primary hover:text-white text-slate-600 dark:text-slate-300 transition-colors text-sm"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/>
              </svg>
              <span>收藏</span>
            </button>
          </div>
        </div>
      </footer>

      <!-- Reaction -->
      <Reaction postId={post.id} />

      <!-- Jump to Comments -->
      <JumpToComments />

      <!-- Reading Mode -->
      <ReadingMode />

      <!-- Read Aloud -->
      <ReadAloud />

      <!-- Paragraph Copy -->
      <ParagraphCopy />

      <!-- Reading Position Persistence -->
      <ReadingPosition />

      <!-- Copy All Code -->
      <CopyAllCode />

      <!-- Reading Completion -->
      <ReadingCompletion />

      <!-- Collapsible Sections -->
      <CollapsibleSections />

      <!-- Reading Mode Toggle (Mobile) -->
      <ReadingModeToggle />

      <!-- Heading Links -->
      <HeadingLinks />

      <!-- Article Feedback -->
      <ArticleFeedback />

      <!-- Comments -->
      <Comments title={post.data.title} />

      <!-- Related Posts -->
      <RelatedPosts currentPostId={post.id} category={post.data.category} tags={post.data.tags} />
    </div>
  </article>

  <!-- Article SEO -->
  <ArticleSEO
    title={post.data.title}
    description={post.body.slice(0, 200)}
    url={`/post/${post.id}`}
    publishedTime={post.data.published}
    image={post.data.cover}
    category={category.name}
    tags={post.data.tags}
  />
</Layout>

<style is:global>
  .prose {
    font-size: var(--article-font-size, 18px);
  }
  .prose h2 {
    @apply text-xl font-bold text-slate-900 dark:text-white mt-12 mb-4;
  }
  .prose h3 {
    @apply text-lg font-bold text-slate-900 dark:text-white mt-8 mb-3;
  }
  .prose p {
    @apply text-slate-600 dark:text-slate-300 leading-relaxed mb-6;
  }
  .prose ul, .prose ol {
    @apply text-slate-600 dark:text-slate-300 mb-6 pl-6;
  }
  .prose li {
    @apply mb-2;
  }
  .prose strong {
    @apply font-semibold text-slate-900 dark:text-white;
  }
  .prose a {
    @apply text-primary underline decoration-primary hover:decoration-primary transition-colors;
  }
  .prose blockquote {
    @apply border-l-4 border-primary pl-4 italic text-slate-500 dark:text-slate-400 my-8;
  }
  .prose code {
    @apply bg-primary px-1.5 py-0.5 rounded text-sm text-primary;
  }
  .prose pre {
    @apply bg-slate-900 dark:bg-slate-950 text-slate-100 p-4 rounded-xl overflow-x-auto my-8;
  }
  .prose pre code {
    @apply bg-transparent p-0 text-slate-100;
  }
</style>