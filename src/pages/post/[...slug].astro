---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

const BASE = '/my-blog';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const categoryInfo: Record<string, { name: string; icon: string; color: string }> = {
  daily: { name: '日常生活', icon: '🏠', color: 'from-rose-500 to-pink-500' },
  music: { name: '音乐分析', icon: '🎵', color: 'from-violet-500 to-purple-500' },
  books: { name: '读书鉴赏', icon: '📚', color: 'from-amber-500 to-orange-500' },
  ecommerce: { name: '电商运营', icon: '🛒', color: 'from-emerald-500 to-teal-500' },
  pokemon: { name: '宝可梦', icon: '⚡', color: 'from-blue-500 to-cyan-500' },
};

const category = categoryInfo[post.data.category] || { name: '未知', icon: '📁', color: 'from-slate-500 to-gray-500' };
---

<Layout title={`${post.data.title} | 我的博客`}>
  <article class="bg-[#fff9f0] rounded-3xl border-2 border-dashed border-[#c4a882] overflow-hidden">
    <!-- Header -->
    <header class="relative px-10 py-12 border-b-2 border-dashed border-[#c4a882]">
      {post.data.cover ? (
        <div class="absolute top-0 left-0 right-0 h-48 overflow-hidden" style="background: #ffe4c4;">
          <img src={post.data.cover} alt="" class="w-full h-full" style="object-fit: contain; max-height: 100%;" />
        </div>
      ) : (
        <div class="absolute top-0 left-0 right-0 h-32 bg-[#ffe4c4]"></div>
      )}
      <div class="relative">
        <a href={`${BASE}/category/${post.data.category}`} class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-[#fff9f0] text-sm text-[#8b6b4a] hover:bg-white transition-colors mb-6 border border-[#c4a882]">
          <span>{category.icon}</span>
          <span>{category.name}</span>
        </a>
        <h1 class="text-4xl font-bold text-[#5c4a3a] mb-4 leading-tight">{post.data.title}</h1>
        <div class="flex items-center gap-4 text-sm text-[#a08060]">
          <span class="font-['Caveat']">{post.data.published.toLocaleDateString('zh-CN')}</span>
          {post.data.tags && (
            <div class="flex gap-2">
              {post.data.tags.map((tag) => (
                <span class="px-2 py-1 rounded-md bg-[#ffe4c4] text-[#8b6b4a] border border-[#c4a882]">{tag}</span>
              ))}
            </div>
          )}
        </div>
      </div>
    </header>

    <!-- Content -->
    <div class="px-10 py-10">
      <div class="prose prose-lg max-w-none prose-slate prose-headings:font-bold prose-headings:text-[#5c4a3a] prose-p:text-[#8b7355] prose-li:text-[#8b7355] prose-a:text-[#8b6b4a] prose-strong:text-[#5c4a3a]">
        <Content />
      </div>
    </div>

    <!-- Footer -->
    <footer class="px-10 py-6 border-t-2 border-dashed border-[#c4a882] bg-[#faf8f5]">
      <a href={`${BASE}/category/${post.data.category}`} class="inline-flex items-center gap-2 text-[#8b6b4a] hover:text-[#5c4a3a] font-medium">
        ← 返回{category.name}
      </a>
    </footer>
  </article>
</Layout>

<style>
  .prose h2 {
    @apply text-2xl font-bold text-[#5c4a3a] mt-10 mb-4;
  }
  .prose h3 {
    @apply text-xl font-bold text-[#5c4a3a] mt-8 mb-3;
  }
  .prose p {
    @apply text-[#8b7355] leading-relaxed mb-4;
  }
  .prose ul, .prose ol {
    @apply text-[#8b7355] mb-4 pl-6;
  }
  .prose li {
    @apply mb-2;
  }
  .prose strong {
    @apply font-bold text-[#5c4a3a];
  }
  .prose a {
    @apply text-[#8b6b4a] hover:underline;
  }
  .prose blockquote {
    @apply border-l-4 border-[#c4a882] pl-4 italic text-[#a08060] my-6;
  }
  .prose code {
    @apply bg-[#ffe4c4] px-1 py-0.5 rounded text-sm text-[#8b6b4a];
  }
  .prose pre {
    @apply bg-[#5c4a3a] text-[#ffe4c4] p-4 rounded-xl overflow-x-auto my-6;
  }
  .prose pre code {
    @apply bg-transparent p-0 text-[#ffe4c4];
  }
</style>