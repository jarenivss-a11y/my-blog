---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import Sidebar from '../components/Sidebar.astro';

const BASE = '/my-blog';

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.published.getTime() - a.data.published.getTime())
  .slice(0, 10);

const categories = [
  { name: '日常生活', slug: 'daily', icon: '🏠' },
  { name: '音乐分析', slug: 'music', icon: '🎵' },
  { name: '读书鉴赏', slug: 'books', icon: '📚' },
  { name: '电商运营', slug: 'ecommerce', icon: '🛒' },
  { name: '宝可梦', slug: 'pokemon', icon: '⚡' },
];

const categoryInfo: Record<string, { name: string }> = {
  daily: { name: '日常生活' },
  music: { name: '音乐分析' },
  books: { name: '读书鉴赏' },
  ecommerce: { name: '电商运营' },
  pokemon: { name: '宝可梦' },
};

const categoryCounts = categories.map(cat => ({
  ...cat,
  count: allPosts.filter(post => post.data.category === cat.slug).length
}));

const allTags = [...new Set(allPosts.flatMap(post => post.data.tags || []))];
---

<Layout title="首页 | 我的博客">
  <div class="xl:flex xl:gap-8">
    <main class="flex-1">
      <!-- Hero Section -->
      <section class="mb-16 p-8 rounded-3xl backdrop-blur-xl bg-gradient-to-br from-primary/5 via-white/70 to-primary/10 dark:from-primary/10 dark:via-slate-800/70 dark:to-primary/10 border border-primary/10 dark:border-primary/20">
        <div class="flex flex-col md:flex-row items-center gap-8">
          <div class="w-28 h-28 rounded-full bg-gradient-to-br from-primary to-primary/60 flex items-center justify-center text-5xl font-serif text-white shadow-xl shadow-primary/30 flex-shrink-0">
            M
          </div>

          <div class="text-center md:text-left">
            <h1 class="text-3xl md:text-4xl font-serif font-black text-slate-900 dark:text-white mb-3 tracking-tight">
              你好，欢迎来访
            </h1>
            <p class="text-lg text-slate-500 dark:text-slate-400 mb-4 max-w-xl">
              在这里记录生活的点滴，分享关于音乐、读书、电商运营和宝可梦的思考
            </p>
            <div class="flex flex-wrap gap-2 justify-center md:justify-start">
              {allTags.slice(0, 8).map((tag) => (
                <span class="px-3 py-1 text-xs rounded-full bg-primary/10 text-primary dark:bg-primary/20">
                  #{tag}
                </span>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- Categories -->
      <section class="mb-16">
        <h2 class="text-xs font-medium text-slate-400 uppercase tracking-widest mb-6">探索分类</h2>
        <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
          {categoryCounts.map((cat) => (
            <a
              href={`${BASE}/category/${cat.slug}`}
              class="group relative p-6 rounded-2xl backdrop-blur-xl bg-white/70 dark:bg-slate-800/50 border border-white/50 dark:border-slate-700/50 shadow-sm hover:shadow-lg hover:border-primary/30 dark:hover:border-primary/50 transition-all duration-300"
            >
              <span class="text-3xl mb-3 block">{cat.icon}</span>
              <div class="font-medium text-slate-800 dark:text-slate-100 text-sm group-hover:text-primary transition-colors">{cat.name}</div>
              <div class="text-xs text-slate-400 dark:text-slate-500 mt-1">{cat.count} 篇</div>
            </a>
          ))}
        </div>
      </section>

      <!-- Latest Posts -->
      <section>
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-xs font-medium text-slate-400 uppercase tracking-widest">最新文章</h2>
          <div class="flex gap-2">
            <button id="layout-list" class="p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors" title="列表布局">
              <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
              </svg>
            </button>
            <button id="layout-grid" class="p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors" title="网格布局">
              <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
              </svg>
            </button>
          </div>
        </div>

        <!-- List Layout -->
        <div id="posts-list" class="space-y-4">
          {posts.length > 0 ? (
            posts.map((post) => (
              <article class="group">
                <a
                  href={`${BASE}/post/${post.id}`}
                  class="block p-6 rounded-2xl backdrop-blur-xl bg-white/70 dark:bg-slate-800/50 border border-white/50 dark:border-slate-700/50 hover:bg-white dark:hover:bg-slate-800 hover:border-primary/30 dark:hover:border-primary/50 hover:shadow-lg transition-all duration-300"
                >
                  <div class="flex items-center gap-3 mb-3">
                    <span class="text-xs text-slate-400">{post.data.published.toLocaleDateString('zh-CN')}</span>
                    <span class="px-2 py-0.5 text-xs bg-primary/10 text-primary dark:bg-primary/20 rounded-full">
                      {categoryInfo[post.data.category]?.name || '未知'}
                    </span>
                  </div>
                  <h3 class="text-lg font-serif font-semibold text-slate-900 dark:text-white group-hover:text-primary transition-colors mb-2">
                    {post.data.title}
                  </h3>
                  <p class="text-sm text-slate-500 dark:text-slate-400 line-clamp-2">{post.body.slice(0, 120)}...</p>
                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class="flex gap-2 mt-3">
                      {post.data.tags.slice(0, 3).map((tag) => (
                        <span class="px-2 py-0.5 text-xs bg-slate-100 dark:bg-slate-700 text-slate-500 dark:text-slate-400 rounded">
                          #{tag}
                        </span>
                      ))}
                    </div>
                  )}
                </a>
              </article>
            ))
          ) : (
            <div class="text-center py-16">
              <p class="text-slate-400 dark:text-slate-500">暂无文章</p>
            </div>
          )}
        </div>

        <!-- Grid Layout -->
        <div id="posts-grid" class="hidden grid grid-cols-1 md:grid-cols-2 gap-4">
          {posts.length > 0 ? (
            posts.map((post) => (
              <article class="group">
                <a
                  href={`${BASE}/post/${post.id}`}
                  class="block p-6 rounded-2xl backdrop-blur-xl bg-white/70 dark:bg-slate-800/50 border border-white/50 dark:border-slate-700/50 hover:bg-white dark:hover:bg-slate-800 hover:border-primary/30 dark:hover:border-primary/50 hover:shadow-lg transition-all duration-300 h-full"
                >
                  <div class="flex items-center gap-3 mb-3">
                    <span class="px-2 py-0.5 text-xs bg-primary/10 text-primary dark:bg-primary/20 rounded-full">
                      {categoryInfo[post.data.category]?.name || '未知'}
                    </span>
                    <span class="text-xs text-slate-400">{post.data.published.toLocaleDateString('zh-CN')}</span>
                  </div>
                  <h3 class="text-lg font-serif font-semibold text-slate-900 dark:text-white group-hover:text-primary transition-colors mb-2 line-clamp-2">
                    {post.data.title}
                  </h3>
                  <p class="text-sm text-slate-500 dark:text-slate-400 line-clamp-3">{post.body.slice(0, 100)}...</p>
                </a>
              </article>
            ))
          ) : (
            <div class="col-span-2 text-center py-16">
              <p class="text-slate-400 dark:text-slate-500">暂无文章</p>
            </div>
          )}
        </div>
      </section>
    </main>

    <Sidebar />
  </div>

  <script>
    function initLayoutToggle() {
      const listBtn = document.getElementById('layout-list');
      const gridBtn = document.getElementById('layout-grid');
      const listView = document.getElementById('posts-list');
      const gridView = document.getElementById('posts-grid');

      if (!listBtn || !gridBtn || !listView || !gridView) return;

      const savedLayout = localStorage.getItem('posts-layout') || 'list';

      function setLayout(layout: string) {
        if (layout === 'grid') {
          listView.classList.add('hidden');
          gridView.classList.remove('hidden');
          gridBtn.classList.add('bg-primary/10', 'text-primary');
          listBtn.classList.remove('bg-primary/10', 'text-primary');
        } else {
          listView.classList.remove('hidden');
          gridView.classList.add('hidden');
          listBtn.classList.add('bg-primary/10', 'text-primary');
          gridBtn.classList.remove('bg-primary/10', 'text-primary');
        }
        localStorage.setItem('posts-layout', layout);
      }

      listBtn.addEventListener('click', () => setLayout('list'));
      gridBtn.addEventListener('click', () => setLayout('grid'));

      setLayout(savedLayout);
    }

    initLayoutToggle();
    document.addEventListener('astro:after-swap', initLayoutToggle);
  </script>
</Layout>