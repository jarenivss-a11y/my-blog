---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const BASE = '/my-blog';

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.published.getTime() - a.data.published.getTime())
  .slice(0, 10);

const categories = [
  { name: '日常生活', slug: 'daily', icon: '🏠' },
  { name: '音乐分析', slug: 'music', icon: '🎵' },
  { name: '读书鉴赏', slug: 'books', icon: '📚' },
  { name: '电商运营', slug: 'ecommerce', icon: '🛒' },
  { name: '宝可梦', slug: 'pokemon', icon: '⚡' },
];

const categoryInfo: Record<string, { name: string }> = {
  daily: { name: '日常生活' },
  music: { name: '音乐分析' },
  books: { name: '读书鉴赏' },
  ecommerce: { name: '电商运营' },
  pokemon: { name: '宝可梦' },
};

const categoryCounts = categories.map(cat => ({
  ...cat,
  count: allPosts.filter(post => post.data.category === cat.slug).length
}));
---

<Layout title="首页 | 我的博客">
  <!-- Hero -->
  <section class="mb-16">
    <h1 class="text-3xl font-serif font-semibold text-gray-900 mb-3 tracking-tight">
      你好，欢迎来访
    </h1>
    <p class="text-gray-500 text-lg">
      在这里记录生活的点滴，分享关于音乐、读书、电商运营和宝可梦的思考
    </p>
  </section>

  <!-- Categories -->
  <section class="mb-16">
    <h2 class="text-xs font-medium text-gray-400 uppercase tracking-widest mb-6">探索分类</h2>
    <div class="grid grid-cols-2 md:grid-cols-5 gap-3">
      {categoryCounts.map((cat) => (
        <a
          href={`${BASE}/category/${cat.slug}`}
          class="flex flex-col items-center gap-2 p-4 rounded-xl border border-gray-200 hover:border-gray-400 hover:bg-gray-50 transition-all duration-200 text-center"
        >
          <span class="text-2xl">{cat.icon}</span>
          <div>
            <div class="font-medium text-gray-800 text-sm">{cat.name}</div>
            <div class="text-xs text-gray-400">{cat.count} 篇</div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Latest Posts -->
  <section>
    <h2 class="text-xs font-medium text-gray-400 uppercase tracking-widest mb-6">最新文章</h2>
    <div class="space-y-4">
      {posts.length > 0 ? (
        posts.map((post) => (
          <article class="group">
            <a href={`${BASE}/post/${post.id}`} class="block p-5 -mx-5 rounded-xl hover:bg-gray-50 transition-all duration-200">
              <div class="flex items-center gap-3 mb-2">
                <span class="text-xs text-gray-400">{post.data.published.toLocaleDateString('zh-CN')}</span>
                <span class="px-2 py-0.5 text-xs bg-gray-100 text-gray-600 rounded">
                  {categoryInfo[post.data.category]?.name || '未知'}
                </span>
              </div>
              <h3 class="text-lg font-medium text-gray-900 group-hover:text-gray-600 transition-colors mb-2">
                {post.data.title}
              </h3>
              <p class="text-sm text-gray-500 line-clamp-2">{post.body.slice(0, 120)}...</p>
            </a>
          </article>
        ))
      ) : (
        <p class="text-gray-500 text-center py-12">暂无文章</p>
      )}
    </div>
  </section>
</Layout>