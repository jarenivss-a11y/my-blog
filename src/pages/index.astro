---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import Sidebar from '../components/Sidebar.astro';

const BASE = '/my-blog';

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.published.getTime() - a.data.published.getTime())
  .slice(0, 10)
  .map(post => ({...post, readingTime: Math.max(1, Math.ceil(post.body.split(/\s+/).length / 400))}));

const categories = [
  { name: '日常生活', slug: 'daily', icon: '🏠' },
  { name: '音乐分析', slug: 'music', icon: '🎵' },
  { name: '读书鉴赏', slug: 'books', icon: '📚' },
  { name: '电商运营', slug: 'ecommerce', icon: '🛒' },
  { name: '宝可梦', slug: 'pokemon', icon: '⚡' },
];

const categoryInfo: Record<string, { name: string; emoji: string; gradient: string; border: string; shadow: string }> = {
  daily: { name: '日常生活', emoji: '🏠', gradient: 'from-amber-50/50 via-orange-50/40 to-yellow-50/50', border: 'border-amber-200/60', shadow: 'shadow-amber-500' },
  music: { name: '音乐分析', emoji: '🎵', gradient: 'from-pink-50/50 via-purple-50/40 to-fuchsia-50/50', border: 'border-pink-200/60', shadow: 'shadow-pink-500' },
  books: { name: '读书鉴赏', emoji: '📚', gradient: 'from-emerald-50/50 via-green-50/40 to-teal-50/50', border: 'border-emerald-200/60', shadow: 'shadow-emerald-500' },
  ecommerce: { name: '电商运营', emoji: '🛒', gradient: 'from-blue-50/50 via-indigo-50/40 to-violet-50/50', border: 'border-blue-200/60', shadow: 'shadow-blue-500' },
  pokemon: { name: '宝可梦', emoji: '⚡', gradient: 'from-yellow-50/50 via-orange-50/40 to-red-50/50', border: 'border-yellow-200/60', shadow: 'shadow-yellow-500' },
};

const categoryCounts = categories.map(cat => ({
  ...cat,
  count: allPosts.filter(post => post.data.category === cat.slug).length
}));

const allTags = [...new Set(allPosts.flatMap(post => post.data.tags || []))];
---

<Layout title="首页 | 我的博客">
  <div class="xl:flex xl:gap-8">
    <main class="flex-1">
      <!-- Hero Section - 小黑风格：纯净留白，简洁线条 -->
      <section class="mb-16 relative">
        <!-- 手绘风格装饰线 -->
        <div class="absolute -top-4 left-1/2 -translate-x-1/2 w-32 h-0.5 bg-cyan-400 opacity-40"></div>

        <div class="flex flex-col md:flex-row items-center gap-10 py-8">
          <!-- Logo -->
          <div class="relative">
            <div class="w-28 h-28 rounded-2xl bg-gradient-to-br from-cyan-500 to-cyan-600 flex items-center justify-center text-5xl font-['Cormorant_Garamond'] text-white shadow-lg shadow-cyan-500/20 flex-shrink-0">
              <span>M</span>
            </div>
            <!-- 小黑风格注释 -->
            <span class="absolute -top-2 -right-4 text-xs text-cyan-500 font-medium rotate-12">logo</span>
          </div>

          <div class="text-center md:text-left">
            <h1 class="text-3xl md:text-4xl font-['Cormorant_Garamond'] font-semibold mb-3 tracking-tight">
              <span class="text-gray-800">你好，欢迎来访</span>
            </h1>
            <p class="text-gray-500 mb-5 max-w-xl leading-relaxed">
              在这里记录生活的点滴，分享关于音乐、读书、电商运营和宝可梦的思考
            </p>
            <!-- 小黑风格标签 -->
            <div class="flex flex-wrap gap-2 justify-center md:justify-start">
              {allTags.slice(0, 8).map((tag) => (
                <span class="px-3 py-1 text-sm text-cyan-600 bg-cyan-50 border border-cyan-200 rounded-full hover:bg-cyan-100 transition-colors cursor-default">
                  #{tag}
                </span>
              ))}
            </div>
          </div>
        </div>

        <!-- 底部装饰线 -->
        <div class="absolute -bottom-4 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gray-200 to-transparent"></div>
      </section>

      <!-- Categories - 小黑风格：简洁卡片 -->
      <section class="mb-16">
        <h2 class="text-xs font-medium text-gray-400 uppercase tracking-widest mb-6 flex items-center gap-3">
          <span class="h-px flex-1 bg-gray-200"></span>
          <span class="px-4 text-gray-500">探索分类</span>
          <span class="h-px flex-1 bg-gray-200"></span>
        </h2>
        <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
          {categoryCounts.map((cat, index) => (
            <a
              href={`${BASE}/category/${cat.slug}`}
              class="group p-6 rounded-2xl border border-gray-200 bg-white hover:border-cyan-300 hover:shadow-lg hover:shadow-cyan-100 transition-all duration-300"
              style={`animation-delay: ${index * 0.05}s;`}
            >
              <span class="text-3xl mb-3 block">{cat.icon}</span>
              <div class="font-medium text-gray-700 text-sm group-hover:text-cyan-600 transition-colors">{cat.name}</div>
              <div class="text-xs text-gray-400 mt-1">{cat.count} 篇</div>
            </a>
          ))}
        </div>
      </section>

      <!-- Latest Posts - 小黑风格：干净利落 -->
      <section>
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-xs font-medium text-gray-400 uppercase tracking-widest flex items-center gap-3">
            <span class="w-6 h-px bg-cyan-400"></span>
            最新文章
          </h2>
          <div class="flex gap-2">
            <button id="layout-list" class="p-2 rounded-lg hover:bg-gray-100 border border-transparent hover:border-gray-200 transition-all" title="列表布局">
              <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
              </svg>
            </button>
            <button id="layout-grid" class="p-2 rounded-lg hover:bg-gray-100 border border-transparent hover:border-gray-200 transition-all" title="网格布局">
              <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
              </svg>
            </button>
          </div>
        </div>

        <!-- List Layout -->
        <div id="posts-list" class="space-y-4">
          {posts.length > 0 ? (
            posts.map((post, index) => {
              const cat = categoryInfo[post.data.category] || categoryInfo.daily;
              return (
              <article class="group animate-fade-in-up" style={`animation-delay: ${index * 0.05}s;`}>
                <a
                  href={`${BASE}/post/${post.id}`}
                  class="group block p-6 rounded-2xl border border-gray-100 bg-white hover:border-cyan-200 hover:shadow-lg transition-all duration-300"
                >
                  <div class="flex items-start gap-4">
                    <!-- Category indicator -->
                    <div class="flex-shrink-0 w-10 h-10 rounded-xl bg-gray-50 border border-gray-100 flex items-center justify-center text-xl">
                      {cat.emoji}
                    </div>

                    <div class="flex-1 min-w-0">
                      <div class="flex flex-wrap items-center gap-3 mb-2">
                        <span class="text-xs text-gray-400">{post.data.published.toLocaleDateString('zh-CN')}</span>
                        <span class="flex items-center gap-1 text-xs text-gray-400">
                          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                          </svg>
                          {post.readingTime} 分钟
                        </span>
                        <span class="px-2 py-0.5 text-xs rounded-full bg-cyan-50 text-cyan-600 border border-cyan-100">
                          {cat.name}
                        </span>
                      </div>

                      <h3 class="text-lg font-medium text-gray-800 group-hover:text-cyan-600 transition-colors mb-2 line-clamp-1">
                        {post.data.title}
                      </h3>

                      <p class="text-sm text-gray-500 line-clamp-2 leading-relaxed">{post.body.slice(0, 120)}...</p>

                      {post.data.tags && post.data.tags.length > 0 && (
                        <div class="flex gap-2 mt-3">
                          {post.data.tags.slice(0, 4).map((tag) => (
                            <span class="px-2 py-0.5 text-xs rounded-full bg-gray-50 text-gray-500 border border-gray-100">
                              #{tag}
                            </span>
                          ))}
                        </div>
                      )}
                    </div>

                    <!-- Arrow -->
                    <div class="flex-shrink-0 opacity-0 group-hover:opacity-100 transition-opacity">
                      <svg class="w-5 h-5 text-cyan-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                      </svg>
                    </div>
                  </div>
                </a>
              </article>
              );
            })
          ) : (
            <div class="text-center py-20">
              <div class="text-5xl mb-4 opacity-20">📝</div>
              <p class="text-gray-400">暂无文章</p>
            </div>
          )}
        </div>

        <!-- Grid Layout -->
        <div id="posts-grid" class="hidden grid grid-cols-1 md:grid-cols-2 gap-4">
          {posts.length > 0 ? (
            posts.map((post, index) => {
              const cat = categoryInfo[post.data.category] || categoryInfo.daily;
              return (
              <article class="group animate-fade-in-up" style={`animation-delay: ${index * 0.05}s;`}>
                <a
                  href={`${BASE}/post/${post.id}`}
                  class="group block p-6 rounded-2xl border border-gray-100 bg-white hover:border-cyan-200 hover:shadow-lg transition-all duration-300 h-full"
                >
                  <div class="flex items-center gap-3 mb-4">
                    <span class="text-2xl">{cat.emoji}</span>
                    <span class="px-2 py-0.5 text-xs rounded-full bg-cyan-50 text-cyan-600 border border-cyan-100">
                      {cat.name}
                    </span>
                    <span class="text-xs text-gray-400">{post.data.published.toLocaleDateString('zh-CN')}</span>
                  </div>

                  <h3 class="text-base font-medium text-gray-800 group-hover:text-cyan-600 transition-colors mb-2 line-clamp-2">
                    {post.data.title}
                  </h3>

                  <p class="text-sm text-gray-500 line-clamp-3 leading-relaxed">{post.body.slice(0, 100)}...</p>

                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-1.5 mt-4">
                      {post.data.tags.slice(0, 3).map((tag) => (
                        <span class="px-2 py-0.5 text-xs rounded-full bg-gray-50 text-gray-500 border border-gray-100">
                          #{tag}
                        </span>
                      ))}
                    </div>
                  )}
                </a>
              </article>
              );
            })
          ) : (
            <div class="col-span-2 text-center py-20">
              <div class="text-5xl mb-4 opacity-20">📝</div>
              <p class="text-gray-400">暂无文章</p>
            </div>
          )}
        </div>
      </section>
    </main>

    <Sidebar />
  </div>

  <script>
    function initLayoutToggle() {
      const listBtn = document.getElementById('layout-list');
      const gridBtn = document.getElementById('layout-grid');
      const listView = document.getElementById('posts-list');
      const gridView = document.getElementById('posts-grid');

      if (!listBtn || !gridBtn || !listView || !gridView) return;

      const savedLayout = localStorage.getItem('posts-layout') || 'list';

      function setLayout(layout: string) {
        if (layout === 'grid') {
          listView.classList.add('hidden');
          gridView.classList.remove('hidden');
          gridBtn.classList.add('bg-cyan-100', 'text-cyan-700', 'border-cyan-200');
          listBtn.classList.remove('bg-cyan-100', 'text-cyan-700', 'border-cyan-200');
        } else {
          listView.classList.remove('hidden');
          gridView.classList.add('hidden');
          listBtn.classList.add('bg-cyan-100', 'text-cyan-700', 'border-cyan-200');
          gridBtn.classList.remove('bg-cyan-100', 'text-cyan-700', 'border-cyan-200');
        }
        localStorage.setItem('posts-layout', layout);
      }

      listBtn.addEventListener('click', () => setLayout('list'));
      gridBtn.addEventListener('click', () => setLayout('grid'));

      setLayout(savedLayout);
    }

    initLayoutToggle();
    document.addEventListener('astro:after-swap', initLayoutToggle);
  </script>

  <style>
    @keyframes fade-in-up {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .animate-fade-in-up {
      opacity: 0;
      animation: fade-in-up 0.5s ease-out forwards;
    }
  </style>
</Layout>
