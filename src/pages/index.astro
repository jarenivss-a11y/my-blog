---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import Sidebar from '../components/Sidebar.astro';

const BASE = '/my-blog';

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.published.getTime() - a.data.published.getTime())
  .slice(0, 10)
  .map(post => ({...post, readingTime: Math.max(1, Math.ceil(post.body.split(/\s+/).length / 400))}));

const categories = [
  { name: '日常生活', slug: 'daily', icon: '🏠' },
  { name: '音乐分析', slug: 'music', icon: '🎵' },
  { name: '读书鉴赏', slug: 'books', icon: '📚' },
  { name: '电商运营', slug: 'ecommerce', icon: '🛒' },
  { name: '宝可梦', slug: 'pokemon', icon: '⚡' },
];

const categoryInfo: Record<string, { name: string; emoji: string; gradient: string; border: string; shadow: string }> = {
  daily: { name: '日常生活', emoji: '🏠', gradient: 'from-amber-50/50 via-orange-50/40 to-yellow-50/50', border: 'border-amber-200/60', shadow: 'shadow-amber-500' },
  music: { name: '音乐分析', emoji: '🎵', gradient: 'from-pink-50/50 via-purple-50/40 to-fuchsia-50/50', border: 'border-pink-200/60', shadow: 'shadow-pink-500' },
  books: { name: '读书鉴赏', emoji: '📚', gradient: 'from-emerald-50/50 via-green-50/40 to-teal-50/50', border: 'border-emerald-200/60', shadow: 'shadow-emerald-500' },
  ecommerce: { name: '电商运营', emoji: '🛒', gradient: 'from-blue-50/50 via-indigo-50/40 to-violet-50/50', border: 'border-blue-200/60', shadow: 'shadow-blue-500' },
  pokemon: { name: '宝可梦', emoji: '⚡', gradient: 'from-yellow-50/50 via-orange-50/40 to-red-50/50', border: 'border-yellow-200/60', shadow: 'shadow-yellow-500' },
};

const categoryCounts = categories.map(cat => ({
  ...cat,
  count: allPosts.filter(post => post.data.category === cat.slug).length
}));

const allTags = [...new Set(allPosts.flatMap(post => post.data.tags || []))];
---

<Layout title="首页 | 我的博客">
  <div class="xl:flex xl:gap-8">
    <main class="flex-1">
      <!-- Hero Section - InternalBeyond Style -->
      <section class="mb-16 p-8 rounded-3xl backdrop-blur-2xl bg-[rgba(155,180,218,0.08)] border border-[rgba(165,188,230,0.2)] shadow-[0_8px_32px_rgba(0,0,0,0.18)] relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-[rgba(114,144,180,0.15)] via-transparent to-[rgba(80,128,176,0.1)] pointer-events-none"></div>
        <div class="absolute top-4 right-8 text-8xl opacity-[0.06]">✦</div>
        <div class="flex flex-col md:flex-row items-center gap-8 relative z-10">
          <div class="w-28 h-28 rounded-full bg-gradient-to-br from-[#5080b0] via-[#72a8d8] to-[#8895b4] flex items-center justify-center text-5xl font-['Cormorant_Garamond'] text-white shadow-[0_0_30px_rgba(80,128,176,0.4),0_0_60px_rgba(80,128,176,0.2)] flex-shrink-0">
            M
          </div>

          <div class="text-center md:text-left">
            <h1 class="text-3xl md:text-4xl font-['Cormorant_Garamond'] font-semibold text-[#e2e9f5] mb-3 tracking-tight">
              你好，欢迎来访
            </h1>
            <p class="text-lg text-[#b2c0d8] mb-4 max-w-xl">
              在这里记录生活的点滴，分享关于音乐、读书、电商运营和宝可梦的思考
            </p>
            <div class="flex flex-wrap gap-2 justify-center md:justify-start">
              {allTags.slice(0, 8).map((tag) => (
                <span class="px-3 py-1 text-xs rounded-full bg-teal-500/20 text-teal-700 dark:bg-teal-400/30 dark:text-teal-300">
                  #{tag}
                </span>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- Categories -->
      <section class="mb-16">
        <h2 class="text-xs font-medium text-slate-400 uppercase tracking-widest mb-6">探索分类</h2>
        <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
          {categoryCounts.map((cat) => (
            <a
              href={`${BASE}/category/${cat.slug}`}
              class="group relative p-6 rounded-2xl backdrop-blur-2xl bg-[rgba(155,180,218,0.08)] border border-[rgba(165,188,230,0.2)] shadow-[0_8px_32px_rgba(0,0,0,0.18)] hover:shadow-[0_8px_48px_rgba(80,128,176,0.25)] hover:border-[rgba(165,188,230,0.35)] transition-all duration-300 overflow-hidden"
            >
              <div class="absolute inset-0 bg-gradient-to-br from-[rgba(114,144,180,0.1)] via-transparent to-[rgba(80,128,176,0.08)] pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
              <span class="text-3xl mb-3 block">{cat.icon}</span>
              <div class="font-medium text-[#e0e6f2] text-sm group-hover:text-[#72a8d8] transition-colors">{cat.name}</div>
              <div class="text-xs text-[#8a9cc4] mt-1">{cat.count} 篇</div>
            </a>
          ))}
        </div>
      </section>

      <!-- Latest Posts -->
      <section>
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-xs font-medium text-slate-400 uppercase tracking-widest">最新文章</h2>
          <div class="flex gap-2">
            <button id="layout-list" class="p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors" title="列表布局">
              <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
              </svg>
            </button>
            <button id="layout-grid" class="p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors" title="网格布局">
              <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
              </svg>
            </button>
          </div>
        </div>

        <!-- List Layout -->
        <div id="posts-list" class="space-y-4">
          {posts.length > 0 ? (
            posts.map((post) => {
              const cat = categoryInfo[post.data.category] || categoryInfo.daily;
              return (
              <article class="group">
                <a
                  href={`${BASE}/post/${post.id}`}
                  class="group block p-6 rounded-2xl backdrop-blur-2xl bg-[rgba(155,180,218,0.08)] border border-[rgba(165,188,230,0.2)] shadow-[0_8px_32px_rgba(0,0,0,0.18)] hover:shadow-[0_8px_48px_rgba(80,128,176,0.25)] hover:border-[rgba(165,188,230,0.35)] transition-all duration-500 relative overflow-hidden"
                >
                  <div class="absolute inset-0 bg-gradient-to-br from-[rgba(114,144,180,0.12)] via-transparent to-[rgba(80,128,176,0.1)] pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                  <div class="absolute -top-2 -right-2 text-4xl opacity-20 group-hover:opacity-40 transition-opacity">{cat.emoji}</div>
                  <div class="flex items-center gap-3 mb-3 relative z-10">
                    <span class="text-xs text-[#8a9cc4]">{post.data.published.toLocaleDateString('zh-CN')}</span>
                    <span class="flex items-center gap-1 text-xs text-[#8a9cc4]">
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                      </svg>
                      {post.readingTime} 分钟
                    </span>
                    <span class="px-2 py-0.5 text-xs rounded-full bg-[rgba(80,128,176,0.2)] text-[#72a8d8]">
                      {cat.name}
                    </span>
                  </div>
                  <h3 class="text-lg font-serif font-semibold text-[#e0e6f2] group-hover:text-[#72a8d8] transition-colors mb-2 relative z-10">
                    {post.data.title}
                  </h3>
                  <p class="text-sm text-[#8a9cc4] line-clamp-2 relative z-10">{post.body.slice(0, 120)}...</p>
                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class="flex gap-2 mt-3 relative z-10">
                      {post.data.tags.slice(0, 3).map((tag) => (
                        <span class="px-2 py-0.5 text-xs bg-[rgba(80,128,176,0.15)] text-[#72a8d8] rounded">
                          #{tag}
                        </span>
                      ))}
                    </div>
                  )}
                </a>
              </article>
              );
            })
          ) : (
            <div class="text-center py-16">
              <p class="text-[#8a9cc4]">暂无文章</p>
            </div>
          )}
        </div>

        <!-- Grid Layout -->
        <div id="posts-grid" class="hidden grid grid-cols-1 md:grid-cols-2 gap-4">
          {posts.length > 0 ? (
            posts.map((post) => {
              const cat = categoryInfo[post.data.category] || categoryInfo.daily;
              return (
              <article class="group">
                <a
                  href={`${BASE}/post/${post.id}`}
                  class="group block p-6 rounded-2xl backdrop-blur-2xl bg-[rgba(155,180,218,0.08)] border border-[rgba(165,188,230,0.2)] shadow-[0_8px_32px_rgba(0,0,0,0.18)] hover:shadow-[0_8px_48px_rgba(80,128,176,0.25)] hover:border-[rgba(165,188,230,0.35)] transition-all duration-500 h-full relative overflow-hidden"
                >
                  <div class="absolute inset-0 bg-gradient-to-br from-[rgba(114,144,180,0.12)] via-transparent to-[rgba(80,128,176,0.1)] pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                  <div class="absolute -top-2 -right-2 text-4xl opacity-20 group-hover:opacity-40 transition-opacity">{cat.emoji}</div>
                  <div class="flex items-center gap-3 mb-3 relative z-10">
                    <span class="px-2 py-0.5 text-xs rounded-full bg-[rgba(80,128,176,0.2)] text-[#72a8d8]">
                      {cat.name}
                    </span>
                    <span class="text-xs text-[#8a9cc4]">{post.data.published.toLocaleDateString('zh-CN')}</span>
                    <span class="flex items-center gap-1 text-xs text-[#8a9cc4]">
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                      </svg>
                      {post.readingTime} 分钟
                    </span>
                  </div>
                  <h3 class="text-lg font-serif font-semibold text-[#e0e6f2] group-hover:text-[#72a8d8] transition-colors mb-2 line-clamp-2 relative z-10">
                    {post.data.title}
                  </h3>
                  <p class="text-sm text-[#8a9cc4] line-clamp-3 relative z-10">{post.body.slice(0, 100)}...</p>
                </a>
              </article>
              );
            })
          ) : (
            <div class="col-span-2 text-center py-16">
              <p class="text-[#8a9cc4]">暂无文章</p>
            </div>
          )}
        </div>
      </section>
    </main>

    <Sidebar />
  </div>

  <script>
    function initLayoutToggle() {
      const listBtn = document.getElementById('layout-list');
      const gridBtn = document.getElementById('layout-grid');
      const listView = document.getElementById('posts-list');
      const gridView = document.getElementById('posts-grid');

      if (!listBtn || !gridBtn || !listView || !gridView) return;

      const savedLayout = localStorage.getItem('posts-layout') || 'list';

      function setLayout(layout: string) {
        if (layout === 'grid') {
          listView.classList.add('hidden');
          gridView.classList.remove('hidden');
          gridBtn.classList.add('bg-primary', 'text-primary');
          listBtn.classList.remove('bg-primary', 'text-primary');
        } else {
          listView.classList.remove('hidden');
          gridView.classList.add('hidden');
          listBtn.classList.add('bg-primary', 'text-primary');
          gridBtn.classList.remove('bg-primary', 'text-primary');
        }
        localStorage.setItem('posts-layout', layout);
      }

      listBtn.addEventListener('click', () => setLayout('list'));
      gridBtn.addEventListener('click', () => setLayout('grid'));

      setLayout(savedLayout);
    }

    initLayoutToggle();
    document.addEventListener('astro:after-swap', initLayoutToggle);
  </script>
</Layout>