---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const BASE = '/my-blog';

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.published.getTime() - a.data.published.getTime())
  .slice(0, 10);

const categories = [
  { name: '日常生活', slug: 'daily', icon: '🏠' },
  { name: '音乐分析', slug: 'music', icon: '🎵' },
  { name: '读书鉴赏', slug: 'books', icon: '📚' },
  { name: '电商运营', slug: 'ecommerce', icon: '🛒' },
  { name: '宝可梦', slug: 'pokemon', icon: '⚡' },
];

const categoryInfo: Record<string, { name: string }> = {
  daily: { name: '日常生活' },
  music: { name: '音乐分析' },
  books: { name: '读书鉴赏' },
  ecommerce: { name: '电商运营' },
  pokemon: { name: '宝可梦' },
};

const categoryCounts = categories.map(cat => ({
  ...cat,
  count: allPosts.filter(post => post.data.category === cat.slug).length
}));
---

<Layout title="首页 | 我的博客">
  <div class="p-8">
    <!-- Hero -->
    <section class="mb-12">
      <h1 class="text-4xl font-bold text-gray-900 mb-4">你好，欢迎来到我的博客</h1>
      <p class="text-lg text-gray-600">记录生活点滴，分享兴趣爱好</p>
    </section>

    <!-- Categories Overview -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">分类</h2>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
        {categoryCounts.map((cat) => (
          <a
            href={`${BASE}/category/${cat.slug}`}
            class="bg-white rounded-xl border border-gray-200 p-6 hover:shadow-lg hover:border-indigo-300 transition-all"
          >
            <div class="text-3xl mb-3">{cat.icon}</div>
            <div class="font-medium text-gray-900">{cat.name}</div>
            <div class="text-sm text-gray-500">{cat.count} 篇文章</div>
          </a>
        ))}
      </div>
    </section>

    <!-- Recent Posts -->
    <section>
      <h2 class="text-2xl font-bold text-gray-900 mb-6">最新文章</h2>
      <div class="space-y-4">
        {posts.length > 0 ? (
          posts.map((post) => (
            <article class="bg-white rounded-xl border border-gray-200 p-6 hover:shadow-md transition-shadow">
              <div class="flex items-center gap-3 text-sm text-gray-500 mb-3">
                <span class="bg-gray-100 px-2 py-1 rounded">
                  {categoryInfo[post.data.category]?.name || '未知'}
                </span>
                <span>{post.data.published.toLocaleDateString('zh-CN')}</span>
              </div>
              <h3 class="text-xl font-bold text-gray-900 mb-2">
                <a href={`${BASE}/post/${post.id}`} class="hover:text-indigo-600 transition-colors">
                  {post.data.title}
                </a>
              </h3>
              <p class="text-gray-600 line-clamp-2">{post.body.slice(0, 150)}...</p>
            </article>
          ))
        ) : (
          <div class="bg-white rounded-xl border border-gray-200 p-12 text-center">
            <p class="text-gray-500">暂无文章</p>
          </div>
        )}
      </div>
    </section>
  </div>
</Layout>