---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import Sidebar from '../components/Sidebar.astro';

const BASE = '/my-blog';

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.published.getTime() - a.data.published.getTime())
  .slice(0, 10)
  .map(post => ({...post, readingTime: Math.max(1, Math.ceil(post.body.split(/\s+/).length / 400))}));

const categories = [
  { name: '日常生活', slug: 'daily', icon: '🏠' },
  { name: '音乐分析', slug: 'music', icon: '🎵' },
  { name: '读书鉴赏', slug: 'books', icon: '📚' },
  { name: '电商运营', slug: 'ecommerce', icon: '🛒' },
  { name: '宝可梦', slug: 'pokemon', icon: '⚡' },
];

const categoryInfo: Record<string, { name: string; emoji: string; gradient: string; border: string; shadow: string }> = {
  daily: { name: '日常生活', emoji: '🏠', gradient: 'from-amber-50/50 via-orange-50/40 to-yellow-50/50', border: 'border-amber-200/60', shadow: 'shadow-amber-500' },
  music: { name: '音乐分析', emoji: '🎵', gradient: 'from-pink-50/50 via-purple-50/40 to-fuchsia-50/50', border: 'border-pink-200/60', shadow: 'shadow-pink-500' },
  books: { name: '读书鉴赏', emoji: '📚', gradient: 'from-emerald-50/50 via-green-50/40 to-teal-50/50', border: 'border-emerald-200/60', shadow: 'shadow-emerald-500' },
  ecommerce: { name: '电商运营', emoji: '🛒', gradient: 'from-blue-50/50 via-indigo-50/40 to-violet-50/50', border: 'border-blue-200/60', shadow: 'shadow-blue-500' },
  pokemon: { name: '宝可梦', emoji: '⚡', gradient: 'from-yellow-50/50 via-orange-50/40 to-red-50/50', border: 'border-yellow-200/60', shadow: 'shadow-yellow-500' },
};

const categoryCounts = categories.map(cat => ({
  ...cat,
  count: allPosts.filter(post => post.data.category === cat.slug).length
}));

const allTags = [...new Set(allPosts.flatMap(post => post.data.tags || []))];
---

<Layout title="首页 | 我的博客">
  <div class="xl:flex xl:gap-8">
    <main class="flex-1">
      <!-- Hero Section - Enhanced Glass Morphism -->
      <section class="mb-16 p-10 rounded-3xl backdrop-blur-2xl bg-[rgba(155,180,218,0.06)] border border-[rgba(165,188,230,0.15)] shadow-[0_8px_40px_rgba(0,0,0,0.2),inset_0_1px_0_rgba(255,255,255,0.05)] relative overflow-hidden">
        <!-- Animated gradient border -->
        <div class="absolute inset-0 rounded-3xl p-px bg-gradient-to-br from-[rgba(80,128,176,0.4)] via-[rgba(114,168,216,0.2)] to-[rgba(80,128,176,0.3)] opacity-60">
          <div class="absolute inset-0 rounded-3xl bg-[rgba(20,30,50,0.8)] -z-10"></div>
        </div>

        <!-- Animated background gradient -->
        <div class="absolute inset-0 bg-gradient-to-br from-[rgba(80,128,176,0.12)] via-transparent to-[rgba(114,168,216,0.08)] pointer-events-none animate-pulse-slow"></div>

        <!-- Enhanced floating particles -->
        <div class="absolute inset-0 overflow-hidden pointer-events-none">
          <div class="particle absolute w-1 h-1 rounded-full bg-[rgba(114,168,216,0.7)] animate-float-up" style="left: 10%; animation-delay: 0s;"></div>
          <div class="particle absolute w-1.5 h-1.5 rounded-full bg-[rgba(80,128,176,0.5)] animate-float-up" style="left: 25%; animation-delay: 1s;"></div>
          <div class="particle absolute w-1 h-1 rounded-full bg-[rgba(114,168,216,0.6)] animate-float-up" style="left: 45%; animation-delay: 2s;"></div>
          <div class="particle absolute w-2 h-2 rounded-full bg-[rgba(80,128,176,0.4)] animate-float-up" style="left: 65%; animation-delay: 0.5s;"></div>
          <div class="particle absolute w-1 h-1 rounded-full bg-[rgba(114,168,216,0.5)] animate-float-up" style="left: 80%; animation-delay: 1.5s;"></div>
          <div class="particle absolute w-1.5 h-1.5 rounded-full bg-[rgba(80,128,176,0.6)] animate-float-up" style="left: 90%; animation-delay: 2.5s;"></div>
          <div class="particle absolute w-0.5 h-0.5 rounded-full bg-white/40 animate-float-up" style="left: 35%; animation-delay: 0.8s;"></div>
          <div class="particle absolute w-0.5 h-0.5 rounded-full bg-white/30 animate-float-up" style="left: 55%; animation-delay: 1.8s;"></div>
        </div>

        <!-- Decorative glow orbs -->
        <div class="absolute -top-20 -right-20 w-40 h-40 rounded-full bg-[rgba(80,128,176,0.18)] blur-3xl animate-pulse"></div>
        <div class="absolute -bottom-10 -left-10 w-32 h-32 rounded-full bg-[rgba(114,168,216,0.12)] blur-2xl animate-pulse" style="animation-delay: 1s;"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-64 h-64 rounded-full bg-[rgba(80,128,176,0.05)] blur-3xl"></div>

        <div class="absolute top-4 right-8 text-8xl opacity-[0.04] select-none animate-pulse-subtle">✦</div>

        <div class="flex flex-col md:flex-row items-center gap-10 relative z-10">
          <div class="relative">
            <!-- Outer ring with gradient -->
            <div class="absolute inset-0 rounded-full bg-gradient-to-br from-[rgba(80,128,176,0.6)] to-transparent blur-xl animate-pulse-subtle"></div>
            <div class="w-32 h-32 rounded-full bg-gradient-to-br from-[#5080b0] via-[#72a8d8] to-[#8895b4] flex items-center justify-center text-6xl font-['Cormorant_Garamond'] text-white shadow-[0_0_40px_rgba(80,128,176,0.5),0_0_80px_rgba(80,128,176,0.25)] flex-shrink-0 animate-glow-pulse">
              <span class="relative z-10">M</span>
              <div class="absolute inset-0 rounded-full bg-gradient-to-br from-[#5080b0] via-[#72a8d8] to-[#8895b4] animate-spin-slow"></div>
            </div>
            <div class="absolute -inset-2 rounded-full border border-[rgba(80,128,176,0.3)] animate-ping opacity-20"></div>
            <!-- Second ring -->
            <div class="absolute -inset-4 rounded-full border border-[rgba(80,128,176,0.15)] animate-ping opacity-10" style="animation-delay: 0.5s;"></div>
          </div>

          <div class="text-center md:text-left">
            <h1 class="text-4xl md:text-5xl font-['Cormorant_Garamond'] font-semibold mb-4 tracking-tight animate-fade-in-up">
              <span class="bg-gradient-to-r from-[#e2e9f5] via-[#8ac4e8] to-[#b2c0d8] bg-clip-text text-transparent">你好，欢迎来访</span>
            </h1>
            <p class="text-lg text-[#b2c0d8] mb-5 max-w-xl leading-relaxed animate-fade-in-up" style="animation-delay: 0.1s;">
              在这里记录生活的点滴，分享关于音乐、读书、电商运营和宝可梦的思考
            </p>
            <div class="flex flex-wrap gap-3 justify-center md:justify-start animate-fade-in-up" style="animation-delay: 0.2s;">
              {allTags.slice(0, 8).map((tag) => (
                <span class="group px-4 py-1.5 text-sm rounded-full bg-[rgba(80,128,176,0.12)] border border-[rgba(80,128,176,0.2)] text-[#72a8d8] hover:bg-[rgba(80,128,176,0.22)] hover:border-[rgba(80,128,176,0.35)] hover:shadow-[0_0_15px_rgba(80,128,176,0.3)] transition-all duration-300 cursor-default">
                  #{tag}
                </span>
              ))}
            </div>
          </div>
        </div>
      </section>

      <style>
        @keyframes float-up {
          0% { transform: translateY(100vh) scale(0); opacity: 0; }
          10% { opacity: 1; }
          90% { opacity: 1; }
          100% { transform: translateY(-20vh) scale(1); opacity: 0; }
        }
        @keyframes glow-pulse {
          0%, 100% { box-shadow: 0 0 40px rgba(80,128,176,0.5), 0 0 80px rgba(80,128,176,0.25); }
          50% { box-shadow: 0 0 60px rgba(80,128,176,0.6), 0 0 100px rgba(80,128,176,0.35); }
        }
        @keyframes spin-slow {
          from { transform: rotate(0deg); }
          to { transform: rotate(360deg); }
        }
        @keyframes fade-in-up {
          from { opacity: 0; transform: translateY(20px); }
          to { opacity: 1; transform: translateY(0); }
        }
        @keyframes pulse-slow {
          0%, 100% { opacity: 0.5; }
          50% { opacity: 0.8; }
        }
        .particle { animation: float-up 15s linear infinite; }
        .animate-glow-pulse { animation: glow-pulse 3s ease-in-out infinite; }
        .animate-spin-slow { animation: spin-slow 20s linear infinite; }
        .animate-fade-in-up { animation: fade-in-up 0.8s ease-out forwards; }
        .animate-pulse-slow { animation: pulse-slow 4s ease-in-out infinite; }
      </style>

      <!-- Categories -->
      <section class="mb-16">
        <h2 class="text-xs font-medium text-[#8a9cc4] uppercase tracking-widest mb-6 flex items-center gap-3">
          <span class="h-px flex-1 bg-gradient-to-r from-transparent via-[rgba(80,128,176,0.3)] to-transparent"></span>
          <span class="px-4">探索分类</span>
          <span class="h-px flex-1 bg-gradient-to-r from-transparent via-[rgba(80,128,176,0.3)] to-transparent"></span>
        </h2>
        <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
          {categoryCounts.map((cat, index) => (
            <a
              href={`${BASE}/category/${cat.slug}`}
              class="group relative p-6 rounded-2xl backdrop-blur-2xl bg-[rgba(155,180,218,0.05)] border border-[rgba(165,188,230,0.15)] shadow-[0_8px_32px_rgba(0,0,0,0.15)] hover:shadow-[0_8px_48px_rgba(80,128,176,0.3)] hover:border-[rgba(80,128,176,0.4)] transition-all duration-500 overflow-hidden animate-fade-in-up"
              style={`animation-delay: ${index * 0.1}s;`}
            >
              <div class="absolute inset-0 bg-gradient-to-br from-[rgba(80,128,176,0.15)] via-transparent to-[rgba(114,168,216,0.1)] pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

              <!-- Shimmer effect -->
              <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-700">
                <div class="absolute inset-0 -translate-x-full group-hover:translate-x-full transition-transform duration-1000 bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>
              </div>

              <!-- Glow effect on hover -->
              <div class="absolute -inset-px rounded-2xl bg-gradient-to-br from-[rgba(80,128,176,0.3)] to-[rgba(114,168,216,0.2)] opacity-0 group-hover:opacity-100 transition-opacity duration-500 -z-10 blur-sm"></div>

              <span class="text-4xl mb-4 block transform group-hover:scale-110 group-hover:rotate-3 transition-all duration-300">{cat.icon}</span>
              <div class="font-medium text-[#e0e6f2] text-sm group-hover:text-[#72a8d8] transition-colors duration-300">{cat.name}</div>
              <div class="text-xs text-[#8a9cc4] mt-2 group-hover:text-[#a0b8d8] transition-colors">{cat.count} 篇</div>

              <!-- Arrow indicator -->
              <div class="absolute bottom-4 right-4 opacity-0 group-hover:opacity-100 transition-all duration-300 transform translate-x-2 group-hover:translate-x-0">
                <svg class="w-4 h-4 text-[#72a8d8]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </div>
            </a>
          ))}
        </div>
      </section>

      <!-- Latest Posts -->
      <section>
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-xs font-medium text-[#8a9cc4] uppercase tracking-widest flex items-center gap-3">
            <span class="h-px w-8 bg-gradient-to-r from-[rgba(80,128,176,0.5)] to-transparent"></span>
            最新文章
          </h2>
          <div class="flex gap-2">
            <button id="layout-list" class="p-2.5 rounded-xl hover:bg-[rgba(80,128,176,0.15)] border border-transparent hover:border-[rgba(80,128,176,0.2)] transition-all duration-300" title="列表布局">
              <svg class="w-4 h-4 text-[#8a9cc4]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
              </svg>
            </button>
            <button id="layout-grid" class="p-2.5 rounded-xl hover:bg-[rgba(80,128,176,0.15)] border border-transparent hover:border-[rgba(80,128,176,0.2)] transition-all duration-300" title="网格布局">
              <svg class="w-4 h-4 text-[#8a9cc4]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
              </svg>
            </button>
          </div>
        </div>

        <!-- List Layout -->
        <div id="posts-list" class="space-y-5">
          {posts.length > 0 ? (
            posts.map((post, index) => {
              const cat = categoryInfo[post.data.category] || categoryInfo.daily;
              return (
              <article class="group animate-fade-in-up" style={`animation-delay: ${index * 0.08}s;`}>
                <a
                  href={`${BASE}/post/${post.id}`}
                  class="group block p-7 rounded-2xl backdrop-blur-2xl bg-[rgba(155,180,218,0.04)] border border-[rgba(165,188,230,0.12)] shadow-[0_8px_32px_rgba(0,0,0,0.12)] hover:shadow-[0_12px_60px_rgba(80,128,176,0.25)] hover:border-[rgba(80,128,176,0.35)] transition-all duration-500 relative overflow-hidden"
                >
                  <div class="absolute inset-0 bg-gradient-to-br from-[rgba(80,128,176,0.1)] via-transparent to-[rgba(114,168,216,0.08)] pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

                  <!-- Left accent bar -->
                  <div class="absolute left-0 top-0 bottom-0 w-1 bg-gradient-to-b from-[#5080b0] via-[#72a8d8] to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-l-2xl"></div>

                  <div class="absolute -top-4 -right-4 text-5xl opacity-15 group-hover:opacity-30 group-hover:scale-110 transition-all duration-500">{cat.emoji}</div>

                  <div class="flex items-center gap-4 mb-4 relative z-10">
                    <span class="text-xs text-[#7a8cb4]">{post.data.published.toLocaleDateString('zh-CN')}</span>
                    <span class="w-1 h-1 rounded-full bg-[rgba(80,128,176,0.4)]"></span>
                    <span class="flex items-center gap-1.5 text-xs text-[#7a8cb4]">
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                      </svg>
                      {post.readingTime} 分钟
                    </span>
                    <span class="w-1 h-1 rounded-full bg-[rgba(80,128,176,0.4)]"></span>
                    <span class="px-3 py-1 text-xs rounded-full bg-[rgba(80,128,176,0.15)] border border-[rgba(80,128,176,0.2)] text-[#72a8d8]">
                      {cat.name}
                    </span>
                  </div>

                  <h3 class="text-xl font-serif font-semibold text-[#e2e9f5] group-hover:text-[#8ac4e8] group-hover:translate-x-1 transition-all duration-300 mb-3 relative z-10">
                    {post.data.title}
                  </h3>

                  <p class="text-sm text-[#8a9cc4] line-clamp-2 leading-relaxed relative z-10">{post.body.slice(0, 150)}...</p>

                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class="flex gap-2 mt-4 relative z-10">
                      {post.data.tags.slice(0, 4).map((tag) => (
                        <span class="px-2.5 py-1 text-xs rounded-full bg-[rgba(80,128,176,0.1)] border border-[rgba(80,128,176,0.15)] text-[#72a8d8] hover:bg-[rgba(80,128,176,0.2)] hover:border-[rgba(80,128,176,0.25)] transition-all duration-200">
                          #{tag}
                        </span>
                      ))}
                    </div>
                  )}

                  <!-- Read more indicator -->
                  <div class="mt-4 flex items-center gap-2 text-xs text-[#5080b0] opacity-0 group-hover:opacity-100 transition-opacity duration-300 relative z-10">
                    <span>阅读更多</span>
                    <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                    </svg>
                  </div>
                </a>
              </article>
              );
            })
          ) : (
            <div class="text-center py-20">
              <div class="text-6xl mb-4 opacity-30">📝</div>
              <p class="text-[#8a9cc4]">暂无文章</p>
            </div>
          )}
        </div>

        <!-- Grid Layout -->
        <div id="posts-grid" class="hidden grid grid-cols-1 md:grid-cols-2 gap-5">
          {posts.length > 0 ? (
            posts.map((post, index) => {
              const cat = categoryInfo[post.data.category] || categoryInfo.daily;
              return (
              <article class="group animate-fade-in-up" style={`animation-delay: ${index * 0.08}s;`}>
                <a
                  href={`${BASE}/post/${post.id}`}
                  class="group block p-7 rounded-2xl backdrop-blur-2xl bg-[rgba(155,180,218,0.04)] border border-[rgba(165,188,230,0.12)] shadow-[0_8px_32px_rgba(0,0,0,0.12)] hover:shadow-[0_12px_60px_rgba(80,128,176,0.25)] hover:border-[rgba(80,128,176,0.35)] transition-all duration-500 h-full relative overflow-hidden"
                >
                  <div class="absolute inset-0 bg-gradient-to-br from-[rgba(80,128,176,0.1)] via-transparent to-[rgba(114,168,216,0.08)] pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

                  <div class="absolute -top-3 -right-3 text-5xl opacity-15 group-hover:opacity-30 group-hover:scale-110 transition-all duration-500">{cat.emoji}</div>

                  <div class="flex flex-wrap items-center gap-3 mb-4 relative z-10">
                    <span class="px-3 py-1 text-xs rounded-full bg-[rgba(80,128,176,0.15)] border border-[rgba(80,128,176,0.2)] text-[#72a8d8]">
                      {cat.name}
                    </span>
                    <span class="text-xs text-[#7a8cb4]">{post.data.published.toLocaleDateString('zh-CN')}</span>
                    <span class="flex items-center gap-1.5 text-xs text-[#7a8cb4]">
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                      </svg>
                      {post.readingTime} 分钟
                    </span>
                  </div>

                  <h3 class="text-lg font-serif font-semibold text-[#e2e9f5] group-hover:text-[#8ac4e8] group-hover:translate-x-1 transition-all duration-300 mb-3 line-clamp-2 relative z-10">
                    {post.data.title}
                  </h3>

                  <p class="text-sm text-[#8a9cc4] line-clamp-3 leading-relaxed relative z-10">{post.body.slice(0, 120)}...</p>

                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-2 mt-4 relative z-10">
                      {post.data.tags.slice(0, 3).map((tag) => (
                        <span class="px-2.5 py-1 text-xs rounded-full bg-[rgba(80,128,176,0.1)] border border-[rgba(80,128,176,0.15)] text-[#72a8d8]">
                          #{tag}
                        </span>
                      ))}
                    </div>
                  )}
                </a>
              </article>
              );
            })
          ) : (
            <div class="col-span-2 text-center py-20">
              <div class="text-6xl mb-4 opacity-30">📝</div>
              <p class="text-[#8a9cc4]">暂无文章</p>
            </div>
          )}
        </div>
      </section>
    </main>

    <Sidebar />
  </div>

  <script>
    function initLayoutToggle() {
      const listBtn = document.getElementById('layout-list');
      const gridBtn = document.getElementById('layout-grid');
      const listView = document.getElementById('posts-list');
      const gridView = document.getElementById('posts-grid');

      if (!listBtn || !gridBtn || !listView || !gridView) return;

      const savedLayout = localStorage.getItem('posts-layout') || 'list';

      function setLayout(layout: string) {
        if (layout === 'grid') {
          listView.classList.add('hidden');
          gridView.classList.remove('hidden');
          gridBtn.classList.add('bg-primary', 'text-primary');
          listBtn.classList.remove('bg-primary', 'text-primary');
        } else {
          listView.classList.remove('hidden');
          gridView.classList.add('hidden');
          listBtn.classList.add('bg-primary', 'text-primary');
          gridBtn.classList.remove('bg-primary', 'text-primary');
        }
        localStorage.setItem('posts-layout', layout);
      }

      listBtn.addEventListener('click', () => setLayout('list'));
      gridBtn.addEventListener('click', () => setLayout('grid'));

      setLayout(savedLayout);
    }

    initLayoutToggle();
    document.addEventListener('astro:after-swap', initLayoutToggle);
  </script>

  <style>
    @keyframes float-up {
      0% { transform: translateY(100vh) scale(0); opacity: 0; }
      10% { opacity: 1; }
      90% { opacity: 0.8; }
      100% { transform: translateY(-20vh) scale(1); opacity: 0; }
    }
    @keyframes fade-in-up {
      from { opacity: 0; transform: translateY(30px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes glow-pulse {
      0%, 100% { box-shadow: 0 0 40px rgba(80,128,176,0.5), 0 0 80px rgba(80,128,176,0.25); }
      50% { box-shadow: 0 0 60px rgba(80,128,176,0.6), 0 0 100px rgba(80,128,176,0.35); }
    }
    @keyframes spin-slow {
      from { transform: rotate(0deg); }
      to { transform: rotate(360deg); }
    }
    @keyframes pulse-subtle {
      0%, 100% { opacity: 0.6; }
      50% { opacity: 0.9; }
    }

    .particle { animation: float-up 18s linear infinite; }
    .animate-glow-pulse { animation: glow-pulse 3s ease-in-out infinite; }
    .animate-spin-slow { animation: spin-slow 25s linear infinite; }
    .animate-fade-in-up {
