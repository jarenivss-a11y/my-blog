---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const BASE = '/my-blog';

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.published.getTime() - a.data.published.getTime())
  .slice(0, 10);

const categories = [
  { name: '日常生活', slug: 'daily', icon: '🏠', color: 'from-rose-400 to-pink-500' },
  { name: '音乐分析', slug: 'music', icon: '🎵', color: 'from-violet-400 to-purple-500' },
  { name: '读书鉴赏', slug: 'books', icon: '📚', color: 'from-amber-400 to-orange-500' },
  { name: '电商运营', slug: 'ecommerce', icon: '🛒', color: 'from-emerald-400 to-teal-500' },
  { name: '宝可梦', slug: 'pokemon', icon: '⚡', color: 'from-blue-400 to-cyan-500' },
];

const categoryInfo: Record<string, { name: string }> = {
  daily: { name: '日常生活' },
  music: { name: '音乐分析' },
  books: { name: '读书鉴赏' },
  ecommerce: { name: '电商运营' },
  pokemon: { name: '宝可梦' },
};

const categoryCounts = categories.map(cat => ({
  ...cat,
  count: allPosts.filter(post => post.data.category === cat.slug).length
}));

const latestPosts = posts.slice(0, 3);
---

<Layout title="首页 | 我的博客">
  <!-- Hero Section -->
  <section class="mb-16 text-center py-12">
    <h1 class="text-5xl font-bold mb-4 bg-gradient-to-r from-indigo-600 via-violet-600 to-purple-600 bg-clip-text text-transparent">
      你好，欢迎来访
    </h1>
    <p class="text-xl text-slate-600 font-light max-w-2xl mx-auto">
      在这里记录生活的点滴，分享关于音乐、读书、电商运营和宝可梦的思考
    </p>
  </section>

  <!-- Categories -->
  <section class="mb-16">
    <h2 class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-6">探索分类</h2>
    <div class="grid grid-cols-1 md:grid-cols-5 gap-4">
      {categoryCounts.map((cat) => (
        <a
          href={`${BASE}/category/${cat.slug}`}
          class="group relative overflow-hidden rounded-2xl p-6 bg-white border border-slate-200/50 hover:border-transparent hover:shadow-xl transition-all duration-300"
        >
          <div class={`absolute inset-0 bg-gradient-to-br ${cat.color} opacity-0 group-hover:opacity-10 transition-opacity duration-300`}></div>
          <div class="relative">
            <span class="text-4xl mb-4 block">{cat.icon}</span>
            <h3 class="font-semibold text-slate-800 mb-1">{cat.name}</h3>
            <p class="text-sm text-slate-500">{cat.count} 篇文章</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Latest Posts -->
  <section>
    <h2 class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-6">最新文章</h2>
    <div class="grid gap-6">
      {posts.length > 0 ? (
        posts.map((post, index) => (
          <article class="group relative bg-white rounded-2xl border border-slate-200/50 p-8 hover:border-indigo-200 hover:shadow-lg hover:shadow-indigo-500/10 transition-all duration-300">
            <div class="flex items-start gap-6">
              <div class={`hidden md:flex w-12 h-12 rounded-xl items-center justify-center text-2xl ${
                index === 0 ? 'bg-gradient-to-br from-indigo-500 to-violet-500 text-white' :
                index === 1 ? 'bg-gradient-to-br from-violet-500 to-purple-500 text-white' :
                'bg-gradient-to-br from-purple-500 to-pink-500 text-white'
              }`}>
                {index === 0 ? '🚀' : index === 1 ? '✨' : '📝'}
              </div>
              <div class="flex-1">
                <div class="flex items-center gap-3 mb-3">
                  <span class="px-3 py-1 rounded-full text-xs font-medium bg-slate-100 text-slate-600">
                    {categoryInfo[post.data.category]?.name || '未知'}
                  </span>
                  <span class="text-sm text-slate-400">{post.data.published.toLocaleDateString('zh-CN')}</span>
                </div>
                <h3 class="text-xl font-semibold text-slate-800 mb-2 group-hover:text-indigo-600 transition-colors">
                  <a href={`${BASE}/post/${post.id}`}>{post.data.title}</a>
                </h3>
                <p class="text-slate-600 line-clamp-2">{post.body.slice(0, 120)}...</p>
                {post.data.tags && (
                  <div class="flex gap-2 mt-4">
                    {post.data.tags.slice(0, 3).map((tag) => (
                      <span class="px-2 py-1 rounded-md text-xs bg-indigo-50 text-indigo-600">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </div>
              <a href={`${BASE}/post/${post.id}`} class="hidden group-hover:flex items-center justify-center w-10 h-10 rounded-full bg-slate-100 text-slate-600 group-hover:bg-indigo-500 group-hover:text-white transition-all duration-300">
                →
              </a>
            </div>
          </article>
        ))
      ) : (
        <div class="bg-white rounded-2xl border border-slate-200/50 p-12 text-center">
          <p class="text-slate-500">暂无文章</p>
        </div>
      )}
    </div>
  </section>
</Layout>