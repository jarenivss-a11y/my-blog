---
import Layout from '../layouts/Layout.astro';

const BASE = '/my-blog';

const messages = [
  '这个页面好像迷路了...',
  '糟糕，你发现了一个隐藏的虫虫！',
  '页面正在度假中，请稍后再试~',
  'Oops! 这个页面不存在。',
  '页面走丢了，让我带你回家吧！',
];

const randomMessage = messages[Math.floor(Math.random() * messages.length)];
---

<Layout title="页面未找到 | 我的博客" description="抱歉，您访问的页面不存在">
  <div class="min-h-[70vh] flex items-center justify-center">
    <div class="text-center px-4 animate-on-scroll p-12 rounded-3xl backdrop-blur-2xl bg-[rgba(155,180,218,0.06)] border border-[rgba(165,188,230,0.15)] shadow-[0_8px_40px_rgba(0,0,0,0.2)] relative overflow-hidden">
      <!-- Background decorations -->
      <div class="absolute inset-0 bg-gradient-to-br from-[rgba(80,128,176,0.08)] via-transparent to-[rgba(114,168,216,0.05)] pointer-events-none"></div>
      <div class="absolute -top-10 -right-10 w-40 h-40 rounded-full bg-[rgba(80,128,176,0.1)] blur-3xl"></div>
      <div class="absolute -bottom-10 -left-10 w-32 h-32 rounded-full bg-[rgba(114,168,216,0.08)] blur-2xl"></div>

      <div class="relative mb-8">
        <div class="text-[120px] md:text-[180px] font-black text-[rgba(80,128,176,0.15)] font-serif leading-none select-none">404</div>
        <div class="absolute inset-0 flex items-center justify-center">
          <span class="text-7xl md:text-8xl">🔍</span>
        </div>
      </div>

      <h1 class="text-2xl font-serif font-bold text-[#e2e9f5] mb-4 relative z-10">页面未找到</h1>
      <p class="text-[#8a9cc4] mb-2 relative z-10">{randomMessage}</p>
      <p class="text-[#7a8cb4] text-sm mb-8 relative z-10">别担心，你可以从这里继续探索：</p>

      <div class="flex flex-wrap items-center justify-center gap-3 mb-8 relative z-10">
        <a
          href={BASE}
          class="px-6 py-3 rounded-full bg-gradient-to-r from-[#5080b0] to-[#72a8d8] text-white font-medium hover:shadow-[0_4px_20px_rgba(80,128,176,0.4)] transition-all flex items-center gap-2"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
          </svg>
          返回首页
        </a>
        <a
          href={`${BASE}/search`}
          class="px-6 py-3 rounded-full backdrop-blur-xl bg-[rgba(155,180,218,0.08)] border border-[rgba(80,128,176,0.2)] text-[#b2c0d8] font-medium hover:bg-[rgba(80,128,176,0.15)] hover:border-[rgba(80,128,176,0.35)] hover:text-[#72a8d8] transition-all flex items-center gap-2"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
          搜索文章
        </a>
        <a
          href={`${BASE}/archive`}
          class="px-6 py-3 rounded-full backdrop-blur-xl bg-[rgba(155,180,218,0.08)] border border-[rgba(80,128,176,0.2)] text-[#b2c0d8] font-medium hover:bg-[rgba(80,128,176,0.15)] hover:border-[rgba(80,128,176,0.35)] hover:text-[#72a8d8] transition-all flex items-center gap-2"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
          </svg>
          浏览归档
        </a>
      </div>

      <div class="flex flex-wrap gap-3 justify-center relative z-10">
        <a href={`${BASE}/category/daily`} class="px-4 py-2 rounded-xl backdrop-blur-xl bg-[rgba(80,128,176,0.1)] border border-[rgba(80,128,176,0.15)] text-sm text-[#72a8d8] hover:bg-[rgba(80,128,176,0.2)] hover:border-[rgba(80,128,176,0.3)] transition-all">
          🏠 日常生活
        </a>
        <a href={`${BASE}/category/music`} class="px-4 py-2 rounded-xl backdrop-blur-xl bg-[rgba(80,128,176,0.1)] border border-[rgba(80,128,176,0.15)] text-sm text-[#72a8d8] hover:bg-[rgba(80,128,176,0.2)] hover:border-[rgba(80,128,176,0.3)] transition-all">
          🎵 音乐分析
        </a>
        <a href={`${BASE}/category/ecommerce`} class="px-4 py-2 rounded-xl backdrop-blur-xl bg-[rgba(80,128,176,0.1)] border border-[rgba(80,128,176,0.15)] text-sm text-[#72a8d8] hover:bg-[rgba(80,128,176,0.2)] hover:border-[rgba(80,128,176,0.3)] transition-all">
          🛒 电商运营
        </a>
        <a href={`${BASE}/category/pokemon`} class="px-4 py-2 rounded-xl backdrop-blur-xl bg-[rgba(80,128,176,0.1)] border border-[rgba(80,128,176,0.15)] text-sm text-[#72a8d8] hover:bg-[rgba(80,128,176,0.2)] hover:border-[rgba(80,128,176,0.3)] transition-all">
          ⚡ 宝可梦
        </a>
      </div>
    </div>
  </div>
</Layout>