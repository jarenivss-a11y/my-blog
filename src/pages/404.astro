---
import Layout from '../layouts/Layout.astro';

const BASE = '/my-blog';

const messages = [
  '这个页面好像迷路了...',
  '糟糕，你发现了一个隐藏的虫虫！',
  '页面正在度假中，请稍后再试~',
  'Oops! 这个页面不存在。',
  '页面走丢了，让我带你回家吧！',
];

const randomMessage = messages[Math.floor(Math.random() * messages.length)];
---

<Layout title="页面未找到 | 我的博客" description="抱歉，您访问的页面不存在">
  <main id="main-content" class="min-h-[70vh] flex items-center justify-center" role="main" aria-label="404 页面未找到">
    <div class="text-center px-4 py-16 max-w-lg mx-auto">
      <!-- 小黑风格：简洁留白 -->
      <div class="relative mb-8" aria-hidden="true">
        <div class="text-[100px] md:text-[140px] font-black text-gray-100 font-serif leading-none select-none">404</div>
        <div class="absolute inset-0 flex items-center justify-center">
          <span class="text-5xl md:text-6xl">🔭</span>
        </div>
      </div>

      <h1 class="text-2xl font-serif font-bold text-gray-800 mb-4">页面未找到</h1>
      <p class="text-gray-500 mb-2" role="status">{randomMessage}</p>
      <p class="text-gray-400 text-sm mb-8">别担心，你可以从这里继续探索：</p>

      <nav class="flex flex-wrap items-center justify-center gap-3 mb-8" aria-label="快速导航">
        <a
          href={BASE}
          class="px-6 py-3 rounded-full bg-cyan-500 text-white font-medium hover:bg-cyan-600 hover:shadow-lg hover:shadow-cyan-500/20 transition-all flex items-center gap-2 focus:outline-none focus:ring-2 focus:ring-cyan-400 focus:ring-offset-2"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
          </svg>
          <span>返回首页</span>
        </a>
        <a
          href={`${BASE}/search`}
          class="px-6 py-3 rounded-full border border-gray-200 bg-white text-gray-600 font-medium hover:border-cyan-300 hover:text-cyan-600 transition-all flex items-center gap-2 focus:outline-none focus:ring-2 focus:ring-cyan-400 focus:ring-offset-2"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
          <span>搜索文章</span>
        </a>
        <a
          href={`${BASE}/archive`}
          class="px-6 py-3 rounded-full border border-gray-200 bg-white text-gray-600 font-medium hover:border-cyan-300 hover:text-cyan-600 transition-all flex items-center gap-2 focus:outline-none focus:ring-2 focus:ring-cyan-400 focus:ring-offset-2"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
          </svg>
          <span>浏览归档</span>
        </a>
      </nav>

      <nav class="flex flex-wrap gap-3 justify-center" aria-label="分类链接">
        <a href={`${BASE}/category/daily`} class="px-4 py-2 rounded-xl bg-gray-50 border border-gray-100 text-sm text-gray-600 hover:bg-cyan-50 hover:border-cyan-200 hover:text-cyan-600 transition-all focus:outline-none focus:ring-2 focus:ring-cyan-400">
          🏠 日常生活
        </a>
        <a href={`${BASE}/category/music`} class="px-4 py-2 rounded-xl bg-gray-50 border border-gray-100 text-sm text-gray-600 hover:bg-cyan-50 hover:border-cyan-200 hover:text-cyan-600 transition-all focus:outline-none focus:ring-2 focus:ring-cyan-400">
          🎵 音乐分析
        </a>
        <a href={`${BASE}/category/ecommerce`} class="px-4 py-2 rounded-xl bg-gray-50 border border-gray-100 text-sm text-gray-600 hover:bg-cyan-50 hover:border-cyan-200 hover:text-cyan-600 transition-all focus:outline-none focus:ring-2 focus:ring-cyan-400">
          🛒 电商运营
        </a>
        <a href={`${BASE}/category/pokemon`} class="px-4 py-2 rounded-xl bg-gray-50 border border-gray-100 text-sm text-gray-600 hover:bg-cyan-50 hover:border-cyan-200 hover:text-cyan-600 transition-all focus:outline-none focus:ring-2 focus:ring-cyan-400">
          ⚡ 宝可梦
        </a>
      </nav>
    </div>
  </main>
</Layout>