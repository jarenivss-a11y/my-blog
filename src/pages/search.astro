---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const BASE = '/my-blog';
const query = Astro.url.searchParams.get('q') || '';

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.published.getTime() - a.data.published.getTime());

const categoryInfo: Record<string, { name: string; icon: string }> = {
  daily: { name: '日常生活', icon: '🏠' },
  music: { name: '音乐分析', icon: '🎵' },
  books: { name: '读书鉴赏', icon: '📚' },
  ecommerce: { name: '电商运营', icon: '🛒' },
  pokemon: { name: '宝可梦', icon: '⚡' },
};

// Prepare search data
const searchData = posts.map(post => ({
  id: post.id,
  title: post.data.title,
  body: post.body.slice(0, 500),
  category: post.data.category,
  categoryName: categoryInfo[post.data.category]?.name || '未知',
  tags: post.data.tags || [],
  published: post.data.published.toISOString(),
}));
---

<Layout title={query ? `搜索: ${query} | 我的博客` : '搜索 | 我的博客'}>
  <header class="mb-12 py-8 border-b border-gray-100">
    <h1 class="text-3xl font-serif font-bold text-gray-800 mb-2">搜索</h1>
    <p class="text-gray-500" id="search-status" role="status" aria-live="polite">
      输入关键词搜索文章
    </p>
  </header>

  <form id="search-form" method="get" action="/my-blog/search" class="mb-8" role="search">
    <div class="relative max-w-xl">
      <label for="search-input" class="sr-only">搜索文章</label>
      <input
        type="text"
        name="q"
        id="search-input"
        value={query}
        placeholder="搜索文章标题、内容或标签..."
        class="w-full h-12 pl-12 pr-4 rounded-2xl border border-gray-200 bg-white text-gray-800 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-cyan-400 focus:border-cyan-300 transition-all"
        aria-describedby="search-hint"
      />
      <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
      </svg>
    </div>
    <p id="search-hint" class="sr-only">输入关键词后按回车搜索，或等待实时搜索结果</p>
  </form>

  <div id="search-results" class="space-y-4" role="region" aria-label="搜索结果" aria-live="polite">
    <p class="text-center py-16 text-gray-400">
      输入关键词开始搜索
    </p>
  </div>

  <script type="application/json" id="search-data" set:html={JSON.stringify(searchData)} />

  <script is:inline define:vars={{ initialQuery: query }}>
    const searchIndex = JSON.parse(document.getElementById('search-data').textContent);
    const resultsContainer = document.getElementById('search-results');
    const statusEl = document.getElementById('search-status');
    const input = document.getElementById('search-input');
    let selectedIndex = -1;

    function escapeHtml(text) {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    // Fuzzy match score - higher is better match
    function fuzzyScore(query, text) {
      const q = query.toLowerCase();
      const t = text.toLowerCase();
      let score = 0;
      let qIndex = 0;
      let prevMatch = -1;

      for (let i = 0; i < t.length && qIndex < q.length; i++) {
        if (t[i] === q[qIndex]) {
          score += 10;
          // Bonus for consecutive matches
          if (prevMatch === i - 1) score += 5;
          // Bonus for match at word boundary
          if (i === 0 || /[\s\p{P}]/u.test(t[i-1])) score += 8;
          // Bonus for match after underscore or camelCase
          if (i > 0 && /[A-Z]/.test(t[i])) score += 3;
          prevMatch = i;
          qIndex++;
        } else if (t[i] === ' ' || t[i] === '-') {
          score += 1;
        }
      }

      // Return score only if all query chars matched
      return qIndex === q.length ? score : 0;
    }

    function highlight(text, query) {
      if (!query) return text;
      const regex = new RegExp(`(${query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
      return text.replace(regex, '<mark class="bg-cyan-100 text-cyan-700 px-1 rounded">$1</mark>');
    }

    function search(query) {
      if (!query.trim()) {
        resultsContainer.innerHTML = '<p class="text-center py-16 text-gray-400">输入关键词开始搜索</p>';
        statusEl.textContent = '输入关键词搜索文章';
        return;
      }

      const q = query.toLowerCase().trim();
      statusEl.textContent = `正在搜索 "${query}"...`;

      // Score and sort results
      const scored = searchIndex.map(post => {
        let score = 0;
        // Title matches get highest weight
        if (post.title.toLowerCase().includes(q)) {
          score += fuzzyScore(q, post.title) * 10;
        }
        // Tag matches
        post.tags.forEach(tag => {
          if (tag.toLowerCase().includes(q)) score += fuzzyScore(q, tag) * 5;
        });
        // Category match
        if (post.categoryName.toLowerCase().includes(q)) score += fuzzyScore(q, post.categoryName) * 3;
        // Body match
        if (post.body.toLowerCase().includes(q)) score += fuzzyScore(q, q) * 1;
        return { post, score };
      }).filter(item => item.score > 0).sort((a, b) => b.score - a.score);

      const results = scored.map(item => item.post);

      statusEl.textContent = `找到 ${results.length} 条结果`;

      if (results.length === 0) {
        resultsContainer.innerHTML = `
          <div class="text-center py-16">
            <p class="text-4xl mb-4">🔍</p>
            <p class="text-gray-500 mb-4">没有找到相关文章</p>
            <p class="text-sm text-gray-400">试试其他关键词？</p>
          </div>
        `;
        return;
      }

      resultsContainer.innerHTML = results.map((post, idx) => {
        const title = highlight(escapeHtml(post.title), query);
        const body = highlight(escapeHtml(post.body.slice(0, 200)), query);
        const date = new Date(post.published).toLocaleDateString('zh-CN');
        const tags = post.tags.slice(0, 3).map(tag => '<span class="text-xs px-2 py-1 rounded-full bg-cyan-50 text-cyan-600">#' + escapeHtml(tag) + '</span>').join('');
        const relevanceScore = Math.round((scored[idx].score / scored[0].score) * 100);
        return '<article class="group" role="article"><a href="/my-blog/post/' + post.id + '" class="block p-6 rounded-2xl border border-gray-100 bg-white hover:border-cyan-200 hover:shadow-lg transition-all duration-300' + (idx === selectedIndex ? ' aria-selected="true"' : '') + ' tabindex="0"><div class="flex items-center gap-3 mb-3"><span class="text-xs text-gray-400">' + date + '</span><span class="px-2 py-0.5 text-xs bg-cyan-50 text-cyan-600 rounded-full">' + escapeHtml(post.categoryName) + '</span><span class="text-xs text-cyan-500 opacity-60">' + relevanceScore + '% 相关</span></div><h3 class="text-lg font-serif font-semibold text-gray-800 group-hover:text-cyan-600 transition-colors mb-2">' + title + '</h3><p class="text-sm text-gray-500 line-clamp-2">' + body + '...</p>' + (post.tags.length > 0 ? '<div class="flex gap-2 mt-3">' + tags + '</div>' : '') + '</a></article>';
      }).join('');
    }

    // Initial search
    if (initialQuery) {
      search(initialQuery);
    }

    // Live search as user types (debounced)
    let timeout;
    input.addEventListener('input', () => {
      selectedIndex = -1;
      clearTimeout(timeout);
      timeout = setTimeout(() => {
        const q = input.value.trim();
        if (q) {
          window.history.replaceState({}, '', `/my-blog/search?q=${encodeURIComponent(q)}`);
          search(q);
        }
      }, 200);
    });

    // Keyboard navigation
    input.addEventListener('keydown', (e) => {
      const articles = resultsContainer.querySelectorAll('article');
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        selectedIndex = Math.min(selectedIndex + 1, articles.length - 1);
        updateSelection(articles);
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        selectedIndex = Math.max(selectedIndex - 1, -1);
        updateSelection(articles);
      } else if (e.key === 'Enter' && selectedIndex >= 0) {
        e.preventDefault();
        const link = articles[selectedIndex].querySelector('a');
        if (link) link.click();
      }
    });

    function updateSelection(articles) {
      articles.forEach((article, idx) => {
        const link = article.querySelector('a');
        if (idx === selectedIndex) {
          article.setAttribute('aria-selected', 'true');
          link.classList.add('ring-2', 'ring-cyan-400');
          link.focus();
        } else {
          article.setAttribute('aria-selected', 'false');
          link.classList.remove('ring-2', 'ring-cyan-400');
        }
      });
    }

    // Form submit
    document.getElementById('search-form').addEventListener('submit', (e) => {
      e.preventDefault();
      const q = input.value.trim();
      if (q) {
        window.location.href = `/my-blog/search?q=${encodeURIComponent(q)}`;
      }
    });
  </script>
</Layout>