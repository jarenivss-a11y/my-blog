---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const BASE = '/my-blog';
const query = Astro.url.searchParams.get('q') || '';

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.published.getTime() - a.data.published.getTime());

const categoryInfo: Record<string, { name: string; icon: string }> = {
  daily: { name: '日常生活', icon: '🏠' },
  music: { name: '音乐分析', icon: '🎵' },
  books: { name: '读书鉴赏', icon: '📚' },
  ecommerce: { name: '电商运营', icon: '🛒' },
  pokemon: { name: '宝可梦', icon: '⚡' },
};

// Prepare search data
const searchData = posts.map(post => ({
  id: post.id,
  title: post.data.title,
  body: post.body.slice(0, 500),
  category: post.data.category,
  categoryName: categoryInfo[post.data.category]?.name || '未知',
  tags: post.data.tags || [],
  published: post.data.published.toISOString(),
}));
---

<Layout title={query ? `搜索: ${query} | 我的博客` : '搜索 | 我的博客'}>
  <header class="mb-12 p-10 rounded-3xl backdrop-blur-xl bg-[rgba(155,180,218,0.06)] border border-[rgba(165,188,230,0.15)] shadow-[0_8px_32px_rgba(0,0,0,0.15)] relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[rgba(80,128,176,0.08)] via-transparent to-[rgba(114,168,216,0.05)] pointer-events-none"></div>
    <div class="absolute -top-10 -right-10 w-32 h-32 rounded-full bg-[rgba(80,128,176,0.1)] blur-2xl"></div>
    <h1 class="text-3xl font-serif font-black text-[#e2e9f5] mb-2 relative z-10">搜索</h1>
    <p class="text-[#8a9cc4] relative z-10" id="search-status">
      输入关键词搜索文章
    </p>
  </header>

  <form id="search-form" method="get" action="/my-blog/search" class="mb-8">
    <div class="relative max-w-xl">
      <input
        type="text"
        name="q"
        id="search-input"
        value={query}
        placeholder="搜索文章标题、内容或标签..."
        class="w-full h-12 pl-12 pr-4 rounded-2xl border border-[rgba(80,128,176,0.2)] bg-[rgba(155,180,218,0.08)] backdrop-blur-xl text-[#e2e9f5] placeholder:text-[#8a9cc4] focus:outline-none focus:ring-2 focus:ring-[#5080b0] focus:border-[rgba(80,128,176,0.4)] transition-all"
      />
      <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-[#8a9cc4]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
      </svg>
    </div>
  </form>

  <div id="search-results" class="space-y-4">
    <p class="text-center py-16 text-[#8a9cc4]">
      输入关键词开始搜索
    </p>
  </div>

  <script type="application/json" id="search-data" set:html={JSON.stringify(searchData)} />

  <script is:inline define:vars={{ initialQuery: query }}>
    const searchIndex = JSON.parse(document.getElementById('search-data').textContent);
    const resultsContainer = document.getElementById('search-results');
    const statusEl = document.getElementById('search-status');
    const input = document.getElementById('search-input');

    function escapeHtml(text) {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    function highlight(text, query) {
      if (!query) return text;
      const regex = new RegExp(`(${query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
      return text.replace(regex, '<mark class="bg-[rgba(80,128,176,0.4)] text-[#8ac4e8] px-1 rounded">$1</mark>');
    }

    function search(query) {
      if (!query.trim()) {
        resultsContainer.innerHTML = '<p class="text-center py-16 text-[#8a9cc4]">输入关键词开始搜索</p>';
        statusEl.textContent = '输入关键词搜索文章';
        return;
      }

      const q = query.toLowerCase().trim();
      statusEl.textContent = `正在搜索 "${query}"...`;

      const results = searchIndex.filter(post =>
        post.title.toLowerCase().includes(q) ||
        post.body.toLowerCase().includes(q) ||
        post.tags.some(tag => tag.toLowerCase().includes(q)) ||
        post.categoryName.toLowerCase().includes(q)
      );

      statusEl.textContent = `找到 ${results.length} 条结果`;

      if (results.length === 0) {
        resultsContainer.innerHTML = `
          <div class="text-center py-16">
            <p class="text-[#8a9cc4] mb-4">没有找到相关文章</p>
            <p class="text-sm text-[#7a8cb4]">试试其他关键词？</p>
          </div>
        `;
        return;
      }

      resultsContainer.innerHTML = results.map(post => {
        const title = highlight(escapeHtml(post.title), query);
        const body = highlight(escapeHtml(post.body.slice(0, 200)), query);
        const date = new Date(post.published).toLocaleDateString('zh-CN');
        const tags = post.tags.slice(0, 3).map(tag => '<span class="text-xs px-2 py-1 rounded-full bg-[rgba(80,128,176,0.15)] text-[#72a8d8]">#' + escapeHtml(tag) + '</span>').join('');
        return '<article class="group"><a href="/my-blog/post/' + post.id + '" class="block p-6 rounded-2xl backdrop-blur-xl bg-[rgba(155,180,218,0.05)] border border-[rgba(165,188,230,0.12)] hover:bg-[rgba(155,180,218,0.1)] hover:border-[rgba(80,128,176,0.3)] hover:shadow-[0_8px_32px_rgba(80,128,176,0.2)] transition-all duration-300"><div class="flex items-center gap-3 mb-3"><span class="text-xs text-[#7a8cb4]">' + date + '</span><span class="px-2 py-0.5 text-xs bg-[rgba(80,128,176,0.2)] text-[#72a8d8] rounded-full">' + escapeHtml(post.categoryName) + '</span></div><h3 class="text-lg font-serif font-semibold text-[#e2e9f5] group-hover:text-[#8ac4e8] transition-colors mb-2">' + title + '</h3><p class="text-sm text-[#8a9cc4] line-clamp-2">' + body + '...</p>' + (post.tags.length > 0 ? '<div class="flex gap-2 mt-3">' + tags + '</div>' : '') + '</a></article>';
      }).join('');
    }

    // Initial search
    if (initialQuery) {
      search(initialQuery);
    }

    // Live search as user types (debounced)
    let timeout;
    input.addEventListener('input', () => {
      clearTimeout(timeout);
      timeout = setTimeout(() => {
        const q = input.value.trim();
        if (q) {
          window.history.replaceState({}, '', `/my-blog/search?q=${encodeURIComponent(q)}`);
          search(q);
        }
      }, 300);
    });

    // Form submit
    document.getElementById('search-form').addEventListener('submit', (e) => {
      e.preventDefault();
      const q = input.value.trim();
      if (q) {
        window.location.href = `/my-blog/search?q=${encodeURIComponent(q)}`;
      }
    });
  </script>
</Layout>