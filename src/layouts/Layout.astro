---
import Fireflies from '../components/Fireflies.astro';
import Sakura from '../components/Sakura.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import BackToTop from '../components/BackToTop.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import VisitorStats from '../components/VisitorStats.astro';
import RunningTime from '../components/RunningTime.astro';
import SEO from '../components/SEO.astro';
import CopyButton from '../components/CopyButton.astro';
import Lightbox from '../components/Lightbox.astro';
import ThemeColorPicker from '../components/ThemeColorPicker.astro';
import ShareCard from '../components/ShareCard.astro';
import KeyboardShortcuts from '../components/KeyboardShortcuts.astro';
import Newsletter from '../components/Newsletter.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Personal Blog" } = Astro.props;
const BASE = '/my-blog';

const categories = [
  { name: '日常生活', slug: 'daily', icon: '🏠' },
  { name: '音乐分析', slug: 'music', icon: '🎵' },
  { name: '读书鉴赏', slug: 'books', icon: '📚' },
  { name: '电商运营', slug: 'ecommerce', icon: '🛒' },
  { name: '宝可梦', slug: 'pokemon', icon: '⚡' },
];

const navLinks = [
  { name: '首页', href: '/' },
  { name: '技能库', href: '/skills' },
  { name: '归档', href: '/archive' },
  { name: '标签', href: '/tags' },
  { name: '订阅', href: '/feed' },
  { name: '友链', href: '/friends' },
  { name: '关于', href: '/about' },
];

const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <!-- Blocking script to set theme color before page renders -->
    <script is:inline>
      (function() {
        var saved = localStorage.getItem('blog-theme-color');
        if (saved) {
          var hex = saved.replace('#', '');
          var r = parseInt(hex.substring(0, 2), 16);
          var g = parseInt(hex.substring(2, 4), 16);
          var b = parseInt(hex.substring(4, 6), 16);
          document.documentElement.style.setProperty('--color-primary', saved);
          document.documentElement.style.setProperty('--color-primary-light', 'rgba(' + r + ', ' + g + ', ' + b + ', 0.12)');
          document.documentElement.style.setProperty('--color-primary-dark', 'rgba(' + r + ', ' + g + ', ' + b + ', 0.25)');
        }
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={`https://jarenivss-a11y.github.io${Astro.url.pathname}`} />
    <meta property="og:site_name" content="我的博客" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;700&family=Noto+Serif+SC:wght@400;600&display=swap" rel="stylesheet">
    <link rel="alternate" type="application/rss+xml" title="我的博客 RSS" href="/my-blog/rss.xml" />
    <SEO title={title} description={description} url={Astro.url.pathname} />
  </head>
  <body class="bg-slate-50 dark:bg-slate-950 text-slate-800 dark:text-slate-100 min-h-screen font-sans antialiased transition-colors duration-500">
    <!-- Skip to content -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:bg-primary focus:text-white focus:rounded-lg focus:outline-none focus:ring-2 focus:ring-white">
      跳转到主要内容
    </a>

    <!-- Reading Progress Bar -->
    <ReadingProgress />

    <!-- Background Effects -->
    <Sakura />
    <Fireflies />

    <!-- Navigation -->
    <header id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
      <div class="mx-auto px-4 transition-all duration-300">
        <div id="nav-container" class="relative overflow-hidden transition-all duration-300 rounded-none">
          <div class="flex h-16 items-center justify-between px-4 md:px-6">
            <a href={BASE} class="text-xl font-black text-slate-800 dark:text-white tracking-tighter hover:text-primary transition-colors">
              我的博客
              <span class="text-primary mx-1">の</span>
              <span class="text-slate-400 dark:text-slate-500 font-normal text-sm">宝藏之地</span>
            </a>

            <!-- Desktop Navigation -->
            <nav class="hidden md:flex items-center gap-6">
              {navLinks.map((link) => (
                link.name === '归档' ? (
                  <div class="relative group">
                    <button class="flex items-center gap-1 py-1 text-sm font-medium text-slate-600 dark:text-slate-300 hover:text-primary dark:hover:text-primary transition-colors">
                      {link.name}
                      <svg class="w-3 h-3 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                      </svg>
                    </button>
                    <div class="absolute top-full left-0 mt-2 w-48 py-2 rounded-2xl backdrop-blur-xl bg-white/90 dark:bg-slate-800/90 border border-white/50 dark:border-slate-700/50 shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
                      {categories.map(cat => (
                        <a href={`${BASE}/category/${cat.slug}`} class="flex items-center gap-2 px-4 py-2 text-sm text-slate-600 dark:text-slate-300 hover:bg-primary/10 hover:text-primary transition-colors">
                          <span>{cat.icon}</span>
                          <span>{cat.name}</span>
                        </a>
                      ))}
                    </div>
                  </div>
                ) : (
                <a
                  href={`${BASE}${link.href}`}
                  class={`relative py-1 text-sm font-medium transition-colors ${
                    currentPath === `${BASE}${link.href}` || currentPath === `${BASE}${link.href}/`
                      ? 'text-primary dark:text-primary'
                      : 'text-slate-600 dark:text-slate-300 hover:text-primary dark:hover:text-primary'
                  }`}
                >
                  {link.name}
                  {currentPath === `${BASE}${link.href}` && (
                    <span class="absolute -bottom-1 left-1/2 -translate-x-1/2 w-1 h-1 bg-primary rounded-full animate-pulse"></span>
                  )}
                </a>
                )
              ))}

              <!-- Search -->
              <div class="relative">
                <input
                  type="text"
                  id="search-input"
                  placeholder="搜索..."
                  class="h-9 w-40 rounded-full border-0 bg-slate-100 dark:bg-slate-800 pl-9 pr-4 text-sm placeholder:text-slate-400 focus:w-56 focus:outline-none focus:ring-2 focus:ring-primary transition-all"
                />
                <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
              </div>

              <ThemeToggle />
            </nav>

            <!-- Mobile Menu Button -->
            <button id="mobile-menu-btn" class="md:hidden p-2 text-slate-600 dark:text-slate-300 hover:text-primary">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
              </svg>
            </button>
          </div>

          <!-- Mobile Menu -->
          <div id="mobile-menu" class="hidden md:hidden px-4 pb-4">
            <div class="flex flex-col space-y-2">
              {navLinks.map((link) => (
                <a
                  href={`${BASE}${link.href}`}
                  class={`py-2 text-sm font-medium transition-colors ${
                    currentPath === `${BASE}${link.href}` || currentPath === `${BASE}${link.href}/`
                      ? 'text-primary'
                      : 'text-slate-600 dark:text-slate-300'
                  }`}
                >
                  {link.name}
                </a>
              ))}
              <div class="pt-2 pb-1">
                <span class="text-xs text-slate-400 uppercase tracking-wider">分类</span>
              </div>
              <div class="grid grid-cols-2 gap-2">
              {categories.map(cat => (
                <a
                  href={`${BASE}/category/${cat.slug}`}
                  class="py-2 px-3 text-sm font-medium rounded-lg bg-slate-100 dark:bg-slate-700/50 text-slate-600 dark:text-slate-300 hover:bg-primary/10 hover:text-primary transition-colors flex items-center gap-2"
                >
                  <span>{cat.icon}</span>
                  <span>{cat.name}</span>
                </a>
              ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <div id="main-content" class="pt-24 pb-20">
      <div class="max-w-6xl mx-auto px-4 md:px-6">
        <main>
          <slot />
        </main>
      </div>
    </div>

    <!-- Footer -->
    <footer class="py-8 border-t border-slate-200/50 dark:border-slate-800/50 text-center">
      <div class="flex items-center justify-center gap-4 mb-4">
        <a href="/my-blog/feed" class="text-sm text-slate-400 hover:text-primary transition-colors" title="订阅预览">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
          </svg>
        </a>
        <a href="/my-blog/rss.xml" class="text-sm text-slate-400 hover:text-primary transition-colors" title="RSS 源">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
          </svg>
        </a>
        <a href="/my-blog/sitemap-preview" class="text-sm text-slate-400 hover:text-primary transition-colors" title="网站地图">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
          </svg>
        </a>
        <a href="/my-blog/sitemap-index.xml" class="text-sm text-slate-400 hover:text-primary transition-colors" title="Sitemap XML">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"/>
          </svg>
        </a>
      </div>
      <VisitorStats />
      <RunningTime />
      <p class="text-sm text-slate-400 dark:text-slate-500 mt-2">© 2026 我的博客 · 用心记录每一天</p>
    </footer>

    <!-- Back to Top Button -->
    <BackToTop />

    <!-- Scrollbar Styles -->
    <style is:global>
      * {
        font-family: 'Noto Sans SC', -apple-system, BlinkMacSystemFont, sans-serif;
      }
      h1, h2, h3 {
        font-family: 'Noto Serif SC', serif;
      }
      a {
        text-decoration: none;
      }
      ::selection {
        background: rgba(99, 102, 241, 0.2);
        color: inherit;
      }
      ::-webkit-scrollbar {
        width: 6px;
        height: 6px;
      }
      ::-webkit-scrollbar-track {
        background: transparent;
      }
      ::-webkit-scrollbar-thumb {
        background: rgba(99, 102, 241, 0.3);
        border-radius: 10px;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: rgba(99, 102, 241, 0.6);
      }

      /* Theme Color Variables */
      :root {
        --color-primary: #6366f1;
        --color-primary-light: rgba(99, 102, 241, 0.12);
        --color-primary-dark: rgba(99, 102, 241, 0.25);
      }

      /* Also set on html element for dynamic updates */
      html {
        --color-primary: #6366f1;
        --color-primary-light: rgba(99, 102, 241, 0.12);
        --color-primary-dark: rgba(99, 102, 241, 0.25);
      }

      /* Focus Styles for Accessibility */
      :focus-visible {
        outline: 2px solid rgba(99, 102, 241, 0.6);
        outline-offset: 2px;
      }
      a:focus-visible, button:focus-visible {
        outline: 2px solid var(--color-primary, #6366f1);
        outline-offset: 2px;
        border-radius: 4px;
      }

      /* Page Transition Animations */
      @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
      }
      @keyframes fadeOut {
        from { opacity: 1; transform: translateY(0); }
        to { opacity: 0; transform: translateY(-10px); }
      }
      ::view-transition-old(root) {
        animation: fadeOut 0.2s ease-out forwards;
      }
      ::view-transition-new(root) {
        animation: fadeIn 0.3s ease-out forwards;
      }
    </style>

    <script>
      // Navigation scroll behavior
      function initNavScroll() {
        const navbar = document.getElementById('navbar');
        const navContainer = document.getElementById('nav-container');
        const mobileMenuBtn = document.getElementById('mobile-menu-btn');
        const mobileMenu = document.getElementById('mobile-menu');

        if (!navbar || !navContainer) return;

        let lastScrollY = window.scrollY;
        let ticking = false;

        const handleScroll = () => {
          if (!ticking) {
            window.requestAnimationFrame(() => {
              const scrollY = window.scrollY;

              if (scrollY > 100) {
                // Scrolled: add glass effect
                navContainer.classList.add('rounded-2xl', 'border', 'border-white/50', 'dark:border-white/10', 'bg-white/80', 'dark:bg-slate-900/80', 'backdrop-blur-xl', 'shadow-lg', 'shadow-black/5');
                navbar.classList.add('top-4');
                navbar.classList.remove('top-0');
                navContainer.classList.remove('rounded-none');
              } else {
                // At top: transparent
                navContainer.classList.remove('rounded-2xl', 'border', 'border-white/50', 'dark:border-white/10', 'bg-white/80', 'dark:bg-slate-900/80', 'backdrop-blur-xl', 'shadow-lg', 'shadow-black/5');
                navbar.classList.remove('top-4');
                navbar.classList.add('top-0');
                navContainer.classList.add('rounded-none');
              }

              lastScrollY = scrollY;
              ticking = false;
            });
            ticking = true;
          }
        };

        window.addEventListener('scroll', handleScroll, { passive: true });
        handleScroll();

        // Mobile menu toggle
        if (mobileMenuBtn && mobileMenu) {
          mobileMenuBtn.addEventListener('click', () => {
            mobileMenu.classList.toggle('hidden');
          });
        }
      }

      // Search handler
      function initSearch() {
        const searchInput = document.getElementById('search-input') as HTMLInputElement;
        if (!searchInput) return;

        searchInput.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' && searchInput.value.trim()) {
            const query = encodeURIComponent(searchInput.value.trim());
            window.location.href = `/my-blog/search?q=${query}`;
          }
        });
      }

      initNavScroll();
      initSearch();
      document.addEventListener('astro:after-swap', () => {
        initNavScroll();
        initSearch();
      });
    </script>
    <CopyButton />
    <Lightbox />
    <ThemeColorPicker />
    <ShareCard />
    <KeyboardShortcuts />
    <Newsletter />
  </body>
</html>