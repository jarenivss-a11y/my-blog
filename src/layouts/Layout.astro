---
import OceanWebGL from '../components/OceanWebGL.astro';
import OceanAudio from '../components/OceanAudio.astro';
import BackToTop from '../components/BackToTop.astro';
import ReadingProgress from '../components/ReadingProgress.astro';
import VisitorStats from '../components/VisitorStats.astro';
import RunningTime from '../components/RunningTime.astro';
import SEO from '../components/SEO.astro';
import CopyButton from '../components/CopyButton.astro';
import Lightbox from '../components/Lightbox.astro';
import LazyImage from '../components/LazyImage.astro';
import ThemeColorPicker from '../components/ThemeColorPicker.astro';
import ShareCard from '../components/ShareCard.astro';
import KeyboardShortcuts from '../components/KeyboardShortcuts.astro';
import Newsletter from '../components/Newsletter.astro';
import ScrollAnimations from '../components/ScrollAnimations.astro';
import RandomPost from '../components/RandomPost.astro';
import ShortcutHelp from '../components/ShortcutHelp.astro';
import ReadingStats from '../components/ReadingStats.astro';
import SeriesNav from '../components/SeriesNav.astro';
import SmoothScroll from '../components/SmoothScroll.astro';
import EditOnGitHub from '../components/EditOnGitHub.astro';
import WelcomeBack from '../components/WelcomeBack.astro';
import FloatingShare from '../components/FloatingShare.astro';
import ReadingStreak from '../components/ReadingStreak.astro';
import BatterySaver from '../components/BatterySaver.astro';
import DailyGoal from '../components/DailyGoal.astro';
import AnnouncementBanner from '../components/AnnouncementBanner.astro';
import CopyLinkBubble from '../components/CopyLinkBubble.astro';
import ReadingList from '../components/ReadingList.astro';
import BackButton from '../components/BackButton.astro';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Personal Blog" } = Astro.props;
const BASE = '/my-blog';

// Get all posts for random post feature
const allPosts = await getCollection('blog');
const postUrls = allPosts
  .filter(p => !p.data.draft)
  .map(p => `${BASE}/post/${p.id}`);

const categories = [
  { name: '日常生活', slug: 'daily', icon: '🏠' },
  { name: '音乐分析', slug: 'music', icon: '🎵' },
  { name: '读书鉴赏', slug: 'books', icon: '📚' },
  { name: '电商运营', slug: 'ecommerce', icon: '🛒' },
  { name: '宝可梦', slug: 'pokemon', icon: '⚡' },
];

const navLinks = [
  { name: '首页', href: '/' },
  { name: '技能库', href: '/skills' },
  { name: '归档', href: '/archive' },
  { name: '标签', href: '/tags' },
  { name: '订阅', href: '/feed' },
  { name: '友链', href: '/friends' },
  { name: '关于', href: '/about' },
];

const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <!-- Blocking script to set theme color before page renders -->
    <script is:inline>
      (function() {
        var saved = localStorage.getItem('blog-theme-color');
        if (saved) {
          var hex = saved.replace('#', '');
          var r = parseInt(hex.substring(0, 2), 16);
          var g = parseInt(hex.substring(2, 4), 16);
          var b = parseInt(hex.substring(4, 6), 16);
          document.documentElement.style.setProperty('--color-primary', saved);
          document.documentElement.style.setProperty('--color-primary-light', 'rgba(' + r + ', ' + g + ', ' + b + ', 0.12)');
          document.documentElement.style.setProperty('--color-primary-dark', 'rgba(' + r + ', ' + g + ', ' + b + ', 0.25)');
        }
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={`https://jarenivss-a11y.github.io${Astro.url.pathname}`} />
    <meta property="og:site_name" content="我的博客" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <!-- PWA Meta Tags -->
    <meta name="theme-color" content="#06b6d4" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="我的博客" />
    <link rel="manifest" href="/my-blog/manifest.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Great+Vibes&family=Noto+Sans+SC:wght@300;400;500;700&family=Noto+Serif+SC:wght@400;600&family=Raleway:wght@200;300&family=Spectral:ital,wght@1,300&display=swap" rel="stylesheet">
    <link rel="alternate" type="application/rss+xml" title="我的博客 RSS" href="/my-blog/rss.xml" />
    <SEO title={title} description={description} url={Astro.url.pathname} />
    <script is:inline define:vars={{ postUrls }}>window.__POST_URLS__ = postUrls;</script>
  </head>
  <body class="bg-[#08080c] text-[#fafafa] min-h-screen font-sans antialiased scroll-smooth relative overflow-x-hidden transition-colors duration-500">
    <!-- Dark background for ocean effect -->
    <div class="fixed inset-0 pointer-events-none -z-10 bg-[#08080c]"></div>

    <!-- Skip to content -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:bg-cyan-500 focus:text-white focus:rounded-lg focus:outline-none focus:ring-2 focus:ring-cyan-400">
      跳转到主要内容
    </a>

    <!-- Announcement Banner -->
    <AnnouncementBanner />

    <!-- Reading Progress Bar -->
    <ReadingProgress />

    <!-- Ocean Background -->
    <OceanWebGL />
    <OceanAudio />

    <!-- Navigation - Ocean theme -->
    <header id="navbar" class="sticky top-0 z-50 backdrop-blur-md bg-[rgba(8,8,12,0.85)] border-b border-[rgba(80,128,176,0.2)]">
      <div class="max-w-6xl mx-auto px-4">
        <div class="flex h-16 items-center justify-between">
          <!-- Logo -->
          <a href={BASE} class="text-xl font-bold text-cyan-400 hover:text-cyan-300 transition-colors tracking-tight">
            我的博客
            <span class="text-cyan-600 mx-1">·</span>
            <span class="text-slate-400 font-normal text-sm">宝藏之地</span>
          </a>

          <!-- Desktop Navigation -->
          <nav class="hidden md:flex items-center gap-8">
            {navLinks.map((link) => (
              link.name === '归档' ? (
                <div class="relative group">
                  <button class="flex items-center gap-1 py-1 text-sm font-medium text-slate-300 hover:text-cyan-400 transition-colors">
                    {link.name}
                    <svg class="w-3 h-3 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                    </svg>
                  </button>
                  <div class="absolute top-full left-0 mt-2 w-48 py-2 bg-[rgba(10,15,25,0.98)] border border-[rgba(80,128,176,0.3)] rounded-xl shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
                    {categories.map(cat => (
                      <a href={`${BASE}/category/${cat.slug}`} class="flex items-center gap-2 px-4 py-2 text-sm text-slate-300 hover:bg-[rgba(80,128,176,0.15)] hover:text-cyan-400 transition-colors">
                        <span>{cat.icon}</span>
                        <span>{cat.name}</span>
                      </a>
                    ))}
                  </div>
                </div>
              ) : (
              <a
                href={`${BASE}${link.href}`}
                class={`relative py-1 text-sm font-medium transition-colors ${
                  currentPath === `${BASE}${link.href}` || currentPath === `${BASE}${link.href}/`
                    ? 'text-cyan-400'
                    : 'text-slate-300 hover:text-cyan-400'
                }`}
              >
                {link.name}
                {currentPath === `${BASE}${link.href}` && (
                  <span class="absolute -bottom-1 left-1/2 -translate-x-1/2 w-1 h-1 bg-cyan-500 rounded-full"></span>
                )}
              </a>
              )
            ))}

            <!-- Search -->
            <div class="relative">
              <input
                type="text"
                id="search-input"
                placeholder="搜索..."
                class="h-9 w-36 rounded-full border border-[rgba(80,128,176,0.3)] bg-[rgba(20,30,50,0.8)] pl-9 pr-4 text-sm placeholder:text-slate-400 focus:w-48 focus:outline-none focus:ring-2 focus:ring-cyan-500 focus:border-cyan-500 transition-all text-slate-200"
              />
              <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
              </svg>
            </div>
          </nav>

          <!-- Mobile Menu Button -->
          <button id="mobile-menu-btn" class="md:hidden p-2 text-slate-300 hover:text-cyan-400">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>
        </div>

        <!-- Mobile Menu -->
        <div id="mobile-menu" class="hidden md:hidden pb-4">
          <div class="flex flex-col gap-1">
            {navLinks.map((link) => (
              <a
                href={`${BASE}${link.href}`}
                class={`py-2 text-sm font-medium transition-colors ${
                  currentPath === `${BASE}${link.href}` || currentPath === `${BASE}${link.href}/`
                    ? 'text-cyan-400'
                    : 'text-slate-300'
                }`}
              >
                {link.name}
              </a>
            ))}
            <div class="pt-2 pb-1 border-t border-[rgba(80,128,176,0.2)] mt-2">
              <span class="text-xs text-slate-500 uppercase tracking-wider">分类</span>
            </div>
            <div class="grid grid-cols-2 gap-2">
            {categories.map(cat => (
              <a
                href={`${BASE}/category/${cat.slug}`}
                class="py-2 px-3 text-sm font-medium rounded-lg bg-[rgba(20,30,50,0.8)] text-slate-300 hover:bg-[rgba(80,128,176,0.15)] hover:text-cyan-400 transition-colors flex items-center gap-2"
              >
                <span>{cat.icon}</span>
                <span>{cat.name}</span>
              </a>
            ))}
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <div id="main-content" class="pt-12 pb-20 relative z-10">
      <div class="max-w-6xl mx-auto px-4 md:px-6">
        <main>
          <slot />
        </main>
      </div>
    </div>

    <!-- Footer -->
    <footer class="py-8 border-t border-[rgba(80,128,176,0.2)] text-center bg-[rgba(8,8,12,0.9)]">
      <div class="flex items-center justify-center gap-6 mb-4">
        <a href="/my-blog/feed" class="text-sm text-slate-400 hover:text-cyan-400 transition-colors" title="订阅预览">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
          </svg>
        </a>
        <a href="/my-blog/rss.xml" class="text-sm text-slate-400 hover:text-cyan-400 transition-colors" title="RSS 源">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
          </svg>
        </a>
        <a href="/my-blog/sitemap-preview" class="text-sm text-slate-400 hover:text-cyan-400 transition-colors" title="网站地图">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
          </svg>
        </a>
        <a href="/my-blog/sitemap-index.xml" class="text-sm text-slate-400 hover:text-cyan-400 transition-colors" title="Sitemap XML">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"/>
          </svg>
        </a>
      </div>
      <VisitorStats />
      <RunningTime />
      <p class="text-sm text-slate-500 mt-2">© 2026 我的博客 · 用心记录每一天</p>
    </footer>

    <!-- Back to Top Button -->
    <BackToTop />

    <!-- Scrollbar Styles - 小黑风格：简洁清新 -->
    <style is:global>
      * {
        font-family: 'Noto Sans SC', -apple-system, BlinkMacSystemFont, sans-serif;
      }
      h1, h2, h3 {
        font-family: 'Noto Serif SC', 'Cormorant Garamond', serif;
      }
      a {
        text-decoration: none;
        position: relative;
      }
      a:not(.no-underline)::after {
        content: '';
        position: absolute;
        bottom: -2px;
        left: 0;
        width: 0;
        height: 2px;
        background: #06b6d4;
        transition: width 0.3s ease;
      }
      a:not(.no-underline):hover::after {
        width: 100%;
      }
      ::selection {
        background: rgba(6, 182, 212, 0.3);
        color: #f1f5f9;
      }
      ::-webkit-scrollbar {
        width: 6px;
        height: 6px;
      }
      ::-webkit-scrollbar-track {
        background: transparent;
      }
      ::-webkit-scrollbar-thumb {
        background: #334155;
        border-radius: 10px;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: #475569;
      }

      /* Theme Color Variables - Ocean theme */
      :root {
        --color-primary: #06b6d4;
        --color-primary-light: rgba(6, 182, 212, 0.15);
        --color-primary-dark: rgba(6, 182, 212, 0.3);
        --bg-deep: #08080c;
        --bg-mid: #0f172a;
        --mist: #64748b;
        --silver: #94a3b8;
        --light: #cbd5e1;
        --pale: #e2e8f0;
        --text-primary: #f1f5f9;
        --text-secondary: #94a3b8;
        --text-muted: #64748b;
        --glass-bg: rgba(15, 23, 42, 0.8);
        --glass-border: rgba(100, 116, 139, 0.2);
        --glass-shadow: rgba(0, 0, 0, 0.3);
        --accent: #06b6d4;
        --accent-light: #22d3ee;
        scrollbar-color: #334155 transparent;
      }

      /* Also set on html element for dynamic updates */
      html {
        --color-primary: #06b6d4;
        --color-primary-light: rgba(6, 182, 212, 0.12);
        --color-primary-dark: rgba(6, 182, 212, 0.25);
        --article-font-size: 18px;
      }

      /* Focus Styles for Accessibility */
      :focus-visible {
        outline: 2px solid rgba(6, 182, 212, 0.6);
        outline-offset: 2px;
        border-radius: 4px;
      }
      a:focus-visible, button:focus-visible {
        outline: 2px solid var(--color-primary, #06b6d4);
        outline-offset: 2px;
        border-radius: 4px;
      }

      /* Smooth button hover effects */
      button, .btn {
        transition: all 0.2s ease;
      }
      button:hover, .btn:hover {
        transform: translateY(-1px);
      }
      button:active, .btn:active {
        transform: translateY(0);
      }

      /* Page Transition Animations */
      @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
      }
      @keyframes fadeOut {
        from { opacity: 1; transform: translateY(0); }
        to { opacity: 0; transform: translateY(-10px); }
      }
      ::view-transition-old(root) {
        animation: fadeOut 0.2s ease-out forwards;
      }
      ::view-transition-new(root) {
        animation: fadeIn 0.3s ease-out forwards;
      }

      /* Print Styles */
      @media print {
        .fixed, header, footer, nav, .back-to-top, #reading-progress, #reading-stats {
          display: none !important;
        }
        body {
          background: white !important;
          color: black !important;
        }
        article {
          max-width: 100% !important;
          box-shadow: none !important;
        }
        a {
          color: black !important;
          text-decoration: underline !important;
        }
        h1, h2, h3 {
          page-break-after: avoid;
        }
        pre, blockquote {
          page-break-inside: avoid;
        }
      }
    </style>

    <script>
      // Mobile menu toggle
      function initMobileMenu() {
        const mobileMenuBtn = document.getElementById('mobile-menu-btn');
        const mobileMenu = document.getElementById('mobile-menu');

        if (mobileMenuBtn && mobileMenu) {
          mobileMenuBtn.addEventListener('click', () => {
            const isHidden = mobileMenu.classList.contains('hidden');
            if (isHidden) {
              mobileMenu.classList.remove('hidden');
            } else {
              mobileMenu.classList.add('hidden');
            }
          });
        }
      }

      // Search handler
      function initSearch() {
        const searchInput = document.getElementById('search-input') as HTMLInputElement;
        if (!searchInput) return;

        searchInput.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' && searchInput.value.trim()) {
            const query = encodeURIComponent(searchInput.value.trim());
            window.location.href = `/my-blog/search?q=${query}`;
          }
        });
      }

      initMobileMenu();
      initSearch();
      document.addEventListener('astro:after-swap', () => {
        initMobileMenu();
        initSearch();
      });
    </script>
    <CopyButton />
    <LazyImage />
    <Lightbox />
    <ThemeColorPicker />
    <ShareCard />
    <KeyboardShortcuts />
    <Newsletter />
    <ScrollAnimations />
    <CopyLinkBubble />
    <BackButton />
    <RandomPost />
    <ShortcutHelp />
    <ReadingStats />
    <SeriesNav />
    <SmoothScroll />
    <EditOnGitHub />
    <WelcomeBack />
    <FloatingShare />
    <ReadingStreak />
    <BatterySaver />
    <DailyGoal />
    <ReadingList />
  </body>
</html>