---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Personal Blog" } = Astro.props;
const BASE = '/my-blog';

const categories = [
  { name: '日常生活', slug: 'daily', icon: '🏠' },
  { name: '音乐分析', slug: 'music', icon: '🎵' },
  { name: '读书鉴赏', slug: 'books', icon: '📚' },
  { name: '电商运营', slug: 'ecommerce', icon: '🛒' },
  { name: '宝可梦', slug: 'pokemon', icon: '⚡' },
];

const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;500;600;700&family=Ma+Shan+Zheng&family=ZCOOL+XiaoWei&display=swap" rel="stylesheet">
  </head>
  <body class="bg-[#faf8f5] text-[#4a4a4a] min-h-screen font-['ZCOOL_XiaoWei']">
    <div class="flex min-h-screen">
      <!-- Sidebar -->
      <aside class="fixed left-0 top-0 h-full w-72 bg-[#fff9f0] border-r-2 border-dashed border-[#8b7355]/30 p-8 flex flex-col" style="border: 3px dashed #c4a882; border-radius: 0 20px 20px 0;">
        <!-- Logo -->
        <div class="mb-12" style="transform: rotate(-1deg);">
          <a href={BASE} class="block group">
            <h1 class="text-3xl font-['Ma_Shan_Zheng'] text-[#5c4a3a] group-hover:text-[#8b6b4a] transition-colors">
              我的博客
            </h1>
            <p class="text-sm text-[#a08060] mt-1 font-['Caveat'] text-lg">记录生活，分享思考</p>
          </a>
        </div>

        <!-- Decorative line -->
        <div class="mb-8">
          <svg width="100%" height="10" viewBox="0 0 200 10" preserveAspectRatio="none">
            <path d="M0,5 Q50,0 100,5 T200,5" stroke="#c4a882" stroke-width="2" fill="none" stroke-dasharray="5,3"/>
          </svg>
        </div>

        <!-- Navigation -->
        <nav class="flex-1">
          <ul class="space-y-3">
            {categories.map((cat) => (
              <li>
                <a
                  href={`${BASE}/category/${cat.slug}`}
                  class={`flex items-center gap-4 px-5 py-3 rounded-xl transition-all duration-200 ${
                    currentPath.includes(cat.slug)
                      ? 'bg-[#ffe4c4] text-[#8b6b4a] border-2 border-[#c4a882] shadow-sm'
                      : 'text-[#6b5a4a] hover:bg-[#fff5e6] border-2 border-transparent hover:border-dashed hover:border-[#c4a882]'
                  }`}
                  style="transform: rotate(0deg);"
                >
                  <span class="text-2xl">{cat.icon}</span>
                  <span class="font-['Caveat'] text-xl">{cat.name}</span>
                </a>
              </li>
            ))}
          </ul>
        </nav>

        <!-- Decorative corner -->
        <div class="mt-8 pt-6 border-t-2 border-dashed border-[#c4a882]/50">
          <div class="text-center">
            <svg width="60" height="60" viewBox="0 0 60 60" class="mx-auto opacity-50">
              <circle cx="30" cy="30" r="25" stroke="#c4a882" stroke-width="2" fill="none" stroke-dasharray="3,3"/>
              <text x="30" y="35" text-anchor="middle" fill="#c4a882" font-size="14" font-family="Caveat">✿</text>
            </svg>
          </div>
        </div>
      </aside>

      <!-- Main Content -->
      <main class="ml-72 flex-1 p-12">
        <div class="max-w-4xl mx-auto">
          <slot />
        </div>
      </main>
    </div>

    <style is:global>
      * {
        font-family: 'ZCOOL XiaoWei', 'Caveat', serif;
      }
      h1, h2, h3 {
        font-family: 'Ma Shan Zheng', cursive;
      }
      body {
        background-image: url("data:image/svg+xml,%3Csvg width='100' height='100' viewBox='0 0 100 100' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='50' cy='50' r='1' fill='%23e8dcc8' fill-opacity='0.4'/%3E%3C/svg%3E");
      }
      a:hover {
        text-decoration: none;
      }
      ::selection {
        background: #ffe4c4;
        color: #8b6b4a;
      }
      ::-webkit-scrollbar {
        width: 8px;
      }
      ::-webkit-scrollbar-track {
        background: #faf8f5;
      }
      ::-webkit-scrollbar-thumb {
        background: #c4a882;
        border-radius: 4px;
      }
    </style>
  </body>
</html>